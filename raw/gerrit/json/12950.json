    {
      "id": "87e2e79541b25d1f59f7139e325f04f851e67c40",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2014-12-16 17:56:14.000000000",
      "message": "Patch Set 2: Code-Review-1\n\n(10 comments)\n\nThis definitely needs a test in conf-sanity to verify that it is working properly.\n\nMy preference on the user interface would be:\n\n    mount -t lustre mgsnid:/fsname/subdir_name /mountpoint\n\nsince it looks more like a subdirectory, but that is just an idea. I'm not sure if that is easy to implement or not. \n\nAlso, there was an old patch for this in http://review.whamcloud.com/5007 That you should look at in case it has useful changes or tests.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "cdf4f279ce4bc76b07103ac136e764129f6e8920",
      "author": {
        "_account_id": 435,
        "name": "Shilong Wang",
        "email": "wshilong@ddn.com",
        "username": "wshilong",
        "inactive": true
      },
      "date": "2015-01-29 05:26:34.000000000",
      "message": "Patch Set 2:\n\nHello Andreas,\n\nSorry for late reply,\n\nIt seems there http://review.whamcloud.com/5007 LU-28 had some discussions about this feature and final conclusion is that we should avoid client change and use second way.\n\nSo i could help rebase LU-28 and push it agian.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "66f2b796ba37d909a62f356b9ce4db69a80821b0",
      "author": {
        "_account_id": 143,
        "name": "Yang Sheng",
        "email": "ys@whamcloud.com",
        "username": "ys"
      },
      "date": "2015-01-29 10:01:21.000000000",
      "message": "Patch Set 2:\n\nSo we won't use mount_subtree for subdir option. right?",
      "accounts_in_message": [],
      "_revision_number": 2
    },
