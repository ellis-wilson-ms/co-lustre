    {
      "id": "bc5ab568b91f708bf571151bb90f8c0e182da0a3",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2014-02-12 04:05:22.000000000",
      "message": "Patch Set 3:\n\nAlex, I think you mentioned it elsewhere, but why not use the dn_parent to find the parent directory in case the LMA is broken?\n\nIn any case, I don't think that this is a blocker for landing the scrub support, since this consistency issue is really related to ZFS itself. Hopefully the checksums and metadata mirroring should avoid the need to fix the parent link.",
      "accounts_in_message": [],
      "_revision_number": 3
    },
