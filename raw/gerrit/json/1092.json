        "username": "prakash"
      },
      "date": "2011-08-08 17:27:04.000000000",
      "message": "Patch Set 3:\n\nCreated the JIRA ticket as requested: http://jira.whamcloud.com/browse/LU-576",
      "accounts_in_message": [],
      "_revision_number": 3
    },
