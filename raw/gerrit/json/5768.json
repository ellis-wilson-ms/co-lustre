        "name": "Jeff Mahoney",
        "email": "jeffm@suse.com",
        "username": "jeffm"
      },
      "date": "2013-03-20 21:37:57.000000000",
      "message": "Patch Set 2:\n\nBTW, this builds ok with RHEL6 as well.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
