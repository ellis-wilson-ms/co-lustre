    {
      "id": "ea9821ac89d13ebc6b56bf2597c3c75ae93037fe",
      "author": {
        "_account_id": 743,
        "name": "Anna Fuchs",
        "email": "anna.fuchs@informatik.uni-hamburg.de",
        "username": "fuchs"
      },
      "date": "2019-04-12 13:01:11.000000000",
      "message": "Patch Set 3:\n\nCompression algorithms usually require source and destination buffers.\nIn case of lz4 those have to be contiguous. While running the system,\nit becomes difficult to allocate big contiguous pages. Therefore we\ndecided to implement a buffer pool which will be initialized before fs runs. Data in Lustre is accessed page-wise; the pool is able to access and free the memory buffers by buffer pointer or page-wise.",
      "accounts_in_message": [],
      "_revision_number": 3
    },
