    {
      "id": "20ed67133fff175978c78f593271d2e37cac285a",
      "author": {
        "_account_id": 304,
        "name": "Malcolm Cowe",
        "email": "malcolm.j.cowe@intel.com",
        "username": "malkolm",
        "inactive": true
      },
      "date": "2013-08-23 03:50:21.000000000",
      "message": "Patch Set 1: Verified\n\nVerified the change on a small test platform. Works as designed but see LU-3828 for possible follow-on work.\n\nMethod:\n\nOn first use of HSM, archive is automatically set to 1 and archive commands work as expected (when no archive is specified, default is selected automatically).\n\nUsing lctl set_param on the MDS to change the default works as expected and lfs hsm_archive command picks up the change.\n\nUsing lctl hsm_archive with --archive flag still works as expected (no negative impact).",
      "accounts_in_message": [],
      "_revision_number": 1
    },
