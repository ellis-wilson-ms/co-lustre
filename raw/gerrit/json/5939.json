  "messages": [
    {
      "id": "a6a1e8d4437ecd6ddde9006a747db65bc1d91b69",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2013-04-04 00:10:47.000000000",
      "message": "Patch Set 1:\n\nNot necessarily a -review, but why did you fix it by removing the 'static' instead of removing the EXPORT_SYMBOL()? Doesn't seem to be needed or used by anybody external.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "ba12b03e869ad531c7822cd0018da0cf00968cef",
      "author": {
        "_account_id": 109,
        "name": "Christopher J. Morrone",
        "email": "morrone2@llnl.gov",
        "username": "morrone"
      },
      "date": "2013-04-04 00:40:46.000000000",
      "message": "Patch Set 1:\n\nSomewhat a toss of the coin.  But I tried to be consistent with the mirror function linkea_entry_unpack().  I figure that if we want the API to export linkea_entry_unpack() it makes sense to export linkea_entry_pack(), whether or not it is currently used.\n\nBut I'm not wed to that.  I'd be fine with removing the EXPORT_SYMBOL() instead.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
