    {
      "id": "fcf562b4750b88a4c7828b67b9158b9b56ad2c96",
      "author": {
        "_account_id": 377,
        "name": "wc-checkpatch",
        "username": "hpdd-checkpatch",
        "tags": [
          "SERVICE_USER"
        ]
      },
      "date": "2016-04-18 15:14:42.000000000",
      "message": "Patch Set 4:\n\nLooks good to me.",
      "accounts_in_message": [],
