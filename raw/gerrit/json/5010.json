        "email": "lai.siyao@whamcloud.com",
        "username": "laisiyao"
      },
      "date": "2013-03-07 13:08:38.000000000",
      "message": "Uploaded patch set 6.",
      "accounts_in_message": [],
      "_revision_number": 6
    },
