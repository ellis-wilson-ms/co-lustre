    {
      "id": "e68a7bb69d861fc652d6c43b8051af1894150333",
      "author": {
        "_account_id": 7,
        "name": "Johann Lombardi",
        "email": "johann.lombardi@intel.com",
        "username": "johann",
        "inactive": true
      },
      "date": "2011-05-13 04:10:34.000000000",
      "message": "Patch Set 2: Looks good to me, approved\n\n",
