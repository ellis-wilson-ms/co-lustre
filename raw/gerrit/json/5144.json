        "email": "morrone2@llnl.gov",
        "username": "morrone"
      },
      "date": "2013-01-24 22:21:01.000000000",
      "message": "Patch Set 1: Looks good to me, but someone else must approve\n\n",
      "accounts_in_message": [],
      "_revision_number": 1
    },
