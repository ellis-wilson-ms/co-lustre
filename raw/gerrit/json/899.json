    {
      "id": "b0e59077355e49c4f39da9441d19eac8696c6074",
      "author": {
        "_account_id": 118,
        "name": "Mikhail Pershin",
        "email": "mpershin@whamcloud.com",
        "username": "tappro"
      },
      "date": "2011-06-07 14:50:07.000000000",
      "message": "Patch Set 1:\n\nAndreas, I am using counter to indicate only zombies in destroy, it is incremented when zombie is deleted from list, not added, that is why we need to check lists too. I was just going to wait for export destroy there. Do you think this counter should be modified to zombie counter? I.e. increased when new zombie is added into the list and decreased upon destroy so don't need to check lists as you mentioned.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "4941293c7d6c8ba3082b4282d61ef96412dea263",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2011-06-07 17:38:26.000000000",
      "message": "Patch Set 1:\n\nYes, I think the counter should be incremented when a zombie is added, and decremented when removed, so that there is no need to check the lists at all (except of course to find imports or exports to be cleaned up).",
      "accounts_in_message": [],
      "_revision_number": 1
    },
