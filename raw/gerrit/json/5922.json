      },
      "date": "2013-04-17 06:54:02.000000000",
      "message": "Patch Set 3:\n\nIf I understand correct, you disagree with logic that we have \n1) preprocessed request with export reference\nand\n2) active request with export reference and rpc counter\n\nI will update patch.",
      "accounts_in_message": [],
      "_revision_number": 3
    },
