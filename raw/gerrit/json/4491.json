    {
      "id": "80db2adf5234fb86bc55996434132fff9b3121b0",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2012-12-17 06:01:10.000000000",
      "message": "Patch Set 2:\n\nIs this going to break our ability to get module symbols easily in maloo? do we collect lustre-debuginfo rpms?",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "5a71d2e5932ed460d2d9a2155c1aa00121c7f890",
      "author": {
        "_account_id": 257,
        "name": "Keith Mannthey",
        "email": "keith.mannthey@intel.com",
        "username": "kmannth",
        "inactive": true
      },
      "date": "2013-01-05 03:08:27.000000000",
      "message": "Patch Set 2: Looks good to me, but someone else must approve\n\nOleg I didn't know Maloo consumes debuginfo, can you elaborate on your concern?  Allowing perf and similar tools to work without hassle is a good thing.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "66ef0ba70f23af6f0aefa831de8bdeca6bda3978",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2013-01-08 05:10:12.000000000",
      "message": "Patch Set 2: Looks good to me, approved\n\nI just verified that we do build debuginfo rpms, so we are probably fine there.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "cc9d6664be26fee400aaef57e700d47ba80d18fe",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2013-01-08 05:10:12.000000000",
      "message": "Change has been successfully cherry-picked as a0588122758ad4a8c2764c1dfa1b45097e0c95da.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "a5cdca2348613d270b1f9aeba0755c090567ad6f",
      "author": {
        "_account_id": 109,
        "name": "Christopher J. Morrone",
        "email": "morrone2@llnl.gov",
        "username": "morrone"
      },
      "date": "2013-01-08 22:33:04.000000000",
      "message": "Patch Set 2:\n\nWhy did this patch also touch m4 files?  That is not mentioned in the comment.\n\nNote that while you are correct that the .ko files need to be exectuable for find-debuginfo.sh to generate a debuginfo package, you should correct the permissions back to non-exectuable in the %files section.\n\nI'll clean that up in the LU-1199 at some point.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "30c4e659b0bfb224d3774fe0837724294de7c39b",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2013-01-08 22:56:13.000000000",
      "message": "Patch Set 2:\n\nThe m4 changes are to avoid https://bugzilla.redhat.com/show_bug.cgi?id=304121.\n\n# ./configure --with-linux=/usr/src/linux-2.6.32-279.11.1.el6.lm.x86_64/ --with-o2ib=/opt/ofed/src/openib/\n...\n# make rpms\n...\nextracting debug info from /root/rpmbuild/BUILDROOT/lustre-2.3.54-2.6.32_279.11.1.el6.lm.x86_64_g7f57b6a.x86_64/lib/mod\nules/2.6.32-279.11.1.el6.lm.x86_64/updates/kernel/net/lustre/ko2iblnd.ko\n/usr/lib/rpm/debugedit: canonicalization unexpectedly shrank by one character\nerror: Bad exit status from /var/tmp/rpm-tmp.pTyzxn (%install)",
      "accounts_in_message": [],
      "_revision_number": 2
    }
  ],
