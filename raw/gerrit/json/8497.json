    {
      "id": "81850763ba32509c7aecfe68dbe8310f968c5ad6",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2013-12-09 14:50:50.000000000",
      "message": "Patch Set 1: Looks good to me, but someone else must approve\n\n(1 inline comment)\n\nIn general this mod replaces 6.4 support with 6.5.  It would be good to keep the capability to build either or both.  We do so for SLES11 SP2 and SP3, it should be possible for 6.4 and 6.5.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "92a7de43d47c6d9090f29e268d576edf0a917493",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2013-12-09 14:51:01.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\n",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "2ca6fb01c101c9974bf78988bbeee942f9f57338",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2013-12-09 14:53:40.000000000",
      "message": "Patch Set 1:\n\nI agree that this mod is a good starting basis for test only.  It gives us something to look at, review, and test with.  We can make it better and production worthy incrementally.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "d7b12c37cae9bde60b28a417931b83bf878babd3",
      "author": {
        "_account_id": 125,
        "name": "James Simmons",
        "email": "jsimmons@infradead.org",
        "username": "jsimmons"
      },
      "date": "2013-12-09 15:24:18.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nI agree with Bob. Also the functionality behind HAVE_LDISKFS_GET_BLOCKS is handled with patch\nhttp://review.whamcloud.com/#/c/8116",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "cf2d708f1cecfb81a3f0802284bb8e2390d2acae",
      "author": {
        "_account_id": 143,
        "name": "Yang Sheng",
        "email": "ys@whamcloud.com",
        "username": "ys"
      },
      "date": "2013-12-09 18:46:39.000000000",
      "message": "Patch Set 1:\n\nHi, Bob, James,\nThis is just a test patch. So i include some dup patch. And one thing i want to point is that the rhel6.5 removed ext4_ext_walk_space but hasn't forward enough to ext4_map_blocks. So we cannot use #8119 and must change it. Any advise is appreciated.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
