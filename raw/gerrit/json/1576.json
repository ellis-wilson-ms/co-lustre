      },
      "date": "2012-01-04 11:25:54.000000000",
      "message": "Patch Set 1:\n\nI tried the patch but it didn't work. \"./configure --disable-server; make rpm\" still produced lustre.rpm instead of lustre-client.rpm.\n\nHowever, the following change works for me. Not sure if it is appropriate though.\n\n lustre.spec.in |    2 +-\n 1 files changed, 1 insertions(+), 1 deletions(-)\n\ndiff --git a/lustre.spec.in b/lustre.spec.in\nindex cd914af..6bae65d 100644\n--- a/lustre.spec.in\n+++ b/lustre.spec.in\n@@ -17,7 +17,7 @@\n # always append the buildid, even when the caller defines %release\n %define fullrelease %{myrelease}%{buildid}\n\n-%{!?lustre_name: %define lustre_name lustre}\n+%{!?lustre_name: %define lustre_name %(patchless=$(echo \"%configure_args\" | grep \"\\\\-\\\\-disable\\\\-server\"); if [ -n \"$patchless\" ]; then echo \"lustre-client\"; else echo \"lustre\"; fi)}\n %{!?build_lustre_tests: %define build_lustre_tests 1}\n\n # in order to get kernel symset and/or kernel module dependencies into",
      "accounts_in_message": [],
      "_revision_number": 1
    },
