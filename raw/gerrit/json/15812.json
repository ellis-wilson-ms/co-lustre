    {
      "id": "b08461b292fdca8d92b7ac0f716d1e69813c2755",
      "author": {
        "_account_id": 104,
        "name": "Niu Yawei",
        "email": "yawei.niu@intel.com",
        "username": "niu",
        "inactive": true
      },
      "date": "2015-07-31 11:52:08.000000000",
      "message": "Patch Set 1:\n\nI'm wondering if we should just re-generate XID for replay requests.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "aaf43bfcb95474e0a461247954631f3609fafef3",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2015-07-31 11:54:29.000000000",
      "message": "Patch Set 1:\n\nwhat do you mean by \"regenerate XID\" ?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "169144b5a6d704ebe7f9a2a3068ff41603eed1ae",
      "author": {
        "_account_id": 147,
        "name": "Maloo",
        "email": "maloo@whamcloud.com",
        "username": "maloo",
        "tags": [
          "SERVICE_USER"
        ]
      },
      "date": "2015-07-31 12:32:19.000000000",
      "message": "Patch Set 1: Verified+1\n\nTests received by maloo, run on CentOS release 6.6/x86_64: (https://testing.hpdd.intel.com/test_sessions/e3deb166-377f-11e5-a40a-5254006e85c2).  Ran 13 tests.  No failures.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "1b3a542313fbdbe74ebd89b6705a4b51d0c995ff",
      "author": {
        "_account_id": 104,
        "name": "Niu Yawei",
        "email": "yawei.niu@intel.com",
        "username": "niu",
        "inactive": true
      },
      "date": "2015-07-31 12:38:27.000000000",
      "message": "Patch Set 1:\n\nI mean we should use new XID for the replay request, which looks nature to me. Though it won't fix this problem, it can make sure all replay requests have a greater XID than connect's.\n\nTo fix this problem, I think I can update my patch to not remove the request from unreplied list when it's not replied.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "e26b046795530f48e05d95b289c10d708fe53ca1",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2015-07-31 15:25:28.000000000",
      "message": "Patch Set 1:\n\nwe can't use new XID because this would break the recovery - XID is the only way for the server to detect already-executed request.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "44bda151433eb244553ea1ea83ae7e4574d9af27",
      "author": {
