      "date": "2023-02-25 16:15:29.000000000",
      "message": "Patch Set 2: Code-Review+1\n\n$ cat LUSTRE-VERSION-FILE \nLUSTRE_VERSION = 2.15.54_34_g3fe35b8\n\n-- After fix --\n# echo \"2.15.54_34_g3fe35b8\" | sed -re 's/([0-9]+)\\.([0-9]+)\\.([0-9]+)([-\\._][a-z]*([0-9]+))?.*/\\5/'\n34\n#\n-- Before Fix --\n# echo \"2.15.54_34_g3fe35b8\" | sed -re 's/([0-9]+)\\.([0-9]+)\\.([0-9]+)(\\.([0-9]+))?.*/\\5/'\n#\n\n-- After Fix --\n# lctl get_param mdt.*.exports.*.* | grep target_version\n       target_version: 2.15.54.34\n       target_version: 2.15.54.34\n       target_version: 2.15.54.34\n\n-- Before Fix --\n# lctl get_param mdt.*.exports.*.* | grep target\n       target_version: 2.15.54.0\n       target_version: 2.15.54.0\n       target_version: 2.15.54.0",
      "accounts_in_message": [],
      "_revision_number": 2
    },
