  "messages": [
    {
      "id": "ba63ac58797dade15a427f7a6f208234fbb9a482",
      "author": {
        "_account_id": 109,
        "name": "Christopher J. Morrone",
        "email": "morrone2@llnl.gov",
        "username": "morrone"
      },
      "date": "2012-11-28 05:05:35.000000000",
      "message": "Patch Set 1:\n\nHi guys, let me know what you think about this change.  Its not clear to me why we had all of that more complex version checking when there are macros in autotools to do the same thing.  Perhaps it is just age of the build system, and the checks didn't exist in earlier autotools packages?\n\nIt certainly cuts out a bunch of lines from autogen.sh if we don't need it any more.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "12dee963fa6a0f73cb616a1f9bf13a9f9c090056",
      "author": {
