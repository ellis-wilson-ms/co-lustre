    {
      "id": "5fe6295092014b6f50dfe7271fc4f247bd8f84c8",
      "author": {
        "_account_id": 131,
        "name": "Jian Yu",
        "email": "yujian@whamcloud.com",
        "username": "yujian"
      },
      "date": "2012-09-10 06:47:42.000000000",
      "message": "Patch Set 5: (1 inline comment)\n\n",
      "accounts_in_message": [],
      "_revision_number": 5
    },
    {
      "id": "b3554a1b7ae9b9c9cb3a2b1c2006ee3e2d99989b",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2012-09-17 21:36:25.000000000",
      "message": "Patch Set 5:\n\nthere's got to be a better way. Enabling and disabling them as we progress through releases is bad, is not it?\n\nI think I personally would prefer we just have a separate \"debug config\" that we'd build and use as we see fit no matter in what stage of release path we are",
      "accounts_in_message": [],
      "_revision_number": 5
    },
    {
      "id": "1540aecdbb25f4ce4e14e8309cc3c6a38629bfc8",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2012-11-08 21:46:11.000000000",
      "message": "Patch Set 5:\n\nOleg,\nI know you don't think that committing and then removing these debug options is an ideal situation, at the same time we've lost a couple of months of testing with these options enabled already.\n\nI'd rather get this patch landed now, and then work out a better solution over time instead of doing nothing.",
      "accounts_in_message": [],
      "_revision_number": 5
    },
    {
      "id": "5bb2374614a5fb40fa2e1b614e2341f4030e1d1d",
      "date": "2012-11-09 01:39:24.000000000",
      "message": "Your change could not be merged due to a path conflict.\n\nPlease merge (or rebase) the change locally and upload the resolution for review.",
      "accounts_in_message": [],
      "_revision_number": 5
    },
    {
      "id": "9e307450ab10ee71b4e960a9553f5426cd30c47c",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2012-11-09 01:40:56.000000000",
      "message": "Patch Set 5:\n\nit needs rebasing.\n\nNote, no point in enabling leak checking, I found it to be very memory hungry and in thisdefault config it cannot work anyway due to the number of initial allocations.\n\nbtw, now that I think about it, we probably cannot land it anyway as we lose out perf gathering edge that Cliff runs from time to time on hyperion.\n\nAlso for such a patch in the future I'd love to see debug spinlock and other such stuff to be added too.",
      "accounts_in_message": [],
      "_revision_number": 5
    },
