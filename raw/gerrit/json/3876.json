        "email": "keith.mannthey@intel.com",
        "username": "kmannth",
        "inactive": true
      },
      "date": "2012-09-07 16:35:56.000000000",
      "message": "Patch Set 5: Looks good to me, but someone else must approve\n\n",
      "accounts_in_message": [],
      "_revision_number": 5
