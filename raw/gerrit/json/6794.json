      "date": "2013-07-29 12:56:17.000000000",
      "message": "Patch Set 2:\n\nKnowing that release will revoke layout lock, could you explain why the current release code will not work without this patch?",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "9b9464d2c26839799d0cf7d01c81321d3e086c05",
      "author": {
        "_account_id": 4,
        "name": "Jinshan Xiong",
        "email": "jinshan.xiong@intel.com",
        "username": "Jay",
        "inactive": true
      },
      "date": "2013-07-29 16:52:48.000000000",
      "message": "Patch Set 2:\n\n\"Knowing that release will revoke layout lock, could you explain why the current release code will not work without this patch?\"\n\nIt's required to purge caching pages before changing layout, otherwise stale pages would be left in address space which could be read by a process accessing data via mmap interfaces.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
