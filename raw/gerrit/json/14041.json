    {
      "id": "52dbc09b36bf5fb6b178288563498fb03199f502",
      "author": {
        "_account_id": 301,
        "name": "Dmitry Eremin",
        "email": "dmitry.eremin@intel.com",
        "username": "dmiter",
        "inactive": true
      },
      "date": "2015-04-06 15:08:10.000000000",
      "message": "Patch Set 2: Code-Review+1",
      "accounts_in_message": [],
      "_revision_number": 2
