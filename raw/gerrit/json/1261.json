    {
      "id": "4a58b58af5173cd0143f42a20a1ab024dec10863",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2011-09-22 13:13:32.000000000",
      "message": "Patch Set 6: Looks good to me, approved\n\nThis looks good.\nBTW, it's possible to significantly improve lock cancel processing time for a case of many clients, I think.\n\nI did this for other kinds of locks before.\nBasically the logic is:\n\nIf we are reprocessing a lock from the waiting list and we have found exactly same lock on the waiting list, and it's\nalready marked as PENDING, that means there is no point iterating this list anymore, as there are conflicting locks down the line (that have marked this lock as PENDING).\n\nUnfortunately we cannot do this for 1st enqueue to ensure that all conflicting locks are properly marked.",
      "accounts_in_message": [],
      "_revision_number": 6
    },
    {
      "id": "ff4edd5d910aa410821059b092fb4246f9c07829",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2011-09-22 13:26:04.000000000",
      "message": "Patch Set 6:\n\nbtw I looked into the failures and they seem to be unrelated.",
      "accounts_in_message": [],
      "_revision_number": 6
    },
