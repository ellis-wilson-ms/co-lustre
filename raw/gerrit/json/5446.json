    {
      "id": "1787a1584bffe83cdf4d662609687a7ee1ffb34b",
      "author": {
        "_account_id": 4,
        "name": "Jinshan Xiong",
        "email": "jinshan.xiong@intel.com",
        "username": "Jay",
        "inactive": true
      },
      "date": "2013-03-14 21:58:00.000000000",
      "message": "Patch Set 3: (1 inline comment)\n\n",
