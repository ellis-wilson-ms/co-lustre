      "author": {
        "_account_id": 4,
        "name": "Jinshan Xiong",
        "email": "jinshan.xiong@intel.com",
        "username": "Jay",
        "inactive": true
      },
      "date": "2013-03-14 21:21:53.000000000",
      "message": "Patch Set 3: I would prefer that you didn't submit this\n\nI checked in my updates, but this patch is on hold.",
      "accounts_in_message": [],
      "_revision_number": 3
    },
    {
