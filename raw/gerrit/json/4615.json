    {
      "id": "850674f7973fe5d5e189fd14c615a8ec281d395a",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2012-11-20 19:31:21.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nThis has the same problem that my patch has - the eviction acrually might happen after the check while you are doing sleeping and that's it.\n\nPossible ways to properly handle that is to declare the fail loc to be FAIL_ONCE so we only kill one import, or potentially we'll need to make sure that all imports were evicted - but this then potentially would be prone to infinite waits if not all targets would send blocking RPCs.\n\nOriginal idea for this test was I believe that only MDT would send a blocking AST and as such only it would be evicted from MDT.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
