    {
      "id": "7f165f2f4aa91da67d364fdb946088b24a8e5e76",
      "author": {
        "_account_id": 234,
        "name": "Doug Oucharek",
        "email": "doug@cadentcomputing.com",
        "username": "Doug",
        "inactive": true
      },
      "date": "2016-01-20 00:56:56.000000000",
      "message": "Patch Set 2:\n\nI agree that http://review.whamcloud.com/#/c/17876 is a more interesting patch for master (i.e. 2.9) but is way too much to quickly back-port to previous releases to fix this for those who need a fix immediately.  \n\nI'll port 17876 to this change but it should not be back-ported until properly validated on multiple sites.  In the meantime, the original change of just having a counter should suffice for those who cannot wait for this patch to be validated.  Given the rarity of the window, I would suggest that this change never be back ported.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "149964feac5f32bddc36ebac5ba0cf5dfccc9385",
      "author": {
        "_account_id": 234,
        "name": "Doug Oucharek",
