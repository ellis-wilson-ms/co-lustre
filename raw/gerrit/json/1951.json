    {
      "id": "1607aa51642122b97bd7a7825504e7a3c8de81c3",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2012-08-07 18:49:29.000000000",
      "message": "Patch Set 6: I would prefer that you didn't submit this\n\n(2 inline comments)\n\nMarking this patch with a negative review.\n\nI'd be OK with landing it largely unchanged (after fixing the commit message) as long as NFS re-export was disabled for kernels that will be using this new API.  This will allow their safe usage for most users, and for testing, and allow us to work on a full solution to the NFS export problem without blocking 3.0+ kernels for a long time.\n\nBasically, all that is needed for this is something like:\n\n diff --git a/lustre/llite/llite_lib.c b/lustre/llite/llite_lib.c\n index e62cff7..bdb94d9 100644\n --- a/lustre/llite/llite_lib.c\n +++ b/lustre/llite/llite_lib.c\n @@ -463,7 +463,7 @@ static int client_common_fill_super(struct super_block *sb,\n          CDEBUG(D_SUPER, \"rootfid \"DFID\"\\n\", PFID(&sbi->ll_root_fid));\n \n          sb->s_op = &lustre_super_operations;\n -#if THREAD_SIZE >= 8192\n +#if THREAD_SIZE >= 8192 /*b=17630*/ && !defined(HAVE_FSTYPE_MOUNT) /*LU-812*/\n         sb->s_export_op = &lustre_export_operations;\n  #endif",
      "accounts_in_message": [],
      "_revision_number": 6
    },
    {
      "id": "84411b7a663dadb4b2c2ae355aff6853724be567",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2012-08-07 20:10:44.000000000",
      "message": "Uploaded patch set 7.",
      "accounts_in_message": [],
      "_revision_number": 7
    },
    {
      "id": "d61fba85813fb16158265de969a029b746df712b",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2012-08-07 20:21:03.000000000",
      "message": "Patch Set 7: Looks good to me, approved\n\nWere this to be submitted again, it probably deserves some extra comments on why NFS export is being disabled for newer kernels, but that can be found in the comments on this change, and will hopefully not be around too long, so it isn't worthwhile to block the patch further.",
      "accounts_in_message": [],
      "_revision_number": 7
    },
