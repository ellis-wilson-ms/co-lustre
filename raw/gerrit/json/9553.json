    {
      "id": "a8668264f3bce6503eeb0de34a478e0d2637beac",
      "author": {
        "_account_id": 11,
        "name": "Michael MacDonald",
        "email": "michael.macdonald@intel.com",
        "username": "mjmac",
        "inactive": true
      },
      "date": "2014-03-08 19:50:44.000000000",
      "message": "Patch Set 2:\n\nOK. I like your approach with fmemopen(); very clever. Question, though: If we are writing < PIPE_BUF, then do we even need the mutex?\n\nhttp://man7.org/linux/man-pages/man7/pipe.7.html\nPOSIX.1-2001 says that write(2)s of less than PIPE_BUF bytes must be\n       atomic: the output data is written to the pipe as a contiguous\n       sequence.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "6451955abba56af64bcac287bf84cb65ce0706d6",
      "author": {
        "_account_id": 11,
        "name": "Michael MacDonald",
        "email": "michael.macdonald@intel.com",
        "username": "mjmac",
        "inactive": true
      },
      "date": "2014-03-08 19:52:02.000000000",
      "message": "Patch Set 2:\n\nHmm. Never mind. I should have read more thoroughly. With O_NONBLOCK that atomicity isn't guaranteed. Alrighty then...",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "4961d80c972221f8dfb2a15f37a98cf8b8f51c64",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2014-03-08 21:57:35.000000000",
