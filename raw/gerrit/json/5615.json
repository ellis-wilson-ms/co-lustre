    {
      "id": "bb939ceccf5b7001a444ef0bc337f7d9abb9cdeb",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2013-03-11 15:01:03.000000000",
      "message": "Patch Set 1:\n\nIs this change even necessary?  Removing LB_LINUX_MODPOST from lustre/autoconf seems OK, but the build appears to work correctly even without it in ldiskfs/config.  Maybe it should just be deleted entirely.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "37da12745162d24bc01dafbda48a8886d53dabe0",
      "author": {
        "_account_id": 198,
        "name": "Minh Diep",
        "email": "mdiep@whamcloud.com",
        "username": "mdiep"
      },
      "date": "2013-03-11 15:04:27.000000000",
      "message": "Patch Set 1:\n\nI am not entirely sure. there's a call from ldiskfs",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "a48c53f7df504f2e8169ec51d34a86962e4acdbf",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2013-03-11 15:07:36.000000000",
      "message": "Patch Set 1:\n\nYes, I see there is a call.  Pretty sure that's where the error reported in the bug comes from.  I'm suggesting that call should be deleted too.  The build seems to go OK without it.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
