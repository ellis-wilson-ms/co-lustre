      "date": "2019-04-03 18:11:34.000000000",
      "message": "Patch Set 2:\n\nPassed enforced test review-zfs on CentOS 7.0/x86_64 uploaded by AT Release Candidate from trevis-72vm6: https://testing.whamcloud.com/test_sessions/d70b05f6-b883-4445-b803-41f09846f31d ran 7 tests.",
      "accounts_in_message": [],
      "_revision_number": 2
