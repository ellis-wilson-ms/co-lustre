    },
    {
      "id": "860fd6cd2e378d70d1c8126b95e7ba6ce9ef36d8",
      "author": {
        "_account_id": 377,
        "name": "wc-checkpatch",
        "username": "hpdd-checkpatch",
        "tags": [
          "SERVICE_USER"
        ]
      },
      "date": "2014-09-02 08:25:12.000000000",
      "message": "Patch Set 2:\n\nLooks good to me.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "ad0f2eb073f80b772dcde2ca587ab6b7572a75f2",
      "author": {
        "_account_id": 136,
        "name": "Alexey Lyashkov",
        "email": "alexey.lyashkov@hpe.com",
        "username": "shadow"
      },
      "date": "2014-09-02 08:26:45.000000000",
      "message": "Patch Set 1:\n\nwhy should not? bulk transfer it's simple LNetGET/LNetPut message, so LNet should be responsible to deliver it request to the destination.\nIf LNet not does it now, so it's just LNet bug. Alex Boyko have demonstrated it half year ago. LNetUnlink vs incoming message race on client side. LNet drops request as none match bits registered in LNet.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "ab3f9fe335d5892f94dc7bc40ece13ac66a52ec8",
      "author": {
        "_account_id": 136,
        "name": "Alexey Lyashkov",
        "email": "alexey.lyashkov@hpe.com",
        "username": "shadow"
      },
      "date": "2014-09-02 08:29:51.000000000",
      "message": "Patch Set 2:\n\nanyway we don't able to resend a bulk due simple bug in ptlrpc - where same XID assigned to the bulk transfer and RPC transfer itself. So we need to fix root cause of it, instead of add some hacks.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "9cb1fdd96e20b2ce3601ef0345f239ac3f8a20aa",
      "author": {
