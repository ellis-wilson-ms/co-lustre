    {
      "id": "1cc373db4c233e4ca67085dad7c78831452aa65a",
      "author": {
        "_account_id": 2,
        "name": "Jenkins",
        "username": "hudson",
        "inactive": true
      },
      "date": "2014-10-11 08:26:19.000000000",
      "message": "Patch Set 3: Verified+1\n\nBuild Successful \n \nhttps://build.hpdd.intel.com/job/lustre-reviews/27454/ : SUCCESS",
      "accounts_in_message": [],
