      },
      "date": "2013-10-24 20:52:01.000000000",
      "message": "Patch Set 5: Looks good to me, but someone else must approve\n\nThis version looks good to me.  One improvement to consider:\n\nIf %kernel_module_package is used, the distribution macros define %kernel_module_package_moddir.  The distribution may define %kernel_module_package_moddir even without %kernel_module_package.\n\nThis can be used in the rpm spec now, even though the spec does not use %kernel_module_package.  Just provide a default if it is not set when it is evaluated.",
      "accounts_in_message": [],
      "_revision_number": 5
    },
