    {
      "id": "46864fac5cf9c07560cdff58d841edb40434525d",
      "author": {
        "_account_id": 137,
        "name": "Richard Henwood",
        "email": "richard.henwood@intel.com",
        "username": "rhenwood",
        "inactive": true
      },
      "date": "2012-05-14 22:22:56.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nI would like both usages to specify 'poollist' as 'pool_list' is not the 'correct' usage.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "5bf5e37f6ce0286008d15b92f0830fdb8a0a4551",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2012-05-14 22:33:13.000000000",
      "message": "Patch Set 1:\n\nRichard, I don't agree.  From a functional standpoint both usages are equally correct.  I think it would be confusing to have a usage help string that looked different from the actual command string.  This is especially true since we're not changing documentation to indicate that the 'poollist' form is preferred in any way.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
