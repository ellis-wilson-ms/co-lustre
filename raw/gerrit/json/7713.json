    {
      "id": "579f41d7838f4776a9e740a365e89bbb222724b8",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2013-09-23 14:55:12.000000000",
      "message": "Patch Set 1:\n\nDmitry, pretty sure RPMSMPTYPE is still used elsewhere in lbuild.  It seems to be needed to generate proper rpm names for SuSE.  rpm naming conventions in SuSE are awfully strange.\n\nSetting the variable could maybe be simplified a bit, but I'm nervous about touching pieces of lbuild I don't need to.  I don't understand it well enough. The intent of this mod is limited to removing the need for 2 identical copies of kernel configs with different names.  That alone will make it easier to update for new SuSE kernel versions in the future.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
