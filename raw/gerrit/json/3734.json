    {
      "id": "f95cbcab7e428834e821318a523bef8245a4653f",
      "author": {
        "_account_id": 125,
        "name": "James Simmons",
        "email": "jsimmons@infradead.org",
        "username": "jsimmons"
      },
      "date": "2012-09-28 12:30:21.000000000",
      "message": "Patch Set 11: Looks good to me, but someone else must approve\n\nTested for client support, works fine. As for server support all I did was copy 2.6-rhel6.series over to 3.0-sles11.series. Then did a configure --with-linux=... --with-linux-obj=... --enable-server --enable-zfs --disable-ldiskfs. Then build. It works as long as you don't enable ldiskfs since that requires alot more love. In theory you could support SuSE server for ZFS today.",
      "accounts_in_message": [],
      "_revision_number": 11
    },
