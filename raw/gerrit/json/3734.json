    {
      "id": "92703b18892bf5e38156e6fa22c429a78a880d9c",
      "author": {
        "_account_id": 125,
        "name": "James Simmons",
        "email": "jsimmons@infradead.org",
        "username": "jsimmons"
      },
      "date": "2012-09-27 18:09:12.000000000",
      "message": "Patch Set 10: I would prefer that you didn't submit this\n\nJust tried the server side build which failed. I copied the 2.6-rhel6.series file over to 3.0-sles11.series and it worked.",
      "accounts_in_message": [],
      "_revision_number": 10
    },
    {
      "id": "113788d0037c6ceb3f980747ea6cf86931e069c7",
      "author": {
        "_account_id": 110,
        "name": "Chris Gearing",
        "email": "chris.gearing@intel.com",
        "username": "chris",
        "inactive": true
      },
      "date": "2012-09-27 19:45:56.000000000",
      "message": "Patch Set 10:\n\nJames,\n\nCan you elaborate on what you did to make server work. Are you saying the  2.6 SLES server compiles with the 2.6-sles11.series but the 3.0 SLES server requires the redhat series file.\n\nThis seems strange to say the least, and if so probably requires another ticket to be opened. The scope of this ticket is SLES Client support, in fact I was going to fill the 3.0-sles11.series file with a note saying 3.0 Server is not supported.",
      "accounts_in_message": [],
      "_revision_number": 10
    },
    {
      "id": "c222f67c08b4faa2e29da291ce18435522db464f",
      "author": {
        "_account_id": 147,
        "name": "Maloo",
        "email": "maloo@whamcloud.com",
        "username": "maloo",
        "tags": [
          "SERVICE_USER"
