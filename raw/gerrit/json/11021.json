    {
      "id": "3728f9f8d3871c027ff7cf51cff65ac2bb2cfa00",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2014-07-15 03:39:08.000000000",
      "message": "Patch Set 3: Code-Review-1\n\nsounds like there's now agreement that the patch shoudl be redone with wait_for_completion_interruptible instead.",
      "accounts_in_message": [],
      "_revision_number": 3
    },
    {
      "id": "6a6b86f0e9003e32c000f08c440543b15f6ad956",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2014-07-15 07:55:19.000000000",
      "message": "Patch Set 3:\n\nI would prefer if we stayed with wait_event_killable() for now.  It isn't clear that it makes sense to interrupt IO currently in flight in the kernel if the process is interrupted, and if this won't cause potential data write ordering problems.",
      "accounts_in_message": [],
      "_revision_number": 3
    },
