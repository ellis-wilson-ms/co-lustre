  "current_revision_number": 9,
  "current_revision": "d1d5446befc4cef4b6832e9b1708f9314f6adae7",
  "revisions": {
    "d1d5446befc4cef4b6832e9b1708f9314f6adae7": {
      "kind": "TRIVIAL_REBASE_WITH_MESSAGE_UPDATE",
      "_number": 9,
      "created": "2013-09-27 15:33:07.000000000",
      "uploader": {
        "_account_id": 112,
        "name": "Oleg Drokin",
