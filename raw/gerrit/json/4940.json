    {
      "id": "4753245992260c6ef73350813f46eb0d7810a22b",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-01-02 06:49:31.000000000",
      "message": "Patch Set 1: Looks good to me, but someone else must approve\n\nPatch looks ok, but might be improved.\n\nDoes it make sense to round the allocation up to some nice power-of-two value, to avoid memory wastage internal to the allocator?\n\nDoes it make sense to also increase the size of the OST request buffers in a similar manner?\n\nShould this be handled inside the ptlrpc service setup, and based on the MAX_REQSIZE parameter and just be a multiple of this size (e.g. 2.1x the maximum request size)?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "547ba5e803d1de47302490e737a45dab5efb590f",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-01-15 08:52:07.000000000",
      "message": "Patch Set 1:\n\nIf the OST bulk RPCs are also increasing in size (http://review.whamcloud.com/4993), does it make sense to increase OST_BUFSIZE in a similar manner?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
