    {
      "id": "8d9a7b9c517c79d120e29fd538fc8c5ca7db0bb0",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2013-12-16 18:11:46.000000000",
      "message": "Patch Set 5: I would prefer that you didn't submit this\n\nThis breaks sanity-hsm test 21 since there we need to return the open lock for release even if the file has no layout. This should be combined with http://review.whamcloud.com/#/c/8084/ or else this patch should depend on that one.\n\nSecond, the structure needs improvement. If create_layout is true then we should not take an open lock in the first place, rather than taking then canceling as the patch does.",
      "accounts_in_message": [],
      "_revision_number": 5
    },
    {
      "id": "0e331d022f8277c82d3466f44610270fd60b3c74",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2013-12-18 03:53:04.000000000",
      "message": "Patch Set 5:\n\nActually we must take the open lock even if there is no layout.\nThis is because the open lock taking will flush the existing conflicting open locks held by other clients.\nIf we don't do that, then the clients will continue to hold the locks and cached filehandles that might prevent us from opening a file for write or for exec.\nSee bugzilla bug 2443 for more details.",
      "accounts_in_message": [],
      "_revision_number": 5
    },
