    {
      "id": "3b4899a899dd82a16131a86f5044c086c6643147",
      "author": {
        "_account_id": 931,
        "name": "Timothy Day",
        "email": "timday@thelustrecollective.com",
        "username": "timday"
      },
      "date": "2024-01-10 22:02:13.000000000",
      "message": "Patch Set 3:\n\nIf a developer runs vagrant anywhere in the Lustre tree, the top-level Vagrantfile will get picked up. I don't think vagrant is common enough for this to be impactful. Worst case, we can move the file to contrib (or add multiple configurations to the Vagrantfile).",
      "accounts_in_message": [],
      "_revision_number": 3
    },
