    {
      "id": "49e62675368bf0f30ef7781ccc252d38766433a4",
      "author": {
        "_account_id": 131,
        "name": "Jian Yu",
        "email": "yujian@whamcloud.com",
        "username": "yujian"
      },
      "date": "2013-06-06 08:58:41.000000000",
      "message": "Patch Set 2: I would prefer that you didn't submit this\n\nI'd suggest to use trap mechanism for each subtest like ost-pools.sh and sanity-quota.sh, e.g.:\n\n cleanup() {\n         trap 0\n         ......\n }\n\n set_cleanup_trap() {\n         trap cleanup EXIT\n }\n\n test_0() {\n         set_cleanup_trap\n         setup\n         check_mount || error \"check_mount failed\"\n         cleanup\n }\n run_test 0 \"single mount setup\"",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "b2430c61f0ff284aee5c15a573afe8e473782f28",
      "author": {
        "_account_id": 103,
        "name": "Zhenyu Xu",
        "email": "bobijam@whamcloud.com",
        "username": "bobijam"
      },
      "date": "2013-06-06 09:02:48.000000000",
      "message": "Patch Set 2:\n\nconf-sanity.sh has different cleanup codes for each test case, not suitable to use an uniform cleanup function for all test cases.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "c22b755534fd9dc27de8db573a98c45bef393f70",
      "author": {
        "_account_id": 131,
        "name": "Jian Yu",
        "email": "yujian@whamcloud.com",
        "username": "yujian"
      },
      "date": "2013-06-06 09:59:36.000000000",
      "message": "Patch Set 2:\n\nThe method can simplify lots of \"error_noexit ...; cleanup; return ...;\" codes to just \"error ...\".",
      "accounts_in_message": [],
      "_revision_number": 2
    },
