      "date": "2012-11-25 07:28:44.000000000",
      "message": "Patch Set 2: Abandoned\n\npatch form LU-2104 fix the issue, and is better than this.\n\n--- a/lustre/obdclass/genops.c\n+++ b/lustre/obdclass/genops.c\n@@ -1370,6 +1370,11 @@ void class_fail_export(struct obd_export *exp)\n         if (obd_dump_on_timeout)\n                 libcfs_debug_dumplog();\n \n+       /* if called during recovery then should keep obd_stale_clients\n+        * consistent */\n+       if (exp->exp_obd->obd_recovering)\n+               exp->exp_obd->obd_stale_clients++;\n+",
      "accounts_in_message": [],
      "_revision_number": 2
