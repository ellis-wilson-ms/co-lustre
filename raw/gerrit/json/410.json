      "author": {
        "_account_id": 7,
        "name": "Johann Lombardi",
        "email": "johann.lombardi@intel.com",
        "username": "johann",
        "inactive": true
      },
      "date": "2011-04-27 13:41:21.000000000",
      "message": "Patch Set 2:\n\nDo we really need to support 64-bit hash value in 1.8?\nWould it be that bad to just stick with 32-bit hash for all 1.8 clients?",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "ac1c34e9dc4e474e038fd7440405e5d4c84705b0",
      "author": {
        "_account_id": 3,
        "name": "Fan Yong",
        "email": "fan.yong@intel.com",
        "username": "nasf",
        "inactive": true
      },
      "date": "2011-04-29 02:28:46.000000000",
      "message": "Patch Set 2:\n\n> Do we really need to support 64-bit hash value in 1.8? Would it be that bad to just stick with 32-bit hash for all 1.8 clients?\n\nWe just want to enable 64-bit hash for \"1.8 client + 2.1 server\" mode. If without such support, we maybe hit bug 20581.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
