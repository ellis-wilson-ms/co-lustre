    {
      "id": "57c9e49060f5b57b616ba966c6e5e36d53aabafd",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2015-03-03 17:26:16.000000000",
      "message": "Patch Set 6:\n\nit seems the root cause is still out there? why are we getting overlapping read/write in the first place?",
      "accounts_in_message": [],
      "_revision_number": 6
    },
    {
      "id": "614417a0923d597b61054cb4c133a359c865e862",
      "author": {
        "_account_id": 443,
        "name": "Andrew Perepechko",
        "email": "andrew.perepechko@hpe.com",
        "username": "panda"
      },
      "date": "2016-05-02 17:42:10.000000000",
      "message": "Patch Set 6:\n\nThat's a duplicate of https://projectlava.xyratex.com/show_bug.cgi?id=20142 which was reintroduced with osd rework.\n\nReads and writes do not overlap.A write goes past the end of file, increasing i_size. An unexpected i_size expansion can lead to a single page in a read request being read short and the next one being read full, which is the reason of the assertion failure.",
      "accounts_in_message": [],
      "_revision_number": 6
    }
  ],
