  "current_revision_number": 6,
  "current_revision": "555eb580e547fb263faee0a4d88482789171211b",
  "revisions": {
    "555eb580e547fb263faee0a4d88482789171211b": {
      "kind": "TRIVIAL_REBASE_WITH_MESSAGE_UPDATE",
      "_number": 6,
      "created": "2014-09-05 00:24:00.000000000",
      "uploader": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "ref": "refs/changes/73/11373/6",
      "fetch": {
