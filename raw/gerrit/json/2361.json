    {
      "id": "dfd25ffeca752e839cc5450068e2dad29a57e806",
      "author": {
        "_account_id": 242,
        "name": "Liu Xuezhao",
        "email": "xuezhao.liu@emc.com",
        "username": "XuezhaoLiu",
        "inactive": true
      },
      "date": "2012-04-03 15:46:32.000000000",
      "message": "Patch Set 1: (1 inline comment)\n\n",
