        "inactive": true
      },
      "date": "2013-03-26 15:44:55.000000000",
      "message": "Patch Set 1: (2 inline comments)\n\nI think we need Alex to confirm that if the changes to the tunefs was intentional.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "42166c09ee2a17d226181193be12573aedbf18b7",
      "author": {
        "_account_id": 104,
        "name": "Niu Yawei",
        "email": "yawei.niu@intel.com",
