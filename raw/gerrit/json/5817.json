    {
      "id": "5744cc36201d4227c0189b1ddaf136215fc655b3",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2013-03-29 06:51:54.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\n(1 inline comment)\n\ngiven UPDATE is not cleared upon mount, we would lead to rewriting a profile on every mount.. i don't think this is good.\nwe need to decide whether we need to modify mountdata to clear UPDATE flag as we were doing previously or we disable this functionality in tunefs.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "23ed6a065111f591de4b17370225f8b600a09b00",
      "author": {
        "_account_id": 125,
        "name": "James Simmons",
        "email": "jsimmons@infradead.org",
        "username": "jsimmons"
      },
      "date": "2013-04-01 13:25:50.000000000",
      "message": "Patch Set 1: No score\n\nAny decision on what to do? I assume lctl conf_param will work as well.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "8d83aa469c86fd1eca7aeb26b729591ac4999eab",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2013-04-03 10:08:10.000000000",
      "message": "Patch Set 1:\n\nto maintain the discussion.. I think there are three options here:\n1) do not use tune2fs for this purpose anymore\n2) use yet another delimiter in the label to store \"update\" status\n3) compare parameters from mountdata vs ones stored on MGS",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
