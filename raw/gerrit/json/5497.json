    {
      "id": "534ac2ea53a94e4bcdaeda0c49d9c06601418859",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-03-08 18:50:34.000000000",
      "message": "Patch Set 4:\n\nHongchao, please assign inspectors when the patch is submitted, instead of resubmitting and retesting the patch multiple times until it passes autotest.\n\nIt might be that you are spending a lot of effort to get the patch to pass testing, but then it will not pass inspection for some reason.  Better to get inspection comments earlier and then you can fix the inspection issues at the same time as you are rebasing the patch to get it to pass testing.",
      "accounts_in_message": [],
      "_revision_number": 4
    },
    {
      "id": "3c59ae6393184e89969422c95c912cb187487968",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2013-03-10 12:08:05.000000000",
      "message": "Patch Set 4: I would prefer that you didn't submit this\n\nI think this is a very tricky solution introducing scalability problems. instead we should be routinely passing env through all the calls (including ldlm).\nthen we can re-use this in OFD as well.",
      "accounts_in_message": [],
      "_revision_number": 4
    },
    {
      "id": "6166c625562839444d6d38d855cd6f1c56b4188f",
      "author": {
        "_account_id": 147,
        "name": "Maloo",
        "email": "maloo@whamcloud.com",
        "username": "maloo",
        "tags": [
          "SERVICE_USER"
        ]
      },
      "date": "2013-03-11 15:32:58.000000000",
      "message": "Patch Set 4: Verified\n\nAutotest results available at https://maloo.whamcloud.com/test_sessions/d614bea0-8835-11e2-b363-52540035b04c",
      "accounts_in_message": [],
      "_revision_number": 4
    },
    {
      "id": "f1b84094b151fca86cde90426e588154dd3a2e8f",
      "author": {
        "_account_id": 144,
        "name": "Hongchao Zhang",
        "email": "hongchao@whamcloud.com",
        "username": "Hongchao.zhang"
      },
      "date": "2013-03-14 10:55:59.000000000",
      "message": "Patch Set 4:\n\nthe LDLM module is also used at client side and it hardly uses the lu_env currently, does we need to add lu_env to LDLM just for this requirement which will increase the stack usage ATM",
      "accounts_in_message": [],
      "_revision_number": 4
    },
    {
      "id": "12225248b3246b9f200eef6355c99d532c046eb8",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2013-03-14 11:02:22.000000000",
      "message": "Patch Set 4:\n\nI think we're more concerned about the servers where CPU is quite often a bottleneck (especially on MDS, where we want as less serialization as possible).",
      "accounts_in_message": [],
      "_revision_number": 4
    },
    {
      "id": "100cd102d96bda3466901cf328ebf602b7b5f5aa",
