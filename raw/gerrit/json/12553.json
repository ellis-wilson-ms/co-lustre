      },
      "date": "2014-12-01 15:55:02.000000000",
      "message": "Patch Set 2:\n\nWould you be okay with making aback port of LU-5888 that is dependent on this patch instead of merging the two patches together.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "383d5cfd35997a38db983292404a2d4e6a99edac",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
