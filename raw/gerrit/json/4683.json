    {
      "id": "f0a10e94cd89c98fa6b2cb15c630d6d5102fe9d8",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2012-12-28 19:32:53.000000000",
      "message": "Patch Set 2: I would prefer that you didn't submit this\n\nOn closer review, the freeing of s_mb_prealloc_table should actually be done in the original ext4-prealloc-rhel[56].patch and then the ext4-vmalloc-rhel5.patch should only move it to the new location.\n\nOtherwise, trying to submit ext4-prealloc-rhel6.patch upstream by itself will be broken, and the upstream kernel already has an equivalent patch to ext4-vmalloc-rhel6.patch.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
