    {
      "id": "89a519e4b3e343d578fce482b07b078fd6ac029e",
      "author": {
        "_account_id": 622,
        "name": "Qian Yingjin",
        "email": "qian@ddn.com",
        "username": "qian"
      },
      "date": "2019-07-19 06:01:10.000000000",
      "message": "Patch Set 3:\n\nHi Patrick,\nThis patch implements separate functionality not included in any other patches.\n\nIt is not about auto attach when the cache copy is still valid in cache.\n\nIt is about：“If the file is being opened with O_RDONLY flags, and the file matches the predefined rule, it will be prefetched and attached into RO-PCC automatically if it is not cache in PCC.”",
      "accounts_in_message": [],
      "_revision_number": 3
    },
    {
      "id": "544a63504438fa6e0dbf544f8128987af0259b2b",
      "author": {
        "_account_id": 622,
        "name": "Qian Yingjin",
        "email": "qian@ddn.com",
        "username": "qian"
      },
      "date": "2019-07-19 06:04:59.000000000",
      "message": "Patch Set 3:\n\nDifferent from RW-PCC auto cache for newly create file, RO-PCC caching not only needs to create PCC copy file stub, but also needs to copy the data from Lustre into PCC copy.\n\nCurrent the auto RO-PCC caching rule (i.e projid={100}) is same as RW-PCC caching rule, maybe we should define them separately?",
      "accounts_in_message": [],
      "_revision_number": 3
    },
    {
      "id": "a9e30bc488b2233ea8369c5c2824fcec0e882c8b",
      "author": {
        "_account_id": 797,
        "name": "Patrick Farrell",
        "email": "pfarrell@whamcloud.com",
        "username": "pfarrell",
        "inactive": true
      },
      "date": "2019-07-19 14:25:40.000000000",
      "message": "Patch Set 3:\n\nAh, sorry!  Thanks.",
      "accounts_in_message": [],
      "_revision_number": 3
    },
