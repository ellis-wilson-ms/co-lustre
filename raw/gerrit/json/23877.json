    {
      "id": "ce6bb1e078a17578da6bc1cfc1dbd2ac04fe0c8e",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2016-11-28 16:25:28.000000000",
      "message": "Patch Set 2:\n\n(1 comment)",
      "accounts_in_message": [],
