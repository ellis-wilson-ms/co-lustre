    {
      "id": "f412a8232215e5048d82ea01c89436ff41f5c8a3",
      "author": {
        "_account_id": 689,
        "name": "Jeremy Filizetti",
        "email": "jeremy.filizetti@gmail.com",
        "username": "jfilizetti"
      },
      "date": "2016-11-16 22:19:44.000000000",
      "message": "Patch Set 2:\n\nFrom the looks of things all versions will need this to be fixed to prevent the possible buffer_head reuse although RHEL5 is the only one I think affected by the hang caused from the kthread_stop issue.  \n\nThe upstream kernel has commit 63706172f332fd3f6e7458ebfb35fa6de9c21dc5 which I believe prevents the issue from calling kthread_stop on a kthread that has already returned.  RHEL 6.2+ has that commit but I'm not sure about SLES.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "24c580f7b019d8444549fe16e66af102c492e81f",
      "author": {
        "_account_id": 689,
