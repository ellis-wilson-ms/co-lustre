        "email": "jeremy.filizetti@gmail.com",
        "username": "jfilizetti"
      },
      "date": "2016-11-16 22:19:44.000000000",
      "message": "Uploaded patch set 2.",
      "accounts_in_message": [],
      "_revision_number": 2
    }
