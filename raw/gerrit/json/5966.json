    {
      "id": "5d62b760a4d11405546d816811765b7ee62ee6ad",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2013-04-10 17:38:59.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nsorry, I don't understand why tracking xattr set with name=LOVEA is not enough. MDD is not supposed to be aware of \"stripes\".",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "eb75bd51ada6c96b17332f32217c2869ccb632e6",
      "author": {
        "_account_id": 140,
        "name": "jacques-Charles Lafoucriere",
        "email": "jacques-charles.lafoucriere@cea.fr",
        "username": "jcl"
      },
      "date": "2013-04-10 20:22:06.000000000",
      "message": "Patch Set 1:\n\nCL_XATTR event mean xattr has been set or deleted without telling which one (lustre internal or user one). It is too generic for us. A layout change is a real lustre event independently of how it is implemented on MDT.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "5756948a701da22f03ee34a9269a4b79b64f7c39",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2013-04-11 08:55:24.000000000",
      "message": "Patch Set 1: Looks good to me, but someone else must approve\n\nI quite dislike that we're putting layout things into MDD again (which has nothing to do with layouts at all). and patch like this states that everything related layout needs to go through MDD which is bad in the long term.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
