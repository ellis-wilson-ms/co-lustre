    {
      "id": "f0d3e4d307f6f6e27457dd8a48cb99a8fca98be8",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2013-04-07 18:07:47.000000000",
      "message": "Patch Set 1: Looks good to me, but someone else must approve\n\n",
      "accounts_in_message": [],
      "_revision_number": 1
