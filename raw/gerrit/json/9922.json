    {
      "id": "6b6ec4deac91df58439bfb7634a4d7ab41d91a37",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2014-04-09 21:36:12.000000000",
      "message": "Patch Set 1: Code-Review-1\n\nLooks like this failed with:\n\n getopt: unrecognized option \"--tag=foo\"\n\nSo it seems we need to fix the Intel lbuild system to stop using this.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "cdb69c9fec1ca77d9aa1781ef7ce1d21c7a957a0",
      "author": {
        "_account_id": 196,
        "name": "Ashley Pittman",
        "email": "apittman@gmail.com",
        "username": "ashley",
        "inactive": true
      },
      "date": "2014-04-10 13:18:42.000000000",
      "message": "Patch Set 1:\n\nThis is how I found the issue, I was debugging a build failure and noticed a file called \"2\" containing an error message.  We've change our build system to no longer provide this option.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "cdebf4fc9412cc70b4e60e7ec791f1af6d73592d",
      "author": {
        "_account_id": 109,
        "name": "Christopher J. Morrone",
        "email": "morrone2@llnl.gov",
        "username": "morrone"
      },
      "date": "2014-04-14 20:27:38.000000000",
      "message": "Patch Set 1: Code-Review-1\n\nYes, the option was left in, but deprecated, explicitly to continue supporting HPDD's build system.  It would be great to get that changed.\n\nFor now, we should have a patch that fixes the buggy redirection rather than removing the option.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "8a39e1221bd69944d9e5888263d0a3ed83258103",
      "author": {
        "_account_id": 198,
        "name": "Minh Diep",
        "email": "mdiep@whamcloud.com",
        "username": "mdiep"
      },
      "date": "2014-04-14 21:36:34.000000000",
      "message": "Patch Set 1:\n\nI will take care of removing the tag from intel build system, and rebuild this.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
