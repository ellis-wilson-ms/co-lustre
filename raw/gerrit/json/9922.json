      "date": "2014-04-09 15:33:56.000000000",
      "message": "Patch Set 1: Verified-1\n\nBuild Failed \n \nhttp://build.whamcloud.com/job/lustre-reviews/22956/ : FAILURE",
      "accounts_in_message": [],
      "_revision_number": 1
