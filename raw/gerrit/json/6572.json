    },
    {
      "id": "2e7a5503313d3e550d5a05895e3fa4f7af809645",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-06-08 16:04:33.000000000",
      "message": "Patch Set 2: I would prefer that you didn't submit this\n\nSorry for confusion. My comment was about osc_extent_make_ready() , not osc_io_submit(), because the first patch was holding \"last->oap_lock\" in both places. However, I also see now that this is incorrect. Inside the loop it should be holding a different oap->oap_lock each time, so it isn't possible to hold a single lock for the whole loop.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
