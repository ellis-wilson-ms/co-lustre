  "messages": [
    {
      "id": "4f5cc41e6215dc757027044e24529eeee63d63a5",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-06-06 16:29:05.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nGetting and dropping the spinlock for every page in the RPC can add a lot of overhead. Better to grab it once at the start of the section and hold it until after the loop. The number of pages in the RPC is limited, so it shouldn't be held for too long.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
