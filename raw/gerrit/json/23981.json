      },
      "date": "2016-12-05 17:50:48.000000000",
      "message": "Patch Set 4: Code-Review-1\n\nThis is too big to use 'Test-Parameters: trivial'.\n\nWithout the changes to the semantic_func_t callbacks it would have been OK. Were those necessary to make the changes I suggested?",
      "accounts_in_message": [],
      "_revision_number": 4
