      },
      "date": "2012-06-19 10:30:09.000000000",
      "message": "Patch Set 1:\n\nSorry, see the comment http://jira.whamcloud.com/browse/LU-1518?focusedCommentId=40817&page=com.atlassian.jira.plugin.system.issuetabpanels:comment-tabpanel#comment-40817.",
