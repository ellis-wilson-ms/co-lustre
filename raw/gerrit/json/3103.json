    {
      "id": "edfcc750865799ea7ccc8fd409fe6c39af5caf25",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2012-06-19 17:58:36.000000000",
      "message": "Patch Set 1:\n\nIt appears the root of the problem with landing this patch is that it was based on commit 180945ed89de5201354511ea878c5b4e0d9e207c (2.1.2-RC3) but pushed to the \"master\" branch for submission.\n\nThis made me incorrectly think that because the patch was only 5 days old that it was reasonably safe to land to master.  I didn't see the comment that had just been posted in the bug before landing it.\n\nIn the future, when pushing patches to the master branch (or any other branch for that matter), please always rebase the patches locally against the most recent version of the branch to avoid conflicts like this.",
      "accounts_in_message": [],
      "_revision_number": 1
    }
