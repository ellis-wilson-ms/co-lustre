      "date": "2013-06-10 21:34:45.000000000",
      "message": "Patch Set 3:\n\nWill this be OK is OSTCOUNT is large enough that some OSTs are not used by the time roc_hit is called?",
      "accounts_in_message": [],
      "_revision_number": 3
    },
    {
      "id": "e156d1c552fc66df15dfabf9792468b8e9571add",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
