    {
      "id": "72eab4e3a53784c4a066e7efe9d02129ffe9c5af",
      "author": {
        "_account_id": 931,
        "name": "Timothy Day",
        "email": "timday@thelustrecollective.com",
        "username": "timday"
      },
      "date": "2024-02-23 06:46:57.000000000",
      "message": "Patch Set 1:\n\nI spent some time finding the divergence of Lustre checkpatch.pl from upstream checkpatch.pl. \n\nI've submitted two patches: one which up-dates Lustre checkpatch.pl to 6.8-rc5 checkpatch.pl and another (this one) which applies the Lustre specific changes. This should make it easy to visualize how far we differ from upstream. It'll also help us understand what changes (if any) checkpatch.pl will need when Lustre is submitted.\n\nBased on my testing, the number of warnings we get it noticeably lower. So this should save us some effort and false positives.\n\nTesting/feedback/concerns would be appreciated.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
