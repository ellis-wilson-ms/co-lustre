  "current_revision_number": 7,
  "current_revision": "e388ebc99cdcb112c9ba7b6e4a4c0117c3b34c31",
  "revisions": {
    "e388ebc99cdcb112c9ba7b6e4a4c0117c3b34c31": {
      "kind": "TRIVIAL_REBASE_WITH_MESSAGE_UPDATE",
      "_number": 7,
