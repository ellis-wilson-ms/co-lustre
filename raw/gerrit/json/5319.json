    {
      "id": "6f22e2d92f94db018f27303545db25cdec75b119",
      "author": {
        "_account_id": 12,
        "name": "wangdi",
        "email": "di.wang@intel.com",
        "username": "wangdi",
        "inactive": true
      },
      "date": "2013-02-19 01:26:06.000000000",
      "message": "Patch Set 2:\n\nWell, sending the seq lookup to one MDT does not mean the seq is located on that MDT. And actually we are not sure whether all of the special seq will be located at MDT0. But the more important reason of not skipping lookup is that we do not want add special case on the client side, because it might easily cause incompatible problem.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "f93e6b671029543d75d49781c4e0a7ce0523cfa6",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-02-19 06:59:57.000000000",
      "message": "Patch Set 2: Looks good to me, approved\n\nI agree with Di - just sending the FLD requests to MDT0 does not mean that all such sequences are on MDT0. It does make it much more likely that such requests can be handled.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
