    {
      "id": "d9bbe5b950ef1ebd8584c90a21bb6193b44a1ca9",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2016-01-14 19:00:20.000000000",
      "message": "Patch Set 1:\n\nThis patch doesn't have anything to do with http://review.whamcloud.com/17683 so it should not be based on that patch, but rather be pushed from an independent branch.  Adding needless patch dependencies complicates landing or refreshing patches and should be avoided when possible.\n\nThat isn't a reason by itself to resubmit this patch, but if the patch needs to be resubmitted for some other reason it should be done from its own branch.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "aaeb3ba4bfa186721038396c66781f3d4f971af5",
      "author": {
        "_account_id": 292,
        "name": "James Nunez",
        "email": "jnunez@whamcloud.com",
        "username": "jnunez"
      },
      "date": "2016-02-02 16:48:51.000000000",
      "message": "Patch Set 1: Code-Review-1\n\n(1 comment)\n\nPlease consider Andreas comments in the LU-7656 ticket:\nHave you verified that this is related to trying to archive dangling symlinks from the source /etc folder, or what is the source of the error? Have you tried using \"tar -cf --ignore-failed-read\" to avoid an error on tar during read? It may also be that these errors are generated at restore time because the files are being deleted during cleanup while tar is still running.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "69aa58f5437f4de7a6c45eb33700c94a804ec41a",
      "author": {
        "_account_id": 577,
        "name": "Noopur Maheshwari",
        "email": "noopur.maheshwari@seagate.com",
        "username": "noopur.maheshwari",
        "inactive": true
      },
      "date": "2016-02-20 04:59:39.000000000",
      "message": "Abandoned\n\nChanging directory to /tmp does not help in this case.\nWe see these tar failures without Lustre mounted as well.\nThere is a problem with the tar utility, OS or VM (kvm or vmware).\nThis isn't a lustre problem.\nAbandoning.",
      "accounts_in_message": [],
      "_revision_number": 1
    }
  ],
