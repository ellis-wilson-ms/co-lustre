    {
      "id": "03dacd9cfafda612102665f474775cf3552bbdee",
      "author": {
        "_account_id": 135,
        "name": "Vitaly Fertman",
        "email": "vitaly.fertman@hpe.com",
        "username": "vitaly_fertman"
      },
      "date": "2020-12-25 18:54:53.000000000",
      "message": "Patch Set 1:\n\nexp_bl_lock_at does not measure the time of the BL AST, but the time between BLAST and the cancel. however there may be multiple IO RPC in between, it is not clear at the beginning how many RPC cycles will be involved, thus exp_bl_lock_at being an average of all the cases is not very useful. at the same time, if having a relevant RPC in hand, it is clear that at least one more cycle will be needed, and measuring just 1 cycle, exp_bl_lock_at will become more accurate. although, I agree that the name of the field has lost its sense partially and may need to be adjusted.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "2d54fefc29532e0731659a3c7ff552ab144afee8",
      "author": {
        "_account_id": 135,
        "name": "Vitaly Fertman",
        "email": "vitaly.fertman@hpe.com",
        "username": "vitaly_fertman"
      },
      "date": "2020-12-25 18:57:02.000000000",
      "message": "Patch Set 1:\n\nwhere 1 cycle is a message going to client (BLAST RPC or IO reply), some processing on the client side, and the next client's RPC (next IO or cancel).",
      "accounts_in_message": [],
      "_revision_number": 1
    },
