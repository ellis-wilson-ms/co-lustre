    {
      "id": "da4566266c2d9375028d01b722a1818bb7ffeabc",
      "author": {
        "_account_id": 564,
        "name": "Giuseppe Di Natale",
        "email": "dinatale2@llnl.gov",
        "username": "dinatale2"
      },
      "date": "2017-07-19 20:12:33.000000000",
      "message": "Patch Set 1:\n\nCuriosity question. Some catalog files may not have lgh_name set, but they would have some form of ID. In my patch, if lgh_name is not set, it's effectively useless. Are there ways to generate a useful name from IDs so that can be printed if lgh_name is not set?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "3a7ac7d21322cad4f1844d8a920ea253127d6146",
      "author": {
        "_account_id": 229,
        "name": "Bruno Faccini",
        "email": "bfaccini@nvidia.com",
        "username": "bfaccini"
      },
      "date": "2017-07-20 06:24:42.000000000",
      "message": "Patch Set 1:\n\nWell in this case you can print its full ID. This is for OSP Catalogs only I think, and then the other important info is the record position for this ID in the CATALOGS (the Catalog of Catalogs!) file...",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "4dcf0fd515a61ed53ee0206299790ee4e1dabe0d",
      "author": {
        "_account_id": 564,
        "name": "Giuseppe Di Natale",
        "email": "dinatale2@llnl.gov",
        "username": "dinatale2"
