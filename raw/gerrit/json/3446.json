      "date": "2012-07-30 03:45:03.000000000",
      "message": "Patch Set 1:\n\nAndreas, see ofd_commitrw_write():\n\n\n        /* Force commit to make the just-deleted blocks\n         * reusable. LU-456 */\n        if (rc == -ENOSPC)\n                th->th_sync = 1;\n\n        ofd_trans_stop(env, ofd, th, rc);\n        if (rc == -ENOSPC && retries++ < 3) {\n                CDEBUG(D_INODE, \"retry after force commit, retries:%d\\n\",\n                       retries);\n                goto retry;\n        }",
      "accounts_in_message": [],
      "_revision_number": 1
    },
