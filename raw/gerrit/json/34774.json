        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2020-01-16 01:16:35.000000000",
      "message": "Abandoned\n\nThanks for the update Patrick.",
      "accounts_in_message": [],
      "_revision_number": 2
    }
