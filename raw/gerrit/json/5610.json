    {
      "id": "3385852f85585213372fef9797fa42d30317ff8e",
      "author": {
        "_account_id": 298,
        "name": "Jeff Mahoney",
        "email": "jeffm@suse.com",
        "username": "jeffm"
      },
      "date": "2013-03-14 17:41:41.000000000",
      "message": "Patch Set 2: I would prefer that you didn't submit this\n\nWe can just mask out the first argument to the routines with a macro, like the following. Then the call sites won't get polluted.\n\n--- a/lustre/include/liblustre.h\n+++ b/lustre/include/liblustre.h\n@@ -453,6 +453,15 @@ struct posix_acl * posix_acl_from_xattr(\n         return NULL;\n }\n \n+#ifdef HAVE_POSIXACL_USER_NS\n+/*\n+ * Mask out &init_user_ns so we don't jump\n+ * through hoops to define it somehow only\n+ * to have it ignored anyway.\n+ */\n+#define posix_acl_from_xattr(a,b,c)    posix_acl_from_xattr(b,c)\n+#endif\n+",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "b290dbb1c762638c49c22b1cea23cbbe710de0b1",
      "author": {
        "_account_id": 179,
        "name": "Peng Tao",
        "email": "bergwolf@gmail.com",
        "username": "bergwolf"
