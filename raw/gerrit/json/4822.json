    {
      "id": "5fd2bacfdb6f5cc520e16d635b4df8a5717b320e",
      "author": {
        "_account_id": 257,
        "name": "Keith Mannthey",
        "email": "keith.mannthey@intel.com",
        "username": "kmannth",
        "inactive": true
      },
      "date": "2013-01-05 00:27:52.000000000",
      "message": "Patch Set 5: (2 inline comments)\n\n",
      "accounts_in_message": [],
