    {
      "id": "064ca41ccb0ffcfd1d5ed907f8701e111e931002",
      "author": {
        "_account_id": 141,
        "name": "Li Wei",
        "email": "wei.g.li@intel.com",
        "username": "liwei",
        "inactive": true
      },
      "date": "2012-11-30 03:38:11.000000000",
      "message": "Patch Set 2:\n\n> 1) opd_pre_last_created should not matter until the first precreate\n> after reconnection. 2) no objects should be available till first\n> completed precreation after reconnection.\n\nosp_precreate_cleanup_orphans() needs to set opd_pre_last_created to the same value of opd_pre_used_id, to empty the pre-created pool.  This was not the case and has been fixed by the patch.  So I believe the landing is fine.",
      "accounts_in_message": [],
      "_revision_number": 2
    }
