    {
      "id": "ecd6828de1f579ac27e8b4cafdbe5b469d4528b6",
      "author": {
        "_account_id": 281,
        "name": "Thomas Stibor",
        "email": "thomas@stibor.net",
        "username": "thomas"
      },
      "date": "2013-12-11 11:17:10.000000000",
      "message": "Patch Set 2:\n\nThanks for the feedback. I did not use the correct wording and probably this led to confusion.\n\nlinux-2.6.36.y\n>grep -r \"cache_register\" | grep \"[net|include]/.*/cache.[c|h]\"\ninclude/linux/sunrpc/cache.h:extern int cache_register(struct cache_detail *cd);\ninclude/linux/sunrpc/cache.h:extern int sunrpc_cache_register_pipefs(struct dentry *parent, const char *,\nnet/sunrpc/cache.c:int cache_register(struct cache_detail *cd)\nnet/sunrpc/cache.c:EXPORT_SYMBOL_GPL(cache_register);\nnet/sunrpc/cache.c:int sunrpc_cache_register_pipefs(struct dentry *parent,\nnet/sunrpc/cache.c:EXPORT_SYMBOL_GPL(sunrpc_cache_register_pipefs);\n/** cache_register_net is not available **/\n\nlinux-2.6.37.y\n>grep -r \"cache_register\" | grep \"[net|include]/.*/cache.[c|h]\"\ninclude/linux/sunrpc/cache.h:extern int cache_register(struct cache_detail *cd);\ninclude/linux/sunrpc/cache.h:extern int cache_register_net(struct cache_detail *cd, struct net *net);\ninclude/linux/sunrpc/cache.h:extern int sunrpc_cache_register_pipefs(struct dentry *parent, const char *,\nnet/sunrpc/cache.c:int cache_register_net(struct cache_detail *cd, struct net *net)\nnet/sunrpc/cache.c:int cache_register(struct cache_detail *cd)\nnet/sunrpc/cache.c:     return cache_register_net(cd, &init_net);\nnet/sunrpc/cache.c:EXPORT_SYMBOL_GPL(cache_register);\nnet/sunrpc/cache.c:int sunrpc_cache_register_pipefs(struct dentry *parent,\nnet/sunrpc/cache.c:EXPORT_SYMBOL_GPL(sunrpc_cache_register_pipefs);\n/** cache_register_net is not exported, but defined, \n ** so checking for AC_DEFUN([LC_HAVE_CACHE_REGISTER_NET]... would say yes, but the module loader would complain (I guess) as it is not imported,\n ** so I changed it to check for function cache_register() **/\n\nlinux-3.3.y\n>grep -r \"cache_register\" | grep \"[net|include]/.*/cache.[c|h]\"\ninclude/linux/sunrpc/cache.h:extern int cache_register(struct cache_detail *cd);\ninclude/linux/sunrpc/cache.h:extern int cache_register_net(struct cache_detail *cd, struct net *net);\ninclude/linux/sunrpc/cache.h:extern int sunrpc_cache_register_pipefs(struct dentry *parent, const char *,\nnet/sunrpc/cache.c:int cache_register_net(struct cache_detail *cd, struct net *net)\nnet/sunrpc/cache.c:EXPORT_SYMBOL_GPL(cache_register_net);\nnet/sunrpc/cache.c:int cache_register(struct cache_detail *cd)\nnet/sunrpc/cache.c:     return cache_register_net(cd, &init_net);\nnet/sunrpc/cache.c:EXPORT_SYMBOL_GPL(cache_register);\nnet/sunrpc/cache.c:int sunrpc_cache_register_pipefs(struct dentry *parent,\nnet/sunrpc/cache.c:EXPORT_SYMBOL_GPL(sunrpc_cache_register_pipefs);\n/** cache_register and cache_register_net are exported **/\n\nlinux-3.4.y\n>grep -r \"cache_register\" | grep \"[net|include]/.*/cache.[c|h]\"\ninclude/linux/sunrpc/cache.h:extern int cache_register_net(struct cache_detail *cd, struct net *net);\ninclude/linux/sunrpc/cache.h:extern int sunrpc_cache_register_pipefs(struct dentry *parent, const char *,\nnet/sunrpc/cache.c:int cache_register_net(struct cache_detail *cd, struct net *net)\nnet/sunrpc/cache.c:EXPORT_SYMBOL_GPL(cache_register_net);\nnet/sunrpc/cache.c:int sunrpc_cache_register_pipefs(struct dentry *parent,\nnet/sunrpc/cache.c:EXPORT_SYMBOL_GPL(sunrpc_cache_register_pipefs);\n/** cache_register is removed **/\n\nTo avoid ifdef-hell _cache_register_net/_cache_unregister_net are created, so we don't have to change the code (with ifdefs) at the end\nof gss_svc_upcall.c",
      "accounts_in_message": [],
      "_revision_number": 2
    },
