      "_revision_number": 1
    },
    {
      "id": "fd947042faa7b3f2a523eec37033c736a073dc92",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2020-08-23 15:55:50.000000000",
      "message": "Patch Set 1: Code-Review-1\n\nRegardless of how upstream is going with this, I would prefer to keep 80-column wrapping for Lustre. As Arshad wrote, this allows terminal windows to be kept narrower, rather than having to make them wider just for a few long lines and have lots of dead space in the rightmost 20 columns because 99% of lines are already wrapped at 80 columns. \n\nThat doesn't mean we cannot ever exceed 80 columns in the few cases they are needed, but I would prefer that those be the exceptions that are warned about, rather than having longer lines when they could still be wrapped easily.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "023fb3630423a4cd086f8e098747934fa189abaa",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2020-08-23 15:56:58.000000000",
      "message": "Patch Set 1:\n\nPS: I removed Shilong's +1 because you can't +1 a patch you are owner of.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
