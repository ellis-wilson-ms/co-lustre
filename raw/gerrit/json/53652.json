      },
      "date": "2024-01-12 06:09:06.000000000",
      "message": "Patch Set 1: Verified-1\n\nPassed enforced test review-ldiskfs-dne-arm on RHEL 8.8/aarch64, RHEL 8.8/x86_64 uploaded by Onyx Autotest 2 from onyx-91vm1: https://testing.whamcloud.com/test_sessions/46cac4ed-8f7a-4a24-83e7-6ec61f0928a6 ran 5 tests.",
      "accounts_in_message": [],
