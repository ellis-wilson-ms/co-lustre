    {
      "id": "716ca81073520b52905ae34a111d6dd1d55d27e1",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2012-05-14 14:47:25.000000000",
      "message": "Patch Set 1: Looks good to me, but someone else must approve\n\nYes, these patches are being landed in order to enable the fix disabling the mmap_sanity subtest in sanityn, test 18.   The motivation is too many encounters with the problem in LU-1205 messing up test runs.",
      "accounts_in_message": [],
