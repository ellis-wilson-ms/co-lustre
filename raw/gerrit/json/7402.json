    {
      "id": "1de19d35b27a1d711905f2c96457200f7c7d5dcb",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-08-22 21:20:35.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nTo further clarify - the whole reason that there is grant inflation with ZFS is because old (and sadly current) clients will only consume grant in PAGE_SIZE chunks (i.e. typically 4kB units).\n\nThat means (in the worst case) if some client is writing sparse 4kB-chunk files that each 4kB written by the client might consume a full 128kB block of space on the OST.  Without the server-side grant inflation this could lead to the OST incorrectly running out of space before the client runs out of grant.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
