    {
      "id": "7b466977996d992b379ab7535dccd56d67b505a7",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-04-24 01:13:13.000000000",
      "message": "Patch Set 1:\n\nIhara, the question with this patch was whether it would cause LU-1279 to be hit also. There is the open question in the bug whether this bug fixes the problem with the module autoloading. If you can confirm that this patch fixes the problem, and does not introduce problems on systems that do not have crc32c hardware support then please comment in the bug and this patch can be landed.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "e1545efa45c7b3defc707d2c59cae5b7e04888ff",
      "author": {
        "_account_id": 125,
        "name": "James Simmons",
        "email": "jsimmons@infradead.org",
        "username": "jsimmons"
      },
      "date": "2013-05-03 12:01:20.000000000",
      "message": "Patch Set 1:\n\nActually by default Cray kernels lack crc32 crypto support. I can test this patch to see if it breaks anything.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
