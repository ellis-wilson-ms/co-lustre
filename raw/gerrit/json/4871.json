      },
      "date": "2012-12-20 18:52:59.000000000",
      "message": "Patch Set 1: Verified\n\nTests received by maloo, run on CentOS release 6.3/x86_64: (https://maloo.whamcloud.com/test_sessions/c0d224b6-4ad1-11e2-8a7b-52540035b04c).  Ran 12 tests.  No failures.",
      "accounts_in_message": [],
