    },
    {
      "id": "c3a715507d32785c71085d7207bb608ca25c3080",
      "author": {
        "_account_id": 109,
        "name": "Christopher J. Morrone",
        "email": "morrone2@llnl.gov",
        "username": "morrone"
      },
      "date": "2013-12-21 00:51:56.000000000",
      "message": "Patch Set 1: Looks good to me, but someone else must approve\n\nI am not sure that this addesses any issue of mine.\n\nMy main issue with this hook is that it just doesn't match my workflow.  I commit frequently, and most of the time the commit hooks are just a nuisance.  I only want to run validation on my commits before I push them somewhere visible to others.  I'm happy to run a command manually to do that validation.\n\nI am not opposed to this change, but it isn't going to get me to start using the hooks.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "d1a21dafa91a99fa29efbf37db0e1e685fc5feac",
      "author": {
        "_account_id": 109,
        "name": "Christopher J. Morrone",
        "email": "morrone2@llnl.gov",
        "username": "morrone"
      },
      "date": "2013-12-21 01:00:00.000000000",
      "message": "Patch Set 1:\n\nApparently git 1.8.2 introduced a new git hook: pre-push.  That will be a more appropriate place for this kind of checking.  At least for my workflow.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
