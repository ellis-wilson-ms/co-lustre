      "date": "2014-07-01 22:27:55.000000000",
      "message": "Patch Set 3:\n\nHi Li Xi,\n\nWill you please create a new patch by merging this patch and 10486?",
      "accounts_in_message": [],
      "_revision_number": 3
    },
