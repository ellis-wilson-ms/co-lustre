      },
      "date": "2012-10-06 08:13:11.000000000",
      "message": "Patch Set 1: Fails\n\nTests received by maloo, run on CentOS release 5.8/x86_64, CentOS release 6.3/x86_64: (https://maloo.whamcloud.com/test_sessions/824629ca-0f87-11e2-85d6-52540035b04c).  Ran 12 tests.  1 tests failed: sanity.",
      "accounts_in_message": [],
