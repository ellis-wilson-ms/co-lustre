        },
        "committer": {
          "name": "Hiroya Nozaki",
          "email": "nozaki.hiroya@jp.fujitsu.com",
          "date": "2015-05-22 08:37:20.000000000",
          "tz": 540
        },
        "subject": "LU-6631 ptlrpc: Retry LDLM_CANCEL in ldlm_cli_cancel_req",
        "message": "LU-6631 ptlrpc: Retry LDLM_CANCEL in ldlm_cli_cancel_req\n\nldlm_cli_cancel_req() immediately returns if it got -EWOULDBLOCK\nfrom a LDLM_CANCEL req it tried to send. In this case client is\nbeing evicted before long. But a lot of network errors can be\nrecovered then we can avoid eviction this case.\n\nThis patch change ldlm_cli_cancel_req to retry LDLM_CANCEL when it\nfailed with -EWOULDBLOCK.\n\nSigned-off-by: Hiroya Nozaki <nozaki.hiroya@jp.fujitsu.com>\nChange-Id: Id5b452f99353a1f899e6f3861ecfeb4525fe5f64\n"
      },
      "branch": "refs/heads/master"
    }
  },
