    {
      "id": "44e96ff579538bd2c870ece34d24c2759b5e622f",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2013-02-20 03:36:59.000000000",
      "message": "Patch Set 1:\n\nso, racer failed in testing even though for a different reason. do we really want to land this if it does not improve racer functionality?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "ab177be2cc46c794ee552dbb8f95960d84c4cfb6",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-02-20 08:20:01.000000000",
      "message": "Patch Set 1:\n\nRacer passed the first test run, but failed to clean up for the second and third runs. I suspect that was due to \"dd\" taking a very long time to exit, but I haven't looked into the details.\n\nI'd like to land this patch anyway, and then get an idea of how often racer is passing on master \"full\" runs. If it is passing most of the time, then is prefer to add it into the \"review\" runs, but that can be decided separately. At least it will give some chance that racer is passing on master.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "3f5be9fc3d3fe4d5c4d35ae9412430a696c96abe",
      "author": {
        "_account_id": 257,
        "name": "Keith Mannthey",
        "email": "keith.mannthey@intel.com",
        "username": "kmannth",
        "inactive": true
      },
      "date": "2013-03-07 01:17:06.000000000",
      "message": "Patch Set 1:\n\nIt looks like the patch for LU-2789 has landed and http://review.whamcloud.com/5417 a patch for LU-2523 is just awaiting gatekeeper.  \n\nDo we sill need this patch?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "77078dd27d4d7c89bd546b02f11a0026d7855f7b",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2013-03-07 03:54:02.000000000",
      "message": "Patch Set 1: Looks good to me, approved\n\nOk, I am lading this to enable further useful racer testing for now.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
