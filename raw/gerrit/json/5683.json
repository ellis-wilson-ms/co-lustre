    {
      "id": "fe12142a958ec3046e201acdd340c792f454a46d",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2013-03-13 10:14:26.000000000",
      "message": "Patch Set 1: Looks good to me, but someone else must approve\n\nin fact, we do want to let others to use OSP-in-recovery and block in osp_precreate_reserve() because this might be the last usable OSP.\nfrom this point of view, non-zero opd_pre_status() is OK, but then it can change while we're waiting for recovery to complete. in turn, recovery can fail in-between while we're still caching zero status in rc.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
