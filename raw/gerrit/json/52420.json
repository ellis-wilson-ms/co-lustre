    {
      "id": "5d2144291380345e8ead975937d1576f5f5db901",
      "author": {
        "_account_id": 931,
        "name": "Timothy Day",
        "email": "timday@thelustrecollective.com",
        "username": "timday"
      },
      "date": "2023-12-15 18:27:58.000000000",
      "message": "Patch Set 2:\n\nThis should be in good shape now. I've been using the python version for a couple months and haven't noticed any bugs. I did a refactor to clean up the code some more. The tests in 'contrib/git-hooks/tests' are all for 'commit-msg' it seems, so I didn't run any of those.\n\nI think it would useful if people could try this out and report back any issues.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
