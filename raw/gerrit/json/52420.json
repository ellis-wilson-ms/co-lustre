    {
      "id": "fc1a975a5bb1fa820818f6771022d9cc36233d2e",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2023-12-16 05:53:24.000000000",
      "message": "Patch Set 2:\n\nI'm not convinced that this script needs to be Python itself, as it could call a separate script to generate the Test-Parameters line.  Having this script in bash is the most portable.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "231391a7c2af3ce79a7775288d4e1c4bc0332326",
      "author": {
        "_account_id": 931,
        "name": "Timothy Day",
        "email": "timday@thelustrecollective.com",
        "username": "timday"
      },
      "date": "2023-12-18 04:32:59.000000000",
      "message": "Patch Set 2:\n\nUsing Python for the entire script I think will make the final product easier to read/understand. This script sticks to using only packages available by default (os, sys, subprocess). So I think this should be just as portable.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
