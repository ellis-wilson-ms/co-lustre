    {
      "id": "dd7f2272ad44cb6d8b79b1c026de55874deaeb6d",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2011-08-05 22:51:18.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\n(3 inline comments)\n\nI meant to commit these comments yesterday...\n\nI think that checking OBD_MD_FLGROUP is enough, even for 1.8 clients, so long as it sets FID_SEQ_OST_MDT0 if it is unset.\n\nAlso, as Di mentioned, it needs to be possible to use FID_SEQ_ECHO from both 1.8 and 2.x clients.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
