    {
      "id": "035174e1109f6199b39efbdedaa10a6e8fe7ad58",
      "author": {
        "_account_id": 281,
        "name": "Thomas Stibor",
        "email": "thomas@stibor.net",
        "username": "thomas"
      },
      "date": "2013-12-10 12:39:19.000000000",
      "message": "Patch Set 2:\n\nBy studying lustre/autoconf/lustre-core.m4,\nconfiguring --with-krb5 --enable-gss --disable-gss-keyring\nand investigating config.h, it turns out that HAVE_GSS_PIPEFS\nis never set, although the keyring back-end is disabled, and thus HAVE_GSS_PIPEFS is never set in any *.c and *.h files.\n\nWhat are the further plans with the gss_pipefs?",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "da470c7b9f6223c3ac8b24bb710f5d05cd63d6c8",
      "author": {
        "_account_id": 125,
        "name": "James Simmons",
        "email": "jsimmons@infradead.org",
        "username": "jsimmons"
      },
      "date": "2013-12-10 15:05:30.000000000",
      "message": "Patch Set 2:\n\nI also noticed the pipefs not being used but I didn't know what to do about. This does need to be address. Could we do this under a different ticket.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
