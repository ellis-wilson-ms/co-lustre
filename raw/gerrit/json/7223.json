    {
      "id": "2c3214d5c2ed7efe581001bae9b292e3c2e3bf3e",
      "author": {
        "_account_id": 302,
        "name": "Patrick Farrell",
        "email": "paf@cray.com",
        "username": "paf",
        "inactive": true
      },
      "date": "2013-08-05 17:28:49.000000000",
      "message": "Patch Set 2:\n\nAgreed on the style fix of the (LA_UID | LA_GID), but I'm uncertain about splitting the mutex lock and unlock in to two different if statements.\n\nPresumably, the la_valid mask is not modified by the mo_attr_set code and its various subroutines, but by splitting the lock and unlock to different if statements, we've created a latent dependency on those flags not changing.\n\nThat makes me hesitant on principle.  I'll go with your preference if you still feel that's best, I just wanted to bring that up first.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "67cafc081a4f6cbeb363418379bf829a9bd273a4",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2013-08-05 18:04:51.000000000",
      "message": "Patch Set 2:\n\nmo_attr_set() takes a const struct md_attr *at parameter so I feel that it's safe.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
