    },
    {
      "id": "faf22d9e669c2a30d5d874a93933c86af3644752",
      "author": {
        "_account_id": 931,
        "name": "Timothy Day",
        "email": "timday@thelustrecollective.com",
        "username": "timday"
      },
      "date": "2025-05-02 00:27:33.000000000",
      "message": "Patch Set 1:\n\nIt seems like both kiblnd_destroy_fmr_pool_list() and kiblnd_destroy_pool_list() are called in other contexts without their respective locks. Should that be fixed as well? kiblnd_pool_free_node(), for example, looks very wrong.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "6cd2423c3c1cfaf8efc7d115931f9d736a1a258f",
      "author": {
        "_account_id": 147,
        "name": "Maloo",
        "email": "maloo@whamcloud.com",
        "username": "maloo",
        "tags": [
          "SERVICE_USER"
        ]
      },
      "date": "2025-05-02 07:51:08.000000000",
      "message": "Patch Set 1: Verified+1\n\nPassed enforced test review-ldiskfs-dne on RHEL 9.4 / x86_64 uploaded by Onyx Autotest from onyx-117vm1: https://testing.whamcloud.com/test_sessions/7491b54c-22c6-40f0-b206-dafba174267d ran 5 tests.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "b081cdfbc61954cd592517729b2b58815e42cbfb",
      "author": {
        "_account_id": 908,
        "name": "Frank Sehr",
        "email": "fsehr@whamcloud.com",
        "username": "fsehr"
      },
      "date": "2025-05-02 18:52:28.000000000",
      "message": "Patch Set 1:\n\nThe list_move in kiblnd_pool_free_node() is protected with a spinlock, so it shouldn't be a problem. The thing I am wondering about is moving it to zombie. What if there are multiple entries that are idling? Isn't it overwriting zombie and only one zombie list is deleted the others lost?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
