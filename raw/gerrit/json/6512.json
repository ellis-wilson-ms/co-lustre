    {
      "id": "139118c191366a932f029dbaea125bcea18eaf39",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-06-07 16:57:13.000000000",
      "message": "Patch Set 1:\n\nDo we really need to add the overhead of tracking these RPCs for all operations when there is only a very rare race condition during startup?\n\nIt would be better to change the LASSERT() to just report an error and clean up the remaining RPCs properly in this case.  That avoids increasing the memory used for every single RPC and the extra list handling.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
