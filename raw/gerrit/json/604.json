    {
      "id": "4da9e0ae38fcba1780c2494c0420261d18d841df",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2011-06-01 21:56:27.000000000",
      "message": "Patch Set 1:\n\nOne additional note - now that the MDS is sending multiple pages to the client in the bulk RPC, the chance of network error is greatly increased.  This will cause the client to be evicted needlessly if the bulk RPC fails.\n\nOn the OSS code this was fixed long ago, so that if a client fails during a bulk read it is not evicted, and simply retries the operation.  It looks like mdt_sendpage() should also be changed to ignore bulk failures like ost_brw_read() does.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "68b142090ea3a39884a48f8d18e1cf567a939ad2",
      "author": {
        "_account_id": 101,
        "name": "Lai Siyao",
        "email": "lai.siyao@whamcloud.com",
        "username": "laisiyao"
      },
      "date": "2011-06-03 08:48:37.000000000",
      "message": "Uploaded patch set 2.",
      "accounts_in_message": [],
