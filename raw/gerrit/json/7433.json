    {
      "id": "332ec26d4c03e889ae201fb7ca818e4d429ab8c3",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2013-09-16 19:26:50.000000000",
      "message": "Patch Set 6: Looks good to me, but someone else must approve\n\n(2 inline comments)\n\nSome cleanups are possible if this patch is updated.\n\nIn general, I'm not so much in favor of adding yet more special cases for this code for detecting loop and MD devices, since there will be even more cases in the future where these checks do not work (e.g. ZFS pools, or ZFS on loop, or btrfs pools, or whatever).  However, I don't have a better solution to offer right now.",
      "accounts_in_message": [],
      "_revision_number": 6
    },
    {
      "id": "490abace54e05a13cf365c70185cdd769db6108a",
      "author": {
        "_account_id": 284,
        "name": "Emoly Liu",
        "email": "emoly@whamcloud.com",
        "username": "liuying_emoly"
      },
      "date": "2013-09-17 07:55:05.000000000",
      "message": "Patch Set 6: (1 inline comment)\n\n",
      "accounts_in_message": [],
      "_revision_number": 6
    },
    {
      "id": "b237de5764e36f4cc9ee952f2a244396a82d641e",
