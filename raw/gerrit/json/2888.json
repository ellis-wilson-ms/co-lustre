        "username": "HiroyaNozaki"
      },
      "date": "2012-06-11 10:28:40.000000000",
      "message": "Patch Set 1:\n\nah, I'm going to upload a new patch tomorrow instead.",
      "accounts_in_message": [],
      "_revision_number": 1
