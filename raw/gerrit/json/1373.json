    {
      "id": "59db0b4d2a86a2fc5aebc02db74431b85e0b4a3e",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2011-09-13 19:56:03.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nPlease see http://jira.whamcloud.com/browse/LU-680",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "3bf3cd1581173e2265c70ffea17c87a874312fcc",
      "author": {
        "_account_id": 1,
        "name": "Robert Read",
        "email": "robert.read@intel.com",
        "username": "rread",
        "inactive": true
      },
      "date": "2011-09-14 18:32:06.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nI like this overall (I've been wanting this for a long time), but I don't think the interface is correct. I think it would be better to determine the interface for a specific mount point, for example:\n\n$ lfs instance /mnt/myhpcfs\nmyhpcfs-xxxxxxxxxxxxx\n\nThis would be much easier to use in scripts then have to grep/awk the results to get the right instance. \n\nAlso, this translation should be added to llapi instead of being embedded in lfs. External tools need to do this, too.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "50dd7bad75361a317bde806471feb6f88d5881c9",
      "author": {
        "_account_id": 137,
        "name": "Richard Henwood",
        "email": "richard.henwood@intel.com",
        "username": "rhenwood",
        "inactive": true
      },
      "date": "2011-09-14 21:48:20.000000000",
      "message": "Patch Set 1:\n\nThanks for these comments. Robert, I believe your suggestions are in common with John's comments on LU-680. There is disagreement over the command name (getname vs instance).\n\nNOTE: The change that I've implemented relies on llapi_file_get_lov_uui.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "0304534eac2e159a1dd94e556e6cf7b250121cb5",
      "author": {
        "_account_id": 1,
        "name": "Robert Read",
        "email": "robert.read@intel.com",
        "username": "rread",
        "inactive": true
      },
      "date": "2011-09-14 22:48:03.000000000",
      "message": "Patch Set 1:\n\nI think getname is fine, though I think it would make sense to add a llapi_get_instance_name() call to mirror the lfs functionality.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
