    {
      "id": "3cbe763669f8794995e1cb74d4c364c0369d159c",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2012-11-09 16:17:44.000000000",
      "message": "Patch Set 1: No score\n\nI believe this mod breaks NFS mounts for older kernels.  http://review.whamcloud.com/#change,3840 is supposed to fix it again.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "197973599a112ff186c4dfddbfa6550ef4048a77",
      "author": {
        "_account_id": 125,
        "name": "James Simmons",
        "email": "jsimmons@infradead.org",
        "username": "jsimmons"
      },
      "date": "2012-11-09 16:52:52.000000000",
      "message": "Patch Set 1:\n\nCurrently Lustre 2.1 does not work for kernels < 2.6.18 which by extension NFS over Lustre also doesn't work.This was also reported in LU-1411/LU-1646 which is fixed by this patch. This patch enables one to mount lustre for these older kernels but NFS will not still mount for kernels < 2.6.18. NFS should work for modern kernels. With the patch for LU-1718 for b2_1 it will restore NFS to modern as well as older kernels.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "8955ab89c48cfb227c65a1b97b98a3ecfdde0a3b",
      "author": {
