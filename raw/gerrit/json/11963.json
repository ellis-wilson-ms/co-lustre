    {
      "id": "db06d5f3ea013abefc03fcc979608557d2235245",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2014-09-17 19:15:11.000000000",
      "message": "Patch Set 1:\n\nnot sure I understand the value of this mod.  while eliminating wrappers is a good goal in this case I think the original code with LL_PROC_PROTO() is easier to understand and maintain.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "d192f2ba008aec3d1f1fdde8dce4c547a0a30e92",
      "author": {
        "_account_id": 125,
        "name": "James Simmons",
        "email": "jsimmons@infradead.org",
        "username": "jsimmons"
      },
      "date": "2014-09-17 19:58:15.000000000",
      "message": "Patch Set 1:\n\nThis is to bring us into sync with what is in the upstream kernel. Mind you I will update this patch with more cleanup soon. I realized I can remove DECLARE_PROC_HANDLER as well.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "a295f6f8012bb28693dab4b8f9679a228b57b2e0",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2014-09-17 20:01:52.000000000",
      "message": "Patch Set 1:\n\nI like my declarations where I can see them so I'm in favor of this change. The only problem I have is that this change neglects to delete the definition of LL_PROC_PROTO(). James, is there a reason you didn't kill it?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
