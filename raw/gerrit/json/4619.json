      "date": "2012-11-20 12:47:57.000000000",
      "message": "Patch Set 1: Fails\n\nBuild Failed \n \nhttp://build.whamcloud.com/job/lustre-reviews/10587/ : FAILURE",
      "accounts_in_message": [],
      "_revision_number": 1
