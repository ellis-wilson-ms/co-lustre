    {
      "id": "64f396ba8fc323e1cf48e44dcdd6458aba3def4e",
      "author": {
        "_account_id": 4,
        "name": "Jinshan Xiong",
        "email": "jinshan.xiong@intel.com",
        "username": "Jay",
        "inactive": true
      },
      "date": "2012-02-03 18:22:43.000000000",
      "message": "Patch Set 4: Looks good to me, but someone else must approve\n\nlol~ you can absolutely choose to use radix tree for free. I meant to say  radix tree is designed to manage sparse indices. Page index is a perfect match. However, for UIDs, it would be in a format of 0x1,2300,0001~0x1,2310,0000 assuming it has to support 100K users. That means most of uid is centered in a specific region and radix tree will be degenerated to an array because it has narrow top nodes and fat and contiguous leaf nodes.",
      "accounts_in_message": [],
      "_revision_number": 4
    },
