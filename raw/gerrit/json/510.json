    {
      "id": "9746ca006274af8d737b7b57fb77390509e4d13d",
      "author": {
        "_account_id": 2,
        "name": "Jenkins",
        "username": "hudson",
        "inactive": true
      },
      "date": "2011-07-15 05:39:48.000000000",
      "message": "Patch Set 2: Verified\n\nBuild Successful \n \nhttp://newbuild.whamcloud.com/job/lustre-reviews/1384/ : SUCCESS",
      "accounts_in_message": [],
