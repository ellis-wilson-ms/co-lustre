    },
    {
      "id": "d466257e0a2a57bb09332ebb244b7e65180e4680",
      "author": {
        "_account_id": 797,
        "name": "Patrick Farrell",
        "email": "pfarrell@whamcloud.com",
        "username": "pfarrell",
        "inactive": true
      },
      "date": "2019-08-09 14:24:47.000000000",
      "message": "Patch Set 3:\n\n(1 comment)\n\nUgh, I have libblkid installed on my CentOS7 machine and this new check isn't working - says it can't be found.\n\nI have pkgconfig installed.  All the utils I'm aware of are up to date, but liblkid can't be found.",
      "accounts_in_message": [],
      "_revision_number": 3
    }
