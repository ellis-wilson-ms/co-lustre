    {
      "id": "588497424a8f32bbdcaef71b355290443998666c",
      "author": {
        "_account_id": 144,
        "name": "Hongchao Zhang",
        "email": "hongchao@whamcloud.com",
        "username": "Hongchao.zhang"
      },
      "date": "2018-07-17 09:22:05.000000000",
      "message": "Patch Set 1:\n\nif the client quota reach its limit, it will perform sync write\n\nint vvp_io_write_commit(const struct lu_env *env, struct cl_io *io)\n{\n        ...\n\n        /* out of quota, try sync write */\n        if (rc == -EDQUOT && !cl_io_is_mkwrite(io)) {\n                CDEBUG(D_ERROR, \"sync write for -EDQUOT, from %d, to %d\\n\",\n                        vio->u.write.vui_from, vio->u.write.vui_to);\n\n                rc = vvp_io_commit_sync(env, io, queue,\n                                        vio->u.write.vui_from,\n                                        vio->u.write.vui_to);\n                if (rc > 0) {\n                        vio->u.write.vui_written += rc;\n                        rc = 0;\n                }\n        }\n\n        ...\n}\n\nin vvp_io_commit_sync, the cl_page_clip is called to enforce the offset (normally it will only be called for lockless write in osc_io_commit_async)\n\nstatic int vvp_io_commit_sync(const struct lu_env *env, struct cl_io *io,\n                              struct cl_page_list *plist, int from, int to)\n{\n        ...\n\n        if (from > 0 || to != PAGE_SIZE) {\n                page = cl_page_list_first(plist);\n                if (plist->pl_nr == 1) {\n                        cl_page_clip(env, page, from, to);\n                } else {\n                        if (from > 0)\n                                cl_page_clip(env, page, from, PAGE_SIZE);\n                        if (to != PAGE_SIZE) {\n                                page = cl_page_list_last(plist);\n                                cl_page_clip(env, page, 0, to);\n                        }\n                }       \n        }\n\n        ...\n}",
      "accounts_in_message": [],
      "_revision_number": 1
    },
