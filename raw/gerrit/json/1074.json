    {
      "id": "1111eff32acbaf1b7da1572778abcdbae5297a7c",
      "author": {
        "_account_id": 141,
        "name": "Li Wei",
        "email": "wei.g.li@intel.com",
        "username": "liwei",
        "inactive": true
      },
      "date": "2011-07-11 02:27:59.000000000",
      "message": "Patch Set 1: Looks good to me, but someone else must approve\n\nIt would be good if similar checks (for the inclusion of an element in a rehashable hash table) elsewhere could also be verified to be not racy, either in this bug or in a new issue.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "4052dd3be05bcd8500dbc5d507492d07c0c28e4d",
      "author": {
        "_account_id": 8,
        "name": "zhen liang",
        "email": "liang.zhen@live.com",
        "username": "liang"
      },
      "date": "2011-07-16 02:07:48.000000000",
      "message": "Patch Set 1: Looks good to me, but someone else must approve\n\nLi Wei, I do believe we have already got plenty of checks like this, we actually did some discussions about this months ago, to make sure we really need that many assertions on atomics, which is expensive because atomic_read is always reading from memory and slow.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
