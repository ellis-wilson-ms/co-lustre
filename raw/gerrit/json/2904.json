    {
      "id": "9d896ded8c875ad68f3f4e4837325f23e566957d",
      "author": {
        "_account_id": 250,
        "name": "Yevheniy Demchenko",
        "email": "zheka@uvt.cz",
        "username": "lanconnected"
      },
      "date": "2012-05-26 20:16:06.000000000",
      "message": "Patch Set 1:\n\nI'm not sure if it's a good idea to return 0 in selinux_is_enabled in lustre_compat25.h . It forcibly disables selinux in lustre for all RHEL5 clients. Wouldn't it be better to return 1 reverting to the previous behaviour for RHEL5?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "29f43bce3d3b921f74d0d206698d7d5268e85032",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2012-05-26 20:20:54.000000000",
      "message": "Patch Set 1:\n\nI was thinking about this same issue, but in truth Lustre does not work correctly with SELinux for RHEL5 anyway and needs to be disabled, so I don't see that as a shortcoming of this patch.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
