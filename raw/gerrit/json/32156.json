    {
      "id": "de5125a203fbd45b654a9ee3940ff6e7f1f76a86",
      "author": {
        "_account_id": 118,
        "name": "Mikhail Pershin",
        "email": "mpershin@whamcloud.com",
        "username": "tappro"
      },
      "date": "2018-05-02 10:37:34.000000000",
      "message": "Patch Set 1:\n\n(1 comment)",
      "accounts_in_message": [],
