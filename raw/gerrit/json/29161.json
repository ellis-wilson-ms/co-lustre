          {
            "commit": "3f0a7241c434d9556308299eea069628715816c2",
            "subject": "LU-9796 ldiskfs: improve inode allocation performance"
          }
        ],
        "author": {
          "name": "Lai Siyao",
          "email": "lai.siyao@intel.com",
          "date": "2017-09-22 02:42:07.000000000",
          "tz": 480
        },
        "committer": {
          "name": "Oleg Drokin",
          "email": "oleg.drokin@intel.com",
          "date": "2017-11-22 03:55:34.000000000",
          "tz": 0
        },
        "subject": "LU-5024 mdc: don't assert on name pack",
        "message": "LU-5024 mdc: don't assert on name pack\n\nFor old version of MDTs which don't support ATTRFID, open will pack\ndentry name in the request, but this name may change if there is\nconcurrent rename, as a result an assertion will be triggerred.\n\nIt's inconvenient to copy name in advance or take dentry lock in the\ncall chain, so It's better to remove this assert, which is safe.\n\nSigned-off-by: Lai Siyao <lai.siyao@intel.com>\nChange-Id: I58d8b8fbbd8057aa2e8618e8923d0432f31dac96\nReviewed-on: https://review.whamcloud.com/29161\nReviewed-by: Andreas Dilger <andreas.dilger@intel.com>\nTested-by: Jenkins\nTested-by: Maloo <hpdd-maloo@intel.com>\nReviewed-by: John L. Hammond <john.hammond@intel.com>\n"
      },
      "branch": "refs/heads/master"
    }
  },
