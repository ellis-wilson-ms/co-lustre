    {
      "id": "1734db16b0eb4be3b85ff00d4498383d47f591dc",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2013-11-08 19:15:34.000000000",
      "message": "Patch Set 1:\n\nEven with this patch I still see reads from /proc/fs/lustre/mdt/lustre-MDT0000/hsm/actions returning -EIO. Should mdt_hsm_actions_proc_show() be taking cdt_llog_lock around llog_cat_process()? I've also seen several test logs where reading from actions returned -EIO and printed something to sdterr but this was not detected by the test since the lctl was at the start of a pipeline.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "314161628ebc3a8750cddf935a85726d572e976c",
      "author": {
        "_account_id": 4,
        "name": "Jinshan Xiong",
        "email": "jinshan.xiong@intel.com",
        "username": "Jay",
        "inactive": true
      },
      "date": "2013-11-08 20:03:20.000000000",
      "message": "Patch Set 1:\n\nDo you know why it returned EIO?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "f921fc1fab81bf90e4fa1ef1f27e648219d92062",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
