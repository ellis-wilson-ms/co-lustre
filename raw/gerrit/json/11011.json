    {
      "id": "f3016ffcdc03c9d3e85f9e60e4ba83de3c04789e",
      "author": {
        "_account_id": 176,
        "name": "Liang Zhen",
        "email": "liang.zhen@intel.com",
        "username": "liangzhen",
        "inactive": true
      },
      "date": "2014-07-10 04:00:13.000000000",
      "message": "Patch Set 2:\n\nthe reason we have this bug is because old libcfs didn't use GFP flags, instead it had self-defined CFS_ALLOC_* flags, then translated it to GFP flags, however, GFP_ZERO was not translated for some historical reason, and GFP_ZERO was never passed into kmalloc. \n\nAfter we removed  all CFS_ALLOC_* and replaced them with GFP flags, GFP_ZERO can be passed into kmalloc, so the memset should be removed.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
