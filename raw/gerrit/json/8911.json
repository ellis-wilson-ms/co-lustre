    {
      "id": "d7ca5e99ee7c74b8bd99863aeb657922f1ffb26e",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2014-01-21 06:24:01.000000000",
      "message": "Patch Set 4:\n\nalso, I'd suggest do not do any checks in OSD and try to stay within the current design: OSD provides space stats and some estimation for metadata overhead (which is supposed to be simple) and then OFD ensures enough space is reserved for every unit to be written.",
      "accounts_in_message": [],
      "_revision_number": 4
    },
    {
      "id": "e952c3b7f7441d114790539d8333673cbc649178",
      "author": {
        "_account_id": 4,
        "name": "Jinshan Xiong",
        "email": "jinshan.xiong@intel.com",
        "username": "Jay",
        "inactive": true
      },
      "date": "2014-01-21 08:08:38.000000000",
      "message": "Patch Set 4:\n\nwell, if we can ignore rewrite case, that's totally fine. Are you sure it's okay to return ENOSPC for ldiskfs rewriting?",
      "accounts_in_message": [],
      "_revision_number": 4
    },
    {
      "id": "a4aa001ae467158f05ccd55e8d0eb18371d11c89",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2014-01-21 08:11:53.000000000",
      "message": "Patch Set 4:\n\nhard to say, but notice this is the case with ZFS/btrfs.",
      "accounts_in_message": [],
      "_revision_number": 4
    },
