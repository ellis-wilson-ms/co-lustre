        ]
      },
      "date": "2014-01-21 05:25:39.000000000",
      "message": "Patch Set 3: Verified-1\n\nTests received by maloo, run on CentOS release 6.4/x86_64: (https://maloo.whamcloud.com/test_sessions/6983d43a-8256-11e3-8160-52540035b04c).  Ran 21 tests.  1 tests failed: conf-sanity.",
      "accounts_in_message": [],
      "_revision_number": 3
