    {
      "id": "ff4a10e9f458860d4d9572015ebb22d651ddba45",
      "author": {
        "_account_id": 251,
        "name": "Bob Glossman",
        "email": "bob.glossman@intel.com",
        "username": "bogl",
        "inactive": true
      },
      "date": "2012-08-09 22:25:32.000000000",
      "message": "Patch Set 2:\n\nIf I may ask, what's the motivation for using ' = LU_BUF_NULL' at all?  The old code that set all the buf->* fields individually looks pretty clear and concise.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "6f7540ccd6734a4b553eec5f74d54f5af20bc967",
      "author": {
        "_account_id": 140,
        "name": "jacques-Charles Lafoucriere",
        "email": "jacques-charles.lafoucriere@cea.fr",
        "username": "jcl"
      },
      "date": "2012-08-09 22:34:52.000000000",
      "message": "Patch Set 2:\n\nI used LU_BUF_NULL because it was defined. If we want to use the old mode we have to remove it so no ambiguity.\nWhen you look at how lu_buf is used, you see that it is not really an opaque object (some time the pointer is set to NULL and the length to a non zero value)",
      "accounts_in_message": [],
      "_revision_number": 2
    },
