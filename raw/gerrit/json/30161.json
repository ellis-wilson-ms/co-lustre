        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2018-05-03 14:01:14.000000000",
      "message": "Abandoned\n\nFor now. See LU-10994.",
      "accounts_in_message": [],
      "_revision_number": 2
    }
