      },
      "date": "2012-02-16 10:36:35.000000000",
      "message": "Patch Set 1: Verified; Looks good to me, but someone else must approve\n\nDistro/Arch: RHEL6/x86_64 (kernel version: 2.6.32-220.el6)\n\nNetwork: IB (in-kernel OFED)\n\nENABLE_QUOTA=yes\n\nreplay-vbr tests passed: https://maloo.whamcloud.com/test_sets/6461d826-5887-11e1-a226-5254004bbbd3",
      "accounts_in_message": [],
      "_revision_number": 1
    },
