  "messages": [
    {
      "id": "281b938fefe313860fc0a655af96e89e8db871a0",
      "author": {
        "_account_id": 101,
        "name": "Lai Siyao",
        "email": "lai.siyao@whamcloud.com",
        "username": "laisiyao"
      },
      "date": "2013-02-26 10:15:18.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nThis doesn't look to be a right fix, because d_lustre_invalidate() may only __d_drop()  when dentry refcount is zero, that's only possible in ll_md_blocking_ast() for unused dentries.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "9a6df5fe916f260e0ebf8dd7f50a9aa430358acb",
      "author": {
        "_account_id": 2,
        "name": "Jenkins",
        "username": "hudson",
        "inactive": true
      },
      "date": "2013-02-26 12:38:01.000000000",
      "message": "Patch Set 1:\n\nBuild Started http://build.whamcloud.com/job/lustre-reviews/13588/ ",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "d84c9afb451a6a17c31165acf85ea806773aef0c",
      "author": {
        "_account_id": 2,
        "name": "Jenkins",
        "username": "hudson",
        "inactive": true
      },
      "date": "2013-02-26 12:51:15.000000000",
      "message": "Patch Set 1: Verified\n\nBuild Successful \n \nhttp://build.whamcloud.com/job/lustre-reviews/13588/ : SUCCESS",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "e1a7aef3a459c88a43da54c099d577b209bc4e4e",
      "author": {
        "_account_id": 229,
        "name": "Bruno Faccini",
        "email": "bfaccini@nvidia.com",
        "username": "bfaccini"
      },
      "date": "2013-02-26 16:23:33.000000000",
      "message": "Patch Set 1:\n\nHello Lai, I am sorry but I don't understand why you think it is safe in this case to call __d_drop() without cache_lock protection ?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "52dc5def121053fea0a3c9551843f6ff5969ff1a",
      "author": {
        "_account_id": 101,
        "name": "Lai Siyao",
        "email": "lai.siyao@whamcloud.com",
        "username": "laisiyao"
      },
      "date": "2013-02-27 03:45:29.000000000",
      "message": "Patch Set 1:\n\nNo, when d_lustre_invalidate() finds dentry has zero refcount, and calls __d_drop(), dcache_lock should have taken. In the place you pointed out dentry  refcount should not be zero. It will be good to LASSERT(spin_is_locked(&dcache_lock) before __d_drop() is called.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
