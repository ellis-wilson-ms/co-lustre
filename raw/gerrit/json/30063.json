    {
      "id": "ed743867aceb12d792691bcefac09f1cff1125d4",
      "author": {
        "_account_id": 125,
        "name": "James Simmons",
        "email": "jsimmons@infradead.org",
        "username": "jsimmons"
      },
      "date": "2017-12-19 16:13:44.000000000",
      "message": "Patch Set 3:\n\nIn this case it was a rebase since I don't have the power to restart test. When I see test failures I do attempt to duplicate them locally. In this case even now if I run conf-sanity 32b it passes. The same was true for Oleg in his testing. The problem was under the right conditions, everything on one node on a VM, it could finish under one second so the event was missed.  This was a good thing that happened since to pointed out a new class of bugs not encountered before.",
      "accounts_in_message": [],
      "_revision_number": 3
    }
