      "message": "Patch Set 6:\n\nI think it makes sense to update the patch:\n\n\n@@ -1783,6 +1783,7 @@ wait_destroy_complete () {\n        while [ $WAIT -lt $MAX ]; do\n                local -a RPCs=($($LCTL get_param -n osc.*.destroys_in_flight))\n                local con=1\n+               local i\n                for ((i=0; i<${#RPCs[@]}; i++)); do\n                        [ ${RPCs[$i]} -eq 0 ] && continue\n                        # there are still some destroy RPCs in flight\n\n\notherwise \"i\" in sanityn/36 is reset on every iteration.",
