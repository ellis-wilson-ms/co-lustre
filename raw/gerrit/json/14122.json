    {
      "id": "aecc241fedd6705b217aa9b34434cd9e37365dee",
      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2015-03-20 14:39:26.000000000",
      "message": "Patch Set 1: Code-Review-1\n\nI think that changing the time of day on the VMs is a bad idea. There are too many potential unintended consequences.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "2e8b28996dcc199d40046e22bd657a467fa731d0",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2015-03-21 15:46:58.000000000",
      "message": "Patch Set 1:\n\nJohn, what about only changing the clocks forward before the filesystem is mounted, and moving this into a separate test script, maybe run at the end of the test session?  I think there is value in running a test like this, though I agree running it in the middle of sanity is not the right thing. I'd originally suggested conf-sanity.sh, where the filesystem is remounted and reformatted for most tests.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "fa0f3ccaea768e11b87faf972d4e8f79cd025933",
      "author": {
        "_account_id": 104,
        "name": "Niu Yawei",
        "email": "yawei.niu@intel.com",
        "username": "niu",
        "inactive": true
      },
      "date": "2015-03-23 02:12:01.000000000",
      "message": "Patch Set 1:\n\npdsh@shadow-26vm9: shadow-26vm7: mcmd: Error: ^AAuthentication Failure: Expired credential\n\nMaybe we can just decrease the time difference from 1 year to a small value which won't expire the pdsh credential?",
      "accounts_in_message": [],
      "_revision_number": 1
    },
