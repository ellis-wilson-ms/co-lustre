      "commit": {
        "parents": [
          {
            "commit": "6a012fe89a63cea5b0f1008125c5df319c4986cb",
            "subject": "LU-12905 tests: wrappers for createmany and unlinkmany"
          }
        ],
        "author": {
          "name": "Mr NeilBrown",
          "email": "neilb@suse.de",
          "date": "2020-06-18 01:38:25.000000000",
          "tz": 600
        },
        "committer": {
          "name": "Oleg Drokin",
          "email": "green@whamcloud.com",
          "date": "2020-06-23 08:12:41.000000000",
          "tz": 0
        },
        "subject": "LU-12780 scrub: all update to bitfields must be protected.",
        "message": "LU-12780 scrub: all update to bitfields must be protected.\n\nWhen a structure contains bitfields, these are updated by\na read-modify-write of the whole word.\nIf two of these updates can race, corruption can occurs - updates can\nbe lost.\n\nTo avoid this, it is best to protect updates with a spinlock.\nMany updates to the os_* bit fields are already protected by\n->os_lock.  This patch addes the lock to the remaining updates.\nIn many cases, this only requires moving a 'lock' earlier, or an\n'unlock' later.\n\nSigned-off-by: Mr NeilBrown <neilb@suse.de>\nChange-Id: I2335d08cd53dcda98d8046d730829347456a6c5d\nReviewed-on: https://review.whamcloud.com/38974\nTested-by: jenkins <devops@whamcloud.com>\nReviewed-by: Alex Zhuravlev <bzzz@whamcloud.com>\nTested-by: Maloo <maloo@whamcloud.com>\nReviewed-by: James Simmons <jsimmons@infradead.org>\nReviewed-by: Oleg Drokin <green@whamcloud.com>\n"
      },
      "branch": "refs/heads/master"
    }
  },
  "requirements": [],
  "submit_records": []
}