  "messages": [
    {
      "id": "37d2012f9a74824108ac999b4bc9ad2947996cfc",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2012-03-15 10:05:16.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nI've added Liang as an inspector for this patch, since he is our networking Guru and should be inspecting this patch.\n\nAs with other patch comments, removing support for clients newer than 2.6.18 is undesirable, so parts of this patch should not be landed.\n\nWith OFED there is an added complexity that some users compile against out-of-tree OFED releases for a variety of reasons, so just because specific features were back-ported to RHEL5 does not necessarily mean that the out-of-tree OFED code has those features.\n\nThat means (5) and (6) are probably off the list, and probably (2) as well.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
