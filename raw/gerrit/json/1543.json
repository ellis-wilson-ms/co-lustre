    {
      "id": "c468466fc5aab3e77dcbceeff9cb6bb6b5acbb1e",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2011-11-07 02:24:16.000000000",
      "message": "Patch Set 4: I would prefer that you didn't submit this\n\nThe problem with a signal an interruptible version of lwi is it will abort immediately and this breaks assumptions for normal requests that are in flight like disconnect.\n\nI can reliably reproduce such hanging of umount in conf-sanity test 5a if I run it in a loop.\n\nI have another idea for a fix that I am now testing.",
      "accounts_in_message": [],
      "_revision_number": 4
    },
