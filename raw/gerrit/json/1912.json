    {
      "id": "199ac9ca4596ec8084a74ec286da2c8076350652",
      "author": {
        "_account_id": 117,
        "name": "Andreas Dilger",
        "email": "adilger@thelustrecollective.com",
        "username": "adilger"
      },
      "date": "2012-01-05 00:26:48.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\n(1 inline comment)\n\nThe main objection is that this reduces the minimum debug amount below 10MB on a system with few cores.\n\nThat said, I wouldn't object to fixing this in a more robust manner, such as reducing the kernel-side minimum limit to some fixed number (e.g. max(2MB, CFS_PAGE_SIZE * cfs_num_possible_cpus()).  On a system with a large number of cores (e.g. some SGI monster with 4096 cores needing 8GB of RAM just for debug logs) this might consume a lot of memory even though only a limited number of cores might be doing Lustre IO, and those cores might not even have that much RAM themselves.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "03e48b4f0e26ec10893e2788172fe99753a32b23",
      "author": {
        "_account_id": 225,
        "name": "Denis Kondratenko",
        "email": "Denis_Kondratenko@xyratex.com",
        "username": "denis_kondratenko",
        "inactive": true
      },
      "date": "2012-02-07 17:46:44.000000000",
      "message": "Uploaded patch set 2.",
      "accounts_in_message": [],
      "_revision_number": 2
    },
    {
      "id": "907e3df59e3d17fadc93759c8496446c0feeb454",
      "author": {
        "_account_id": 225,
        "name": "Denis Kondratenko",
        "email": "Denis_Kondratenko@xyratex.com",
        "username": "denis_kondratenko",
        "inactive": true
      },
      "date": "2012-02-07 17:53:16.000000000",
      "message": "Patch Set 2:\n\nAgree with min 10MB. But maximum size s limited by cfs_trace_max_debug_mb() in cfs_trace_set_debug_mb:\nreturn MAX(512, (total_mb * 80)/100);",
      "accounts_in_message": [],
      "_revision_number": 2
    },
