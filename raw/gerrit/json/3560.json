      "date": "2012-08-09 11:53:40.000000000",
      "message": "Patch Set 4:\n\nldiskfs_iget() handled the NUL terminator for fast symlink case.\n\n} else if (S_ISLNK(inode->i_mode)) {\n        if (ldiskfs_inode_is_fast_symlink(inode)) {\n                inode->i_op = &ldiskfs_fast_symlink_inode_operatoins;\n                nd_terminate_link(ei->i_data, inode->i_size,\n                        sizeof(ei->i_data) - 1);\n        } else {\n                inode->i_op = &ldiskfs_symlink_inode_operations;\n                ldiskfs_set_aops(inode);\n       }\n}",
      "accounts_in_message": [],
      "_revision_number": 4
