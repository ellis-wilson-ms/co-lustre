    {
      "id": "6d5b6896f5fb76076617dfd57ac1681753b5e719",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2012-07-27 04:03:49.000000000",
      "message": "Patch Set 1:\n\nI have a patch solving this problem, but forgot to push it:\nhttp://review.whamcloud.com/#change,3484\n\nwe discussed this yesterday with LiWei, I think the only problem\nwith his patch is that it uses '-' as a delimiter which I was told\nis not correct.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "d67fc46bf6a8f43fb5a51c6d25ca65a702d58f2e",
      "author": {
        "_account_id": 141,
        "name": "Li Wei",
        "email": "wei.g.li@intel.com",
        "username": "liwei",
        "inactive": true
      },
      "date": "2012-07-27 07:58:36.000000000",
      "message": "Patch Set 1:\n\nAlex, I think server_name2fsname() is still a good helper interface.  Hiding string parsing code inside that function avoids adding complexity to lsi_prepare().  Would you like to update your patch to implement server_name2fsname() with your existing string parsing code?  I could simply abandon this patch.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "f7e2d8a059f1108b66be22bb93fb5a38d2a718da",
      "author": {
        "_account_id": 119,
        "name": "Alex Zhuravlev",
        "email": "bzzz@whamcloud.com",
        "username": "bzzz"
      },
      "date": "2012-07-27 11:00:52.000000000",
      "message": "Patch Set 1:\n\noriginally I took server_name2fsname() from orion, but then got to think that couple strstr() and one arithmetic operation are easier to do directly in lsi_prepare(). probably Andreas has an opinion on this.. in the end, either way is fine to me as long as we look for -OST or -MDT and not for '-'.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
      "id": "ef0a58fe78fe0b1c0e175a68ebf585cf2f044229",
      "author": {
