      "author": {
        "_account_id": 177,
        "name": "John Hammond",
        "email": "jhammond@whamcloud.com",
        "username": "jhammond"
      },
      "date": "2016-10-17 20:14:46.000000000",
      "message": "Patch Set 1: Code-Review+1\n\nLooks fine. But since osc_match_base() is only called from osc_dlmlock_at_pgoff() and we end up putting the lock in the callee only to get it again in the caller, it would be better if we just removed osc_match_base() and simplified.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
