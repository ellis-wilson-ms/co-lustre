      },
      "date": "2025-04-07 07:37:13.000000000",
      "message": "Patch Set 3: Code-Review+1\n\nVerified +1\n\n# cat review.patch \ndiff --git a/lustre/llite/dir.c b/lustre/llite/dir.c\nindex 36dbfaa628..90348cf66a 100644\n--- a/lustre/llite/dir.c\n+++ b/lustre/llite/dir.c\n@@ -2043,6 +2043,10 @@ out_free:\n \t\tbool createonly = false;\n \t\tint len;\n \t\tint rc;\n+\t\tchar *review_testing = \"review.testing\";\n+\n+\t\tCERROR(\"%s: Review Testing %.*s : rc = %d\\n\",\n+\t\t       \"Value\", review_testing, 0);\n \n \t\trc = obd_ioctl_getdata(&data, &len, uarg);\n \t\tif (rc)\ndiff --git a/lustre/obdclass/linkea.c b/lustre/obdclass/linkea.c\nindex 823648bd93..1538438d3a 100644\n--- a/lustre/obdclass/linkea.c\n+++ b/lustre/obdclass/linkea.c\n@@ -161,6 +161,9 @@ int linkea_add_buf(struct linkea_data *ldata, const struct lu_name *lname,\n \t\tleh = ldata->ld_leh = ldata->ld_buf->lb_buf;\n \t}\n \n+\tCDEBUG(D_INODE, \"Testing. New link_ea name '\"DFID\":\"DNAME\"' is added\\n\",\n+\t       PFID(pfid), PNAME(lname));\n+\n \tldata->ld_lee = ldata->ld_buf->lb_buf + leh->leh_len;\n\n\n# git diff > review.patch\n# perl contrib/scripts/checkpatch.pl review.patch \nWARNING: '.*s' may be misspelled - perhaps 'DNAME and encode_fn_len()'?\n#11: FILE: lustre/llite/dir.c:2048:\n+\t\tCERROR(\"%s: Review Testing %.*s : rc = %d\\n\",\n \t\t                            ^^^\n\nWARNING: 'PNAME' may be misspelled - perhaps 'encode_fn_luname'?\n#25: FILE: lustre/obdclass/linkea.c:165:\n+\t       PFID(pfid), PNAME(lname));\n \t                   ^^^^^",
      "accounts_in_message": [],
      "_revision_number": 3
    },
