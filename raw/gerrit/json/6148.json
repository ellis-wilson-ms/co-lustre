  "messages": [
    {
      "id": "44ba5f9d2584ff64ca83eb42814e35685ac99795",
      "author": {
        "_account_id": 112,
        "name": "Oleg Drokin",
        "email": "green@whamcloud.com",
        "username": "green"
      },
      "date": "2013-04-24 20:53:49.000000000",
      "message": "Patch Set 1: I would prefer that you didn't submit this\n\nA generic patch needs a bit more work since it will cause 4-8M of space used per namespace on clients which is somewhat excessive.\nAs a server-only patch this is fine, though.\n\nFor a generic patch the namespace type needs to be checked and the bits changed accordingly.",
      "accounts_in_message": [],
      "_revision_number": 1
    },
    {
