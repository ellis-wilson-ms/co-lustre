<item>
            <title>[LUDOC-86] DNE Phase I Doc Changes</title>
                <link>https://jira.whamcloud.com/browse/LUDOC-86</link>
                <project id="10070" key="LUDOC">Lustre Documentation</project>
                    <description>&lt;p&gt;A considerable amount of updates to the manual: description of feature, configuration, administration, troubleshooting and repair of MDT failures&lt;/p&gt;</description>
                <environment></environment>
        <key id="15929">LUDOC-86</key>
            <summary>DNE Phase I Doc Changes</summary>
                <type id="4" iconUrl="https://jira.whamcloud.com/secure/viewavatar?size=xsmall&amp;avatarId=11310&amp;avatarType=issuetype">Improvement</type>
