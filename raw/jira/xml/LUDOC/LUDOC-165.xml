<item>
            <title>[LUDOC-165] Make left panel navigation appear in PDF by default</title>
                <link>https://jira.whamcloud.com/browse/LUDOC-165</link>
                <project id="10070" key="LUDOC">Lustre Documentation</project>
                    <description>&lt;p&gt;The PDF version of the Lustre manual now has a very nice navigation system available in the left panel.  However, two clicks are required to make it visible. It would be very useful to have this navigation system appear by default when the PDF is opened. &lt;/p&gt;</description>
                <environment></environment>
        <key id="19728">LUDOC-165</key>
            <summary>Make left panel navigation appear in PDF by default</summary>
                <type id="1" iconUrl="https://jira.whamcloud.com/secure/viewavatar?size=xsmall&amp;avatarId=11303&amp;avatarType=issuetype">Bug</type>
