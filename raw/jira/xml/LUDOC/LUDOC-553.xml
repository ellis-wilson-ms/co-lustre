	&lt;li&gt;&lt;a href=&quot;https://github.com/DetlevCM/lustre-build-instructions&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;https://github.com/DetlevCM/lustre-build-instructions&lt;/a&gt; (personal notes, drawing from the whamcloud wiki as foundation)&lt;/li&gt;
&lt;/ul&gt;


&lt;p&gt;Via &lt;a href=&quot;https://jira.whamcloud.com/browse/LUDOC-539&quot; title=&quot;Lustre Wiki: Review Introductory Pages&quot; class=&quot;issue-link&quot; data-issue-key=&quot;LUDOC-539&quot;&gt;LUDOC-539&lt;/a&gt;&lt;/p&gt;
&lt;ul class=&quot;alternate&quot; type=&quot;square&quot;&gt;
	&lt;li&gt;&lt;a href=&quot;https://wiki.lustre.org/Lustre_with_ZFS_Install&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;https://wiki.lustre.org/Lustre_with_ZFS_Install&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;&lt;a href=&quot;https://wiki.lustre.org/Operating_System_Configuration_Guidelines_For_Lustre&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;https://wiki.lustre.org/Operating_System_Configuration_Guidelines_For_Lustre&lt;/a&gt; (maybe)&lt;/li&gt;
&lt;/ul&gt;


