                            <comment id="480280" author="arshad512" created="Thu, 4 Dec 2025 09:37:58 +0000"  >&lt;p&gt;It is not a fix. But It will stop multiop from executing in a loop and break out.&lt;/p&gt;

&lt;p&gt;&#160;&lt;/p&gt;
&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;diff --git a/lustre/tests/sanity.sh b/lustre/tests/sanity.sh
index 4f825ce824..fb048b4f84 100755
--- a/lustre/tests/sanity.sh
+++ b/lustre/tests/sanity.sh
@@ -1076,6 +1076,11 @@ test_23d() {
&#160;
&#160; &#160; &#160;echo CentaurHauls &amp;gt; $file
&#160; &#160; &#160;offset=$($MULTIOP $file oO_WRONLY:O_APPEND:w13Zp)
+ &#160; &#160;rc=$?
+ &#160; &#160;if ((rc != 0)); then
+ &#160; &#160; &#160; &#160;error &quot;Multiop execution failed... &apos;$rc&apos;&quot;
+ &#160; &#160;fi
+
&#160; &#160; &#160;if ((offset != 26)); then
&#160; &#160; &#160; &#160; &#160;error &quot;wrong offset, expected 26, got &apos;$offset&apos;&quot;
&#160; &#160; &#160;fi
&#160;
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;&#160;&lt;/p&gt;</comment>
