<item>
            <title>[LU-1178] OFD Test Framework Changes</title>
                <link>https://jira.whamcloud.com/browse/LU-1178</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Once OFD has landed, update test framework to test OFD in addition to obdfilter&lt;/p&gt;</description>
                <environment></environment>
        <key id="13432">LU-1178</key>
            <summary>OFD Test Framework Changes</summary>
