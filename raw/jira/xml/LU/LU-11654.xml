{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.721689&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffc0ff9914&amp;gt;&amp;#93;&lt;/span&gt; class_fail_export+0x224/0x520 &lt;span class=&quot;error&quot;&gt;&amp;#91;obdclass&amp;#93;&lt;/span&gt;}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.728794&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffc11e5a38&amp;gt;&amp;#93;&lt;/span&gt; expired_lock_main+0x5f8/0xc00 &lt;span class=&quot;error&quot;&gt;&amp;#91;ptlrpc&amp;#93;&lt;/span&gt;}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.735665&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff9dccf670&amp;gt;&amp;#93;&lt;/span&gt; ? wake_up_state+0x20/0x20}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.741449&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffc11e5440&amp;gt;&amp;#93;&lt;/span&gt; ? ldlm_server_glimpse_ast+0x3f0/0x3f0 &lt;span class=&quot;error&quot;&gt;&amp;#91;ptlrpc&amp;#93;&lt;/span&gt;}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.749012&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff9dcbb621&amp;gt;&amp;#93;&lt;/span&gt; kthread+0xd1/0xe0}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.754065&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff9dcbb550&amp;gt;&amp;#93;&lt;/span&gt; ? insert_kthread_work+0x40/0x40}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.760333&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff9e3205f7&amp;gt;&amp;#93;&lt;/span&gt; ret_from_fork_nospec_begin+0x21/0x21}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.767030&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff9dcbb550&amp;gt;&amp;#93;&lt;/span&gt; ? insert_kthread_work+0x40/0x40}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.773285&amp;#93;&lt;/span&gt; Code: 74 50 4c 89 e7 44 89 45 c0 e8 bc f5 87 ff 48 85 c0 44 8b 45 c0 74 06 80 78 70 00 74 35 48 8b 45 b8 8b 4d c4 48 89 df 44 89 45 c0 &amp;lt;8b&amp;gt; 50 18 8b 70 14 e8 34 ae ff ff 48 85 c0 48 89 c2 44 8b 45 c0}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.793410&amp;#93;&lt;/span&gt; RIP &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffc17c2b41&amp;gt;&amp;#93;&lt;/span&gt; mdd_close+0x241/0xf40 &lt;span class=&quot;error&quot;&gt;&amp;#91;mdd&amp;#93;&lt;/span&gt;}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.799703&amp;#93;&lt;/span&gt; RSP &amp;lt;ffff8fbf6cc9fcb0&amp;gt;}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.803360&amp;#93;&lt;/span&gt; CR2: 0000000000000018}}&lt;/p&gt;

&lt;p&gt;}}&lt;/p&gt;

&lt;p&gt;The root cause of this issue is that &lt;tt&gt;mdd_close()&lt;/tt&gt;&#160;assumes that &lt;tt&gt;lu_ucred&lt;/tt&gt; is always initialized.&lt;/p&gt;

&lt;p&gt;&#160;&lt;/p&gt;

&lt;p&gt;Patch is coming soon&lt;/p&gt;</description>
