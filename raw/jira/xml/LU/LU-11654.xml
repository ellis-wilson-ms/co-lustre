<item>
            <title>[LU-11654] kernel crash on client eviction with CL_OPEN changelog enabled</title>
                <link>https://jira.whamcloud.com/browse/LU-11654</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Encounter this issue in my test:&lt;/p&gt;

&lt;p&gt;&lt;tt&gt;&lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.601469&amp;#93;&lt;/span&gt; Hardware name: Quanta Cloud Technology Inc. QuantaGrid D51PH-1ULH/S2PH-MB, BIOS S2P_3B04 03/04/2016&lt;/tt&gt;&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.611713&amp;#93;&lt;/span&gt; task: ffff8fbf68309fa0 ti: ffff8fbf6cc9c000 task.ti: ffff8fbf6cc9c000}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.619358&amp;#93;&lt;/span&gt; RIP: 0010:&lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffc17c2b41&amp;gt;&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffc17c2b41&amp;gt;&amp;#93;&lt;/span&gt; mdd_close+0x241/0xf40 &lt;span class=&quot;error&quot;&gt;&amp;#91;mdd&amp;#93;&lt;/span&gt;}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.627991&amp;#93;&lt;/span&gt; RSP: 0018:ffff8fbf6cc9fcb0 EFLAGS: 00010246}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.633468&amp;#93;&lt;/span&gt; RAX: 0000000000000000 RBX: ffff8fa7fda20ba0 RCX: 00000000000000c3}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.640766&amp;#93;&lt;/span&gt; RDX: 0000000000000001 RSI: ffffffffc0b3fec0 RDI: ffff8fa7fda20ba0}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.648064&amp;#93;&lt;/span&gt; RBP: ffff8fbf6cc9fd08 R08: 0000000000000001 R09: ffffffffc1026a71}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.655362&amp;#93;&lt;/span&gt; R10: 0000000000000000 R11: ffffd41edd731800 R12: ffff8fbf6cc9fd90}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.662659&amp;#93;&lt;/span&gt; R13: 0000000000000000 R14: 0000000000000000 R15: 0000000000000001}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.669958&amp;#93;&lt;/span&gt; FS: 0000000000000000(0000) GS:ffff8fafffbc0000(0000) knlGS:0000000000000000}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.678218&amp;#93;&lt;/span&gt; CS: 0010 DS: 0000 ES: 0000 CR0: 0000000080050033}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.684128&amp;#93;&lt;/span&gt; CR2: 0000000000000018 CR3: 0000000f9fe0e000 CR4: 00000000003607e0}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.691427&amp;#93;&lt;/span&gt; DR0: 0000000000000000 DR1: 0000000000000000 DR2: 0000000000000000}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.698732&amp;#93;&lt;/span&gt; DR3: 0000000000000000 DR6: 00000000fffe0ff0 DR7: 0000000000000400}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.706030&amp;#93;&lt;/span&gt; Call Trace:}}&lt;br/&gt;
{{ &lt;span class=&quot;error&quot;&gt;&amp;#91;5996825.708679&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffc163165b&amp;gt;&amp;#93;&lt;/span&gt; mdt_mfd_close+0x3cb/0x810 &lt;span class=&quot;error&quot;&gt;&amp;#91;mdt&amp;#93;&lt;/span&gt;}}&lt;br/&gt;
