<item>
            <title>[LU-19812] lnetctl import fails for IPv6 configurations</title>
                <link>https://jira.whamcloud.com/browse/LU-19812</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;lnetctl import fails when importing IPv6 configurations, while adding IPv6 NIDs via the `lnetctl net add` command line succeeds. &lt;br/&gt;
Note that `lnetctl import` works correctly for IPv4 configurations.&lt;/p&gt;

&lt;p&gt;&lt;b&gt;Environment Information:&lt;/b&gt;&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
# ip addr show dev ens38
4: ens38: &amp;lt;BROADCAST,MULTICAST,UP,LOWER_UP&amp;gt; mtu 1500 qdisc fq_codel state UP group &lt;span class=&quot;code-keyword&quot;&gt;default&lt;/span&gt; qlen 1000
&#160; &#160; link/ether 00:0c:29:dc:8c:00 brd ff:ff:ff:ff:ff:ff
&#160; &#160; altname enp2s6
&#160; &#160; inet6 2001::211:2233:4455:203/64 scope global tentative
&#160; &#160; &#160; &#160;valid_lft forever preferred_lft forever &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;&lt;b&gt;Test showing lnetctl import IPv6 failure:&lt;/b&gt;&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
# lustre_rmmod
# modprobe lnet
# lnetctl lnet configure
# cat lnet.yaml
net:
- &#160; &#160; net type: tcp6
&#160; &#160; &#160; local NI(s):
&#160; &#160; &#160; - &#160; &#160; nid: 2001::211:2233:4455:203@tcp6
&#160; &#160; &#160; &#160; &#160; &#160; interfaces:
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; 0: ens38
# lnetctl &lt;span class=&quot;code-keyword&quot;&gt;import&lt;/span&gt; lnet.yaml
---
add:
- &#160; &#160; &lt;span class=&quot;code-keyword&quot;&gt;import&lt;/span&gt;:
&#160; &#160; &#160; errno: -22
&#160; &#160; &#160; descr: ! &lt;span class=&quot;code-quote&quot;&gt;&quot;\&quot;&lt;/span&gt;couldn&apos;t query intf ens38\&quot;&quot;
... &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;&lt;b&gt;Adding IPv6 NID via lnetctl net add command succeeds:&lt;/b&gt;&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
# lnetctl net add --nid 2001::211:2233:4455:203@tcp6
# lnetctl net show
net:
- &#160; &#160; net type: lo
&#160; &#160; &#160; local NI(s):
&#160; &#160; &#160; - &#160; &#160; nid: 0@lo
&#160; &#160; &#160; &#160; &#160; &#160; status: up
- &#160; &#160; net type: tcp6
&#160; &#160; &#160; local NI(s):
&#160; &#160; &#160; - &#160; &#160; nid: 2001::211:2233:4455:203@tcp6
&#160; &#160; &#160; &#160; &#160; &#160; status: up
&#160; &#160; &#160; &#160; &#160; &#160; interfaces:
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; 0: ens38 &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
