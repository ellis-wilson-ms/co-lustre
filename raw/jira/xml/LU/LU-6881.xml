<item>
            <title>[LU-6881] sub_trans_commit_cb() is racy</title>
                <link>https://jira.whamcloud.com/browse/LU-6881</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;sub_trans_commit_cb() can be called by in parallel, so all_committed could be set to false even if all sub transactions are committed.&lt;/p&gt;

&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;&lt;span class=&quot;code-keyword&quot;&gt;static&lt;/span&gt; void sub_trans_commit_cb(struct lu_env *env,
                                struct thandle *sub_th,
                                struct dt_txn_commit_cb *cb, &lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; err)
{
        struct sub_thandle      *st;
        struct top_multiple_thandle *tmt = cb-&amp;gt;dcb_data;
        bool                    all_committed = &lt;span class=&quot;code-keyword&quot;&gt;true&lt;/span&gt;;
        ENTRY;

        &lt;span class=&quot;code-comment&quot;&gt;/* Check &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; all sub thandles are committed */&lt;/span&gt;
        list_for_each_entry(st, &amp;amp;tmt-&amp;gt;tmt_sub_thandle_list, st_sub_list) {
                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (st-&amp;gt;st_sub_th == sub_th) {
                        st-&amp;gt;st_committed = 1;
                        st-&amp;gt;st_result = err;
                }
                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (!st-&amp;gt;st_committed)
                        all_committed = &lt;span class=&quot;code-keyword&quot;&gt;false&lt;/span&gt;;
        }

        &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (tmt-&amp;gt;tmt_result == 0)
                tmt-&amp;gt;tmt_result = err;

        &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (all_committed)
                top_trans_committed_cb(tmt);

        top_multiple_thandle_dump(tmt, D_INFO);
        top_multiple_thandle_put(tmt);
        RETURN_EXIT;
}
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
