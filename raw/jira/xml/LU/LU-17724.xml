                            <comment id="410799" author="sebastien" created="Thu, 11 Apr 2024 06:54:41 +0000"  >&lt;p&gt;This crash is caused by the use of a user pointer when printing a debug message after &lt;tt&gt;upcall_cache_set_upcall&lt;/tt&gt; returns an error:&lt;/p&gt;
&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;	rc = upcall_cache_set_upcall(rsicache, kbuf, count, true);
	if (rc) {
		CERROR(&quot;%s: incorrect rsi upcall %.*s. Valid value for sptlrpc.gss.rsi_upcall is an executable pathname: rc = %d\n&quot;,
		       rsicache-&amp;gt;uc_name, (int)count, buffer, rc);
		GOTO(out, rc);
	}
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</comment>
