<item>
            <title>[LU-3694] Posix copytool cleanup</title>
                <link>https://jira.whamcloud.com/browse/LU-3694</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Several minor issues have been identified during the review of the initial version of the HSM posix copytool, such as calling select() on regular files.&lt;/p&gt;</description>
                <environment></environment>
        <key id="20179">LU-3694</key>
            <summary>Posix copytool cleanup</summary>
