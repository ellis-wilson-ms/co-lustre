<item>
            <title>[LU-2594] Can one add new LID on a live filesystem</title>
                <link>https://jira.whamcloud.com/browse/LU-2594</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;We would like to add additional nids to our OSS and MDS with out taking down the filesystem. Can we add nids and have them usable by new clients?&lt;/p&gt;</description>
                <environment></environment>
        <key id="17122">LU-2594</key>
            <summary>Can one add new LID on a live filesystem</summary>
                <type id="1" iconUrl="https://jira.whamcloud.com/secure/viewavatar?size=xsmall&amp;avatarId=11303&amp;avatarType=issuetype">Bug</type>
                                            <priority id="4" iconUrl="https://jira.whamcloud.com/images/icons/priorities/minor.svg">Minor</priority>
                        <status id="5" iconUrl="https://jira.whamcloud.com/images/icons/statuses/resolved.png" description="A resolution has been taken, and it is awaiting verification by reporter. From here issues are either reopened, or are closed.">Resolved</status>
                    <statusCategory id="3" key="done" colorName="success"/>
                                    <resolution id="1">Fixed</resolution>
                                        <assignee username="cliffw">Cliff White</assignee>
                                    <reporter username="mhanafi">Mahmoud Hanafi</reporter>
                        <labels>
                    </labels>
                <created>Wed, 9 Jan 2013 15:11:27 +0000</created>
                <updated>Fri, 15 Feb 2013 17:30:36 +0000</updated>
                            <resolved>Fri, 15 Feb 2013 17:30:36 +0000</resolved>
                                    <version>Lustre 2.1.2</version>
                                                        <due></due>
                            <votes>0</votes>
                                    <watches>3</watches>
                                                                            <comments>
                            <comment id="52491" author="cliffw" created="Fri, 15 Feb 2013 17:30:36 +0000"  >&lt;p&gt;Please reopen if you have further questions&lt;/p&gt;</comment>
                            <comment id="50426" author="cliffw" created="Mon, 14 Jan 2013 12:10:52 +0000"  >&lt;p&gt;You need to do the --writeconf so the servers can use the new NIDS. And the clients have to be un-mounted to do the --writeconf. See the Lustre Manual. &lt;/p&gt;</comment>
                            <comment id="50290" author="mhanafi" created="Thu, 10 Jan 2013 16:48:40 +0000"  >&lt;p&gt;If we are adding an additional for new clients and not changing the one for existing clients do we need to do a umount?&lt;/p&gt;</comment>
                            <comment id="50286" author="cliffw" created="Thu, 10 Jan 2013 15:58:06 +0000"  >&lt;p&gt;No, you will have to run --writeconf on the servers to establish the new NIDS, and this will require the clients to umount. In addition, a new MGS NID may change the clients mount command.&lt;/p&gt;</comment>
                    </comments>
