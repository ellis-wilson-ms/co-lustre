<item>
            <title>[LU-10971] Modify lustre-rsync-test to use new changelog routines in test-framework</title>
                <link>https://jira.whamcloud.com/browse/LU-10971</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;The lustre rsync-test registers and deregisters changelog users in subroutines&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;  62 init_changelog() {
  63     CL_USER=$(do_facet $SINGLEMDS lctl --device $MDT0 changelog_register -n)
  64     echo $MDT0: Registered changelog user $CL_USER
  65     CL_USERS=$(( $(do_facet $SINGLEMDS lctl get_param -n \
  66         mdd.$MDT0.changelog_users | wc -l) - 2 ))
  67     [ $CL_USERS -ne 1 ] &amp;amp;&amp;amp; \
  68         echo &lt;span class=&quot;code-quote&quot;&gt;&quot;Other changelog users present ($CL_USERS)&quot;&lt;/span&gt;
  69 }
&#8230;
  90 fini_changelog() {
  91     $LFS changelog_clear $MDT0 $CL_USER 0
  92     do_facet $SINGLEMDS lctl --device $MDT0 changelog_deregister $CL_USER
  93 }

&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;

&lt;p&gt;These subroutines should be updated to use changelog_register and changelog_deregister.&lt;/p&gt;</description>
