--- a/lustre/tests/replay-single.sh
+++ b/lustre/tests/replay-single.sh
@@ -336,6 +336,7 @@ test_14() {
 run_test 14 &lt;span class=&quot;code-quote&quot;&gt;&quot;open(O_CREAT), unlink |X| close&quot;&lt;/span&gt;
 
 test_15() {
+    sync
     multiop_bg_pause $DIR/$tfile O_tSc || &lt;span class=&quot;code-keyword&quot;&gt;return&lt;/span&gt; 5
