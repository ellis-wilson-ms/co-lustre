<item>
            <title>[LU-16205] fid2path for encrypted files</title>
                <link>https://jira.whamcloud.com/browse/LU-16205</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Two cases to support:&lt;/p&gt;
&lt;ul class=&quot;alternate&quot; type=&quot;square&quot;&gt;
	&lt;li&gt;fid2path with the encryption key&lt;/li&gt;
	&lt;li&gt;fid2path without the encryption key&lt;/li&gt;
&lt;/ul&gt;
</description>
                <environment></environment>
