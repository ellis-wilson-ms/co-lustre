	LAYOUT_INTENT_PCCRO_PIN	= 9,	&lt;span class=&quot;code-comment&quot;&gt;/** pin the file into PCCRO */&lt;/span&gt;
	LAYOUT_INTENT_PCCRO_UNPIN = 10,	
