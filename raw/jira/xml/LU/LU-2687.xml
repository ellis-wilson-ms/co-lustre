<item>
            <title>[LU-2687] create conf-sanity.sh test_32 ZFS upgrade test image</title>
                <link>https://jira.whamcloud.com/browse/LU-2687</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;In order to ensure that we do not break ZFS upgrades in the future, a filesystem test image is needed for conf-sanity.sh test_32a.&lt;/p&gt;</description>
                <environment></environment>
        <key id="17320">LU-2687</key>
            <summary>create conf-sanity.sh test_32 ZFS upgrade test image</summary>
