make[5]: *** [/var/lib/jenkins/workspace/lustre-ppc-builder/arch/ppc64/build_type/server/distro/el6/ib_stack/ofa/BUILD/BUILD/lustre-ldiskfs-3.3.0/ldiskfs/mballoc.o] Error 1
make[5]: *** Waiting for unfinished jobs....
