<item>
            <title>[LU-18279] short fix of class_add_nids_to_uuid</title>
                <link>https://jira.whamcloud.com/browse/LU-18279</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;int class_add_nids_to_uuid(struct obd_uuid *uuid, struct lnet_nid *nidlist,
&#160;&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; int nid_count, int nid_size)
{
&#160; &#160; &#160; &#160; struct uuid_nid_data *entry;
&#160; &#160; &#160; &#160; int i, rc; 
&#160; &#160; &#160; &#160; bool matched = false;


&#160; &#160; &#160; &#160; ENTRY;


&#160; &#160; &#160; &#160; if (nid_count &amp;gt;= MTI_NIDS_MAX) {
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; CDEBUG(D_NET, &quot;too many NIDs (%d) for UUID &apos;%s&apos;\n&quot;,
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; nid_count, obd_uuid2str(uuid));
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; return -ENOSPC;
&#160; &#160; &#160; &#160; }&#160; &#160;
... &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;We need here strong comparison ( &amp;gt; ), otherwise it utilizes only 31 (MTI_NIDS_MAX -1 ) elements instead of 32 (MTI_NIDS_MAX).&lt;/p&gt;</description>
