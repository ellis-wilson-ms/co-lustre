                            <comment id="84205" author="di.wang" created="Thu, 15 May 2014 17:40:54 +0000"  >&lt;p&gt;&lt;a href=&quot;http://review.whamcloud.com/10338&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;http://review.whamcloud.com/10338&lt;/a&gt;&lt;/p&gt;</comment>
                            <comment id="84196" author="di.wang" created="Thu, 15 May 2014 17:14:45 +0000"  >&lt;p&gt;It seems we did not consider default LMV EA when we try to shrink the EA size in RPC.&lt;/p&gt;

&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;int mdt_attr_get_eabuf_size(struct mdt_thread_info *info, struct mdt_object *o)
{
.............
        /* Is it a directory? Let&apos;s check for the LMV as well */
        if (S_ISDIR(lu_object_attr(&amp;amp;mdt_object_child(o)-&amp;gt;mo_lu))) {
                rc2 = mo_xattr_get(env, mdt_object_child(o), &amp;amp;LU_BUF_NULL,
                                   XATTR_NAME_LMV);
                         &amp;lt;-------------------------- we should check default LMV EA as well.
                if ((rc2 &amp;lt; 0 &amp;amp;&amp;amp; rc2 != -ENODATA) || (rc2 &amp;gt; rc))
                        rc = rc2;
       }

&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt; </comment>
