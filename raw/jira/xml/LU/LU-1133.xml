<item>
            <title>[LU-1133] sanity-quota 33 fails</title>
                <link>https://jira.whamcloud.com/browse/LU-1133</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;cleanup_quota_test() {&lt;br/&gt;
        trap 0&lt;br/&gt;
        echo &quot;Delete files...&quot;&lt;br/&gt;
        rm -rf $DIR/$tdir&lt;br/&gt;
}&lt;/p&gt;


&lt;ol&gt;
	&lt;li&gt;basic usage tracking for user &amp;amp; group&lt;br/&gt;
test_33() {&lt;br/&gt;
...&lt;br/&gt;
        cleanup_quota_test&lt;/li&gt;
&lt;/ol&gt;


&lt;p&gt;        echo &quot;Verify disk usage after delete&quot;&lt;br/&gt;
        USED=`getquota -u $TSTID global curspace`&lt;br/&gt;
        [ $USED -eq 0 ] || error &quot;Used space for user $TSTID isn&apos;t 0. $USED&quot;&lt;br/&gt;
...&lt;br/&gt;
}&lt;/p&gt;

&lt;p&gt;The test should wait for removal completion.&lt;/p&gt;

&lt;p&gt;With a single-core setup, the test fails.&lt;/p&gt;</description>
