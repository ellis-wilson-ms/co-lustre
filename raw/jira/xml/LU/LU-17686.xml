include/linux/fs.h:1760:47: note: expected &#8216;struct mnt_idmap *&#8217; but argument is of type &#8216;struct user_namespace *&#8217;
 1760 | bool inode_owner_or_capable(struct mnt_idmap *idmap,
      |                             ~~~~~~~~~~~~~~~~~~^~~~~
