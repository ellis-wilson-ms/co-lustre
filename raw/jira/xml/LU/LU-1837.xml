CMD: client-29vm7 mkdir -p /mnt/mds1
Starting mds1: -o user_xattr,acl  /dev/lvm-MDS/P1 /mnt/mds1
CMD: client-29vm7 mkdir -p /mnt/mds1; mount -t lustre -o user_xattr,acl  /dev/lvm-MDS/P1 /mnt/mds1
CMD: client-29vm7 PATH=/usr/lib64/lustre/tests:/usr/lib/lustre/tests:/usr/lib64/lustre/tests:/opt/iozone/bin:/usr/lib64/lustre/tests//usr/lib64/lustre/tests:/usr/lib64/lustre/tests:/usr/lib64/lustre/tests/../utils:/opt/iozone/bin:/usr/lib64/lustre/tests/mpi:/usr/lib64/lustre/tests/racer:/usr/lib64/lustre/../lustre-iokit/sgpdd-survey:/usr/lib64/lustre/tests:/usr/lib64/lustre/utils/gss:/usr/lib64/lustre/utils:/usr/lib64/openmpi/bin:/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin::/sbin NAME=autotest_config sh rpc.sh set_default_debug \&quot;0x33f0404\&quot; \&quot; 0xffb7e3ff\&quot; 32 
