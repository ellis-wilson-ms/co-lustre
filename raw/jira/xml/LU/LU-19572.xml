<item>
            <title>[LU-19572] lfs getdirstripe prints out component header when not needed</title>
                <link>https://jira.whamcloud.com/browse/LU-19572</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;current output:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
$ mkdir /mnt/lustre/test 
$ lfs getdirstripe /mnt/lustre/test
lmv_stripe_count: 0 lmv_stripe_offset: 0 lmv_hash_type: none
mdtidx &#160; &#160; &#160; &#160; &#160; FID[seq:oid:ver]&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;expected output:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
$ lfs getdirstripe /mnt/lustre/test
lmv_stripe_count: 0 lmv_stripe_offset: 0 lmv_hash_type: none&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;example where header is needed:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
$ lfs setdirstripe -c2 /mnt/lustre/test2
$ lfs getdirstripe /mnt/lustre/test2
lmv_stripe_count: 2 lmv_stripe_offset: 1 lmv_hash_type: crush
mdtidx &#160; &#160; &#160; &#160; &#160; FID[seq:oid:ver]
&#160; &#160; &#160;1 &#160; &#160; &#160; &#160; &#160; [0x240000400:0x2:0x0]
&#160; &#160; &#160;0 &#160; &#160; &#160; &#160; &#160; [0x200000401:0x2:0x0]&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
