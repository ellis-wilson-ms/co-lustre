23:43:18: &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffa0483e97&amp;gt;&amp;#93;&lt;/span&gt; lbug_with_loc+0x47/0xb0 &lt;span class=&quot;error&quot;&gt;&amp;#91;libcfs&amp;#93;&lt;/span&gt;&lt;br/&gt;
