                    <description>&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;cleanup_test32_mount() {
&#160; &#160; &#160; &#160; &#160; &#160;local rc=0
&#160; &#160; &#160; &#160; &#160; &#160;trap 0
&#160; &#160; &#160; &#160; &#160; &#160;local loopdev=$(losetup -a | grep $EXT2_DEV | sed -ne &lt;span class=&quot;code-quote&quot;&gt;&apos;s/:.*$/p&apos;&lt;/span&gt;)
