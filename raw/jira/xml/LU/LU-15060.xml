<item>
            <title>[LU-15060] sanity-flr test_208[a,b] defects</title>
                <link>https://jira.whamcloud.com/browse/LU-15060</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;sanity-flr  test_208a  and test_208b failed as:&lt;br/&gt;
      test_208a returned 2&lt;br/&gt;
      test_208b returned 2&lt;br/&gt;
on Lustre setup where osts are located not on one host because of stack_trap &quot;do_nodes $osts $LCTL set_param $old&quot; returns 2:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
[root@lm0117 ~]# pdsh -S -w lm0115,lm0116 /usr/sbin/lctl set_param osd-ldiskfs.lustre-OST0000.nonrotational=0 osd-ldiskfs.lustre-OST0001.nonrotational=0 osd-ldiskfs.lustre-OST0002.nonrotational=0 osd-ldiskfs.lustre-OST0003.nonrotational=0
lm0116: osd-ldiskfs.lustre-OST0002.nonrotational=0
lm0116: osd-ldiskfs.lustre-OST0003.nonrotational=0
lm0116: error: set_param: param_path &lt;span class=&quot;code-quote&quot;&gt;&apos;osd-ldiskfs/lustre-OST0000/nonrotational&apos;&lt;/span&gt;: No such file or directory
lm0116: error: set_param: param_path &lt;span class=&quot;code-quote&quot;&gt;&apos;osd-ldiskfs/lustre-OST0001/nonrotational&apos;&lt;/span&gt;: No such file or directory
pdsh@lm0117: lm0116: ssh exited with exit code 2
lm0115: osd-ldiskfs.lustre-OST0000.nonrotational=0
lm0115: osd-ldiskfs.lustre-OST0001.nonrotational=0
lm0115: error: set_param: param_path &lt;span class=&quot;code-quote&quot;&gt;&apos;osd-ldiskfs/lustre-OST0002/nonrotational&apos;&lt;/span&gt;: No such file or directory
lm0115: error: set_param: param_path &lt;span class=&quot;code-quote&quot;&gt;&apos;osd-ldiskfs/lustre-OST0003/nonrotational&apos;&lt;/span&gt;: No such file or directory
pdsh@lm0117: lm0115: ssh exited with exit code 2
[root@lm0117 ~]# echo $?
2
[root@lm0117 ~]# pdsh -S -w lm0115,lm0116 mount | grep lustre
lm0116: /dev/mapper/ost3_flakey on /mnt/lustre-ost3 type lustre (ro,svname=lustre-OST0002,mgsnode=192.168.1.11@tcp:192.168.1.12@tcp,osd=osd-ldiskfs,errors=remount-ro,user_xattr)
lm0116: /dev/mapper/ost4_flakey on /mnt/lustre-ost4 type lustre (ro,svname=lustre-OST0003,mgsnode=192.168.1.11@tcp:192.168.1.12@tcp,osd=osd-ldiskfs,errors=remount-ro,user_xattr)
lm0115: /dev/mapper/ost1_flakey on /mnt/lustre-ost1 type lustre (ro,svname=lustre-OST0000,mgsnode=192.168.1.11@tcp:192.168.1.12@tcp,osd=osd-ldiskfs,errors=remount-ro,user_xattr)
lm0115: /dev/mapper/ost2_flakey on /mnt/lustre-ost2 type lustre (ro,svname=lustre-OST0001,mgsnode=192.168.1.11@tcp:192.168.1.12@tcp,osd=osd-ldiskfs,errors=remount-ro,user_xattr)
[root@lm0117 ~]# 
