                            <comment id="222373" author="dmiter" created="Mon, 5 Mar 2018 14:23:39 +0000"  >&lt;p&gt;The first issue is just a warning about redundant &quot;&lt;b&gt;if (node)&lt;/b&gt;&quot; operator.&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;&lt;span class=&quot;code-keyword&quot;&gt;static&lt;/span&gt; bool free_node(struct cYAML *node, void *user_data, void **out)
{
	&lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (node-&amp;gt;cy_type == CYAML_TYPE_STRING)
		free(node-&amp;gt;cy_valuestring);
	&lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (node-&amp;gt;cy_string)
		free(node-&amp;gt;cy_string);
	&lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (node)
		free(node);
 
	&lt;span class=&quot;code-keyword&quot;&gt;return&lt;/span&gt; &lt;span class=&quot;code-keyword&quot;&gt;true&lt;/span&gt;;
}

&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</comment>
