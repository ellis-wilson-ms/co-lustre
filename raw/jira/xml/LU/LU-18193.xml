  Trace dump:
  = ./../tests/test-framework.sh:7090:error()
  = sanity.sh:26901:test_300l()
  = ./../tests/test-framework.sh:7435:run_one()
  = ./../tests/test-framework.sh:7498:run_one_logged()
  = ./../tests/test-framework.sh:7321:run_test()
