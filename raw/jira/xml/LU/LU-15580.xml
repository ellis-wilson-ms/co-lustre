<item>
            <title>[LU-15580] create_iam utility is broken and excluded from the build</title>
                <link>https://jira.whamcloud.com/browse/LU-15580</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;lustre/utils/create_iam utility is broken and excluded from the build, but can be useful during iam issues analysis.&#160;&lt;/p&gt;</description>
                <environment></environment>
        <key id="68780">LU-15580</key>
            <summary>create_iam utility is broken and excluded from the build</summary>
