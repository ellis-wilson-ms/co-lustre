<item>
            <title>[LU-2303] Bulk write replay &amp; grant interaction</title>
                <link>https://jira.whamcloud.com/browse/LU-2303</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Grant management when replaying bulk writes need to be reviewed since we might end up with a different result after replay than the original one.&lt;/p&gt;</description>
                <environment></environment>
        <key id="16429">LU-2303</key>
            <summary>Bulk write replay &amp; grant interaction</summary>
                <type id="1" iconUrl="https://jira.whamcloud.com/secure/viewavatar?size=xsmall&amp;avatarId=11303&amp;avatarType=issuetype">Bug</type>
