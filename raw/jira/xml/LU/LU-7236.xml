<item>
            <title>[LU-7236] OST connect and disconnect on demand</title>
                <link>https://jira.whamcloud.com/browse/LU-7236</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;currently Lustre client establishes connections to all targets at mount and tries to keep them alive all the time. at big scale this can lead to lots of extra work at mount, failover.&lt;/p&gt;</description>
                <environment></environment>
        <key id="32398">LU-7236</key>
