<item>
            <title>[LU-17994] Allow loopback-only test setups</title>
                <link>https://jira.whamcloud.com/browse/LU-17994</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;In some cases, it&apos;s useful to have the ability to start Lustre clients and servers locally using only 0@lo0. Lustre can then be tested without having to setup any networking facilities beforehand.&lt;/p&gt;</description>
                <environment></environment>
        <key id="83154">LU-17994</key>
            <summary>Allow loopback-only test setups</summary>
                <type id="4" iconUrl="https://jira.whamcloud.com/secure/viewavatar?size=xsmall&amp;avatarId=11310&amp;avatarType=issuetype">Improvement</type>
