<item>
            <title>[LU-10802] mismatch problem for wildcard in jobid TBF</title>
                <link>https://jira.whamcloud.com/browse/LU-10802</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;One user reported that:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;oss#lctl set_param ost.OSS.ost_io.nrs_policies=&lt;span class=&quot;code-quote&quot;&gt;&quot;tbf jobid&quot;&lt;/span&gt;
oss#lctl set_param ost.OSS.ost_io.nrs_tbf_rule=&lt;span class=&quot;code-quote&quot;&gt;&quot;start runas jobid={*.500} rate=10&quot;&lt;/span&gt;
oss# lctl get_param ost.OSS.ost_io.nrs_tbf_rule
ost.OSS.ost_io.nrs_tbf_rule=
regular_requests:
CPT 0:
runas {*.500} 10, ref 0
&lt;span class=&quot;code-keyword&quot;&gt;default&lt;/span&gt; {*} 10000, ref 2
high_priority_requests:
CPT 0:
runas {*.500} 10, ref 0
&lt;span class=&quot;code-keyword&quot;&gt;default&lt;/span&gt; {*} 10000, ref 1&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;

&lt;p&gt;------------------------------------------------------------------------------------------------------------&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;cli#lfs setstripe -c 1 -i 0 /mnt/lustre_2_10/qos/a1
cli#dd &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt;=/dev/zero of=/mnt/lustre_2_10/qos/a1 count=1000 bs=1M
1000+0 records in
1000+0 records out
1048576000 bytes (1.0 GB) copied, 12.2554 s, 85.6 MB/s&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;The rate is not under control.&lt;/p&gt;</description>
