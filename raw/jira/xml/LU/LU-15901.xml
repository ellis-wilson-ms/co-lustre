                    <description>&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
  &#160; &#160; &#160; list_add_tail(&amp;amp;obd-&amp;gt;u.cli.cl_chg_dev_linkage, &amp;amp;entry-&amp;gt;ced_obds);
&#160; &#160; &#160; &#160; list_add_tail(&amp;amp;entry-&amp;gt;ced_link, &amp;amp;chlg_registered_devices);

&#160; &#160; &#160; &#160; rc = chlg_minor_alloc(&amp;amp;minor);
&#160; &#160; &#160; &#160; &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (rc)
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; GOTO(out_unlock, rc);
...
out_minor:
&#160; &#160; &#160; &#160; chlg_minor_free(minor);
&#160; &#160; &#160; &#160; list_del_init(&amp;amp;obd-&amp;gt;u.cli.cl_chg_dev_linkage);
&#160; &#160; &#160; &#160; list_del(&amp;amp;entry-&amp;gt;ced_link);
out_unlock:
&#160; &#160; &#160; &#160; mutex_unlock(&amp;amp;chlg_registered_dev_lock);
&#160; &#160; &#160; &#160; &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (entry)
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; OBD_FREE_PTR(entry);
&#160; &#160; &#160; &#160; RETURN(rc);
 &lt;/pre&gt;
