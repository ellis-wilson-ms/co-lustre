<item>
            <title>[LU-764] test marked as fail but all subtest pass</title>
                <link>https://jira.whamcloud.com/browse/LU-764</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;&lt;a href=&quot;https://maloo.whamcloud.com/test_sets/657179ce-e58c-11e0-9909-52540025f9af&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;https://maloo.whamcloud.com/test_sets/657179ce-e58c-11e0-9909-52540025f9af&lt;/a&gt;&lt;/p&gt;

