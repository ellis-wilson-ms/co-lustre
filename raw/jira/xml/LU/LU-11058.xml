                            <comment id="232851" author="emoly.liu" created="Fri, 31 Aug 2018 14:47:48 +0000"  >&lt;p&gt;I can easily produce this issue on ldiskfs locally. The log shows it&apos;s related to the following code in process_param2_config():&lt;/p&gt;
&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;        if (kobj) {
                char *value = param;
                char *envp[3];
                int i;

                param = strsep(&amp;amp;value, &quot;=&quot;);
                envp[0] = kasprintf(GFP_KERNEL, &quot;PARAM=%s&quot;, param);
                envp[1] = kasprintf(GFP_KERNEL, &quot;SETTING=%s&quot;, value);
                envp[2] = NULL;

                rc = kobject_uevent_env(kobj, KOBJ_CHANGE, envp);
                for (i = 0; i &amp;lt; ARRAY_SIZE(envp); i++)
                        kfree(envp[i]);

                kobject_put(kobj);

                RETURN(rc);
        }
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</comment>
