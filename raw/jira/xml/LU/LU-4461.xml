<item>
            <title>[LU-4461] bad test in mdt_seq_fini_cli()</title>
                <link>https://jira.whamcloud.com/browse/LU-4461</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;In mdt_seq_fini_cli() we we need to reverse the sense of the check on ss-&amp;gt;ss_server_seq:&lt;/p&gt;
&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;static void mdt_seq_fini_cli(struct mdt_device *mdt)
{
        struct seq_server_site *ss = mdt_seq_site(mdt);

        if (ss == NULL)
                return;

        if (ss-&amp;gt;ss_server_seq == NULL)
                seq_server_set_cli(NULL, ss-&amp;gt;ss_server_seq, NULL);

        return;
}
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
