<item>
            <title>[LU-11139] remove or rename XATTR_NAME_ACL_ACCESS</title>
                <link>https://jira.whamcloud.com/browse/LU-11139</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;We have two names for each of the POSIX ACL xattrs:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
lustre/include/lustre_compat.h:# define XATTR_NAME_POSIX_ACL_ACCESS POSIX_ACL_XATTR_ACCESS
lustre/include/uapi/linux/lustre/lustre_idl.h:#define XATTR_NAME_ACL_ACCESS   &lt;span class=&quot;code-quote&quot;&gt;&quot;system.posix_acl_access&quot;&lt;/span&gt;

lustre/include/lustre_compat.h:# define XATTR_NAME_POSIX_ACL_DEFAULT POSIX_ACL_XATTR_DEFAULT
lustre/include/uapi/linux/lustre/lustre_idl.h:#define XATTR_NAME_ACL_DEFAULT  &lt;span class=&quot;code-quote&quot;&gt;&quot;system.posix_acl_default&quot;&lt;/span&gt;
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;We should use only one name for each.&lt;/p&gt;</description>
