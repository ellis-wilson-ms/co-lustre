&lt;p&gt;Oleg Drokin : &lt;a href=&quot;http://git.whamcloud.com/gitweb/?p=fs/lustre-dev.git&amp;amp;a=commit&amp;amp;h=3d6db8ae1070fbf9048bb5d949ff7c6d2dfa758d&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;3d6db8ae1070fbf9048bb5d949ff7c6d2dfa758d&lt;/a&gt;&lt;br/&gt;
