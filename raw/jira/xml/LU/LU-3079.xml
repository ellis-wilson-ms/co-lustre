&lt;a href=&quot;http://review.whamcloud.com/#/c/6968&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;http://review.whamcloud.com/#/c/6968&lt;/a&gt; - &lt;a href=&quot;https://jira.whamcloud.com/browse/LU-3079&quot; title=&quot;Support for 3.9 mainline kernel&quot; class=&quot;issue-link&quot; data-issue-key=&quot;LU-3079&quot;&gt;&lt;del&gt;LU-3079&lt;/del&gt;&lt;/a&gt;&lt;/p&gt;</comment>
