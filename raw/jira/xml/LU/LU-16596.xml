<item>
            <title>[LU-16596] Lustre client crashed with ASSERTION( ldlm_is_granted(lock) ) failed</title>
                <link>https://jira.whamcloud.com/browse/LU-16596</link>
                <project id="10000" key="LU">Lustre</project>
