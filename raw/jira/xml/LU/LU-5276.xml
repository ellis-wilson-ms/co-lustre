<item>
            <title>[LU-5276] ldiskfs patches for FC19</title>
                <link>https://jira.whamcloud.com/browse/LU-5276</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;This ticket intended to track ldiskfs patches work on FC19 3.7 kernel.&lt;/p&gt;</description>
                <environment></environment>
        <key id="25383">LU-5276</key>
            <summary>ldiskfs patches for FC19</summary>
