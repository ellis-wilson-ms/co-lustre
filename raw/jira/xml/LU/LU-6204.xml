license:        GPL
description:    Lustre Lite Client File System
author:         Sun Microsystems, Inc. &amp;lt;http://www.lustre.org/&amp;gt;
srcversion:     DE8D25CD9D11413C43993B7
depends:        obdclass,ptlrpc,libcfs,lov,lmv,mdc,lnet
vermagic:       2.6.32-431.29.2.el6_lustre.g61d3d7e.x86_64 SMP mod_unload modversions

$ modinfo lnet
