<item>
            <title>[LU-1127] need performance-sanity to work on Hyperion</title>
                <link>https://jira.whamcloud.com/browse/LU-1127</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;To have proper repeatable performance testing on hyperion, our performance-sanity test needs to work. Performance-sanity can then be used for the performance section of release testing.&lt;/p&gt;</description>
                <environment>Hyperion</environment>
        <key id="13256">LU-1127</key>
            <summary>need performance-sanity to work on Hyperion</summary>
