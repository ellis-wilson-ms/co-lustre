                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;session: &lt;a href=&quot;https://testing.hpdd.intel.com/test_sessions/2c5b36b7-c2a1-4e4a-89e7-993f6d6350b5&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;https://testing.hpdd.intel.com/test_sessions/2c5b36b7-c2a1-4e4a-89e7-993f6d6350b5&lt;/a&gt;&lt;br/&gt;
