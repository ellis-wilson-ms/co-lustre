			val=\$(/usr/sbin/lctl get_param -n catastrophe 2&amp;gt;&amp;amp;1);
			if [[ \$? -eq 0 &amp;amp;&amp;amp; \$val -ne 0 ]]; then
				echo \$(hostname -s): \$val;
				rc=\$val;
			fi;
			exit \$rc
pdsh@onyx-40vm5: onyx-40vm1: mcmd: connect failed: Connection refused
