<item>
            <title>[LU-10093] Nodemap fileset configuration lost </title>
                <link>https://jira.whamcloud.com/browse/LU-10093</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Fileset configuration parameter is lost if nodemap are unactivated and reactivated or defined before activating nodemap. Setting admin parameter also loose fileset config.&lt;/p&gt;

&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;[root@mds1 lustre-release]# lctl nodemap_add  SG1
[root@mds1 lustre-release]# lctl nodemap_add_range --name SG1 --range 192.168.10.131@tcp
[root@mds1 lustre-release]# lctl nodemap_set_fileset --name SG1 --fileset /isolated
[root@mds1 lustre-release]# lctl nodemap_activate 1
[root@mds1 lustre-release]# cat /proc/fs/lustre/nodemap/SG1/fileset

[root@mds1 lustre-release]# lctl nodemap_set_fileset --name SG1 --fileset /isolated
[root@mds1 lustre-release]# cat /proc/fs/lustre/nodemap/SG1/fileset
/isolated
[root@mds1 lustre-release]# lctl nodemap_modify --name SG1 --property admin --value 1
[root@mds1 lustre-release]# cat /proc/fs/lustre/nodemap/SG1/fileset

[root@mds1 lustre-release]# lctl nodemap_set_fileset --name SG1 --fileset /isolated
[root@mds1 lustre-release]# cat /proc/fs/lustre/nodemap/SG1/fileset

[root@mds1 lustre-release]# lctl nodemap_set_fileset --name SG1 --fileset /isolated
[root@mds1 lustre-release]# cat /proc/fs/lustre/nodemap/SG1/fileset
/isolated
[root@mds1 lustre-release]# lctl nodemap_activate 0
[root@mds1 lustre-release]# lctl nodemap_activate 1
[root@mds1 lustre-release]# cat /proc/fs/lustre/nodemap/SG1/fileset

[root@mds1 lustre-release]#
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
