<item>
            <title>[LU-9834] misleading loop in llapi_layout_test.c test 29</title>
                <link>https://jira.whamcloud.com/browse/LU-9834</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Smatch highlights:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;        &lt;span class=&quot;code-keyword&quot;&gt;for&lt;/span&gt; (i = LOV_MAX_STRIPE_COUNT-1; i &amp;lt;= 0; i--) {
                rc = llapi_layout_ost_index_get(layout, i, &amp;amp;ost0);
                ASSERTF(rc == 0, &lt;span class=&quot;code-quote&quot;&gt;&quot;errno = %d&quot;&lt;/span&gt;, errno);
                ASSERTF(ost0 == nost, &lt;span class=&quot;code-quote&quot;&gt;&quot;ost=%&quot;&lt;/span&gt;PRIu64&lt;span class=&quot;code-quote&quot;&gt;&quot;, nost=%&quot;&lt;/span&gt;PRIu64&quot;&quot;,
                        ost0, nost);
                nost++;
                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (nost == num_osts)
                        nost = 0;
        }
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;Since LOV_MAX_STRIPE_COUNT-1 is always &amp;gt; 0 and the end condition is &amp;lt;= 0 - we never enter this loop.&lt;/p&gt;</description>
