            <title>[LU-18059] lfs migrate fails for ost index stripe file</title>
                <link>https://jira.whamcloud.com/browse/LU-18059</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;#!/bin/sh&lt;/p&gt;

&lt;p&gt;set -x&lt;/p&gt;

&lt;p&gt;mkdir /mnt/lustre/ost_0000_folder&lt;/p&gt;

&lt;p&gt;mkdir -p /mnt/lustre/.cray/cds/template/ost_0001_folder&lt;/p&gt;

&lt;p&gt;lfs setstripe -o 0 /mnt/lustre/ost_0000_folder&lt;/p&gt;

&lt;p&gt;lfs setstripe -o 1 /mnt/lustre/.cray/cds/template/ost_0001_folder&lt;/p&gt;

&lt;p&gt;dd if=/dev/random of=/mnt/lustre/ost_0000_folder/test_00 bs=1M count=256&lt;/p&gt;

&lt;p&gt;lfs getstripe /mnt/lustre/ost_0000_folder/test_00&lt;/p&gt;

&lt;p&gt;lfs migrate --non-block --copy /mnt/lustre/.cray/cds/template/ost_0001_folder /mnt/lustre/ost_0000_folder/test_00&lt;/p&gt;</description>
