<item>
            <title>[LU-15499] WBC: deadlock for buffered write in parallel when test with dcp/ior</title>
                <link>https://jira.whamcloud.com/browse/LU-15499</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;When benchmark with IOR, we found the following deadlock:&lt;/p&gt;


&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
memfs_file_write_iter()
{
    ....
    down_read(&amp;amp;wbci-&amp;gt;wbci_rw_sem); &lt;span class=&quot;code-comment&quot;&gt;// lock 1
&lt;/span&gt;     &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (wbc_inode_data_caching(wbci)) {
                inode_lock(inode);     &lt;span class=&quot;code-comment&quot;&gt;// lock 2
&lt;/span&gt;                rc = generic_write_checks(iocb, iter);
                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (rc &amp;gt; 0)
                        rc = __generic_file_write_iter(iocb, iter);
                inode_unlock(inode);
                 ....
    }
    up_read(&amp;amp;wbci-&amp;gt;wbci_rw_sem);
    ....
}

memfs_write_begin(...)
{
    rc = memfs_write_getpage(inode, index, pagep);
        &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (rc == -ENOSPC) {
                &lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; rc2;

                &lt;span class=&quot;code-comment&quot;&gt;// need to call inode_unlock(inode);
&lt;/span&gt;                up_read(&amp;amp;wbci-&amp;gt;wbci_rw_sem);
                rc2 = wbc_make_data_commit(file-&amp;gt;f_path.dentry);
                down_read(&amp;amp;wbci-&amp;gt;wbci_rw_sem);
                &lt;span class=&quot;code-comment&quot;&gt;// need to call inode_lock(inode);
&lt;/span&gt;                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (rc2 &amp;lt; 0)
                        rc = rc2;
        }

&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
