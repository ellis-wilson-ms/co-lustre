<item>
            <title>[LU-10150] Update ZFS Version to 0.7.3</title>
                <link>https://jira.whamcloud.com/browse/LU-10150</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;&lt;a href=&quot;https://github.com/zfsonlinux/zfs/releases/tag/zfs-0.7.3&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;https://github.com/zfsonlinux/zfs/releases/tag/zfs-0.7.3&lt;/a&gt;&lt;/p&gt;


&lt;h4&gt;&lt;a name=&quot;%C2%A0&quot;&gt;&lt;/a&gt;&#160;&lt;/h4&gt;
&lt;h4&gt;&lt;a name=&quot;SupportedKernels&quot;&gt;&lt;/a&gt;Supported Kernels&lt;/h4&gt;
&lt;ul&gt;
	&lt;li&gt;Compatible with 2.6.32 - 4.13 Linux kernels.&lt;/li&gt;
&lt;/ul&gt;


&lt;h4&gt;&lt;a name=&quot;BugFixes&quot;&gt;&lt;/a&gt;Bug Fixes&lt;/h4&gt;
&lt;ul&gt;
	&lt;li&gt;Add DKMS package on Debian-based distributions (zfs) &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6044&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6044&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6731&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6731&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Fix function documentation to correctly mirror code &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6754&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6754&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Increase default zloop.sh vdev size &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6758&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6758&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Typo in dsl_dataset.h &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6756&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6756&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6273&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6273&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Fix chattr/cleanup failure &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6749&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6749&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Fixes for SPARC support &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6733&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6733&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6738&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6738&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6750&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6750&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Explicitly depend on icp module in initramfs hook &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6751&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6751&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Fix boot from ZFS issues &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6700&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6700&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6747&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6747&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Skip FREEOBJECTS for objects which can&apos;t exist &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/5699&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#5699&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6507&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6507&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6616&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6616&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Free objects when receiving full stream as clone &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/5699&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#5699&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6507&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6507&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6616&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6616&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Fix intra-pool resumable &apos;zfs send -t &apos; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6618&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6618&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6619&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6619&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6623&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6623&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Fix ARC behavior on 32-bit systems &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/5352&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#5352&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6734&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6734&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Fix inclusion of libgcc_s.so on Void &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6715&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6715&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Use bitwise &apos;&amp;amp;&apos; instead of logical &apos;&amp;amp;&amp;amp;&apos; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6684&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6684&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6722&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6722&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Remove unnecessary equality check &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6685&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6685&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Use linear abd in vdev_copy_uberblocks() &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6718&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6718&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6713&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6713&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;receive_freeobjects() skips freeing some objects &lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/6694&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6694&lt;/a&gt; &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6695&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6695&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Scale the dbuf cache with arc_c &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/6561&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#6561&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Add DKMS package on Debian-based distributions (spl) &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/657&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#657&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;Add parenthesis to btop and ptob macros (&lt;a href=&quot;https://github.com/zfsonlinux/zfs/issues/662&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#662&lt;/a&gt;) &lt;a href=&quot;https://github.com/zfsonlinux/zfs/pull/660&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;#660&lt;/a&gt;&lt;br/&gt;
It doesn&apos;t look like there are any pressing changes in this release related to Lustre.&lt;/li&gt;
&lt;/ul&gt;
</description>
