<item>
            <title>[LU-6510] mdt_handle_idmap unsafe access to req-&gt;rq_export</title>
                <link>https://jira.whamcloud.com/browse/LU-6510</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;smatch highlighted this unsafe usage:&lt;/p&gt;

&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;int mdt_handle_idmap(struct tgt_session_info *tsi)
{
        struct ptlrpc_request   *req = tgt_ses_req(tsi);
        struct mdt_device       *mdt = mdt_exp2dev(req-&amp;gt;rq_export);
        struct mdt_export_data *med;
        struct ptlrpc_user_desc *pud = req-&amp;gt;rq_user_desc;
        struct md_identity *identity;
        __u32 opc;
        int rc = 0;
        ENTRY;

        if (!req-&amp;gt;rq_export)
                RETURN(0);
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;Probably need to move the mdt variable assignment to after this check.&lt;/p&gt;</description>
