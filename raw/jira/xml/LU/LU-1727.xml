08:12:09: &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffa04a36b5&amp;gt;&amp;#93;&lt;/span&gt; lprocfs_counter_add+0x165/0x170 &lt;span class=&quot;error&quot;&gt;&amp;#91;lvfs&amp;#93;&lt;/span&gt;&lt;br/&gt;
08:12:09: &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffa0623367&amp;gt;&amp;#93;&lt;/span&gt; ldlm_pool_shrink+0x57/0xf0 &lt;span class=&quot;error&quot;&gt;&amp;#91;ptlrpc&amp;#93;&lt;/span&gt;&lt;br/&gt;
08:12:09: &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff81096a8f&amp;gt;&amp;#93;&lt;/span&gt; ? up+0x2f/0x50&lt;br/&gt;
08:12:09: &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffa062414b&amp;gt;&amp;#93;&lt;/span&gt; ldlm_pools_shrink+0x27b/0x330 &lt;span class=&quot;error&quot;&gt;&amp;#91;ptlrpc&amp;#93;&lt;/span&gt;&lt;br/&gt;
08:12:09: &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffffa0624233&amp;gt;&amp;#93;&lt;/span&gt; ldlm_pools_srv_shrink+0x13/0x20 &lt;span class=&quot;error&quot;&gt;&amp;#91;ptlrpc&amp;#93;&lt;/span&gt;&lt;br/&gt;
08:12:09: &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff81129bfa&amp;gt;&amp;#93;&lt;/span&gt; shrink_slab+0x12a/0x1a0&lt;br/&gt;
