                            <comment id="26793" author="simmonsja" created="Wed, 18 Jan 2012 08:46:26 +0000"  >&lt;p&gt;Since gerrit with the git commit hooks hates placing build errors in the comments section I placed them here. If you do make rpms in the ldiskfs directory the error you see is&lt;/p&gt;

&lt;p&gt;CONFIGURE_ARGS=$(echo $(eval echo $CONFIGURE_ARGS) | sed -re&lt;br/&gt;
&apos;s/--with-release=&lt;span class=&quot;error&quot;&gt;&amp;#91;^ &amp;#93;&lt;/span&gt;&lt;span class=&quot;error&quot;&gt;&amp;#91;^ &amp;#93;&lt;/span&gt;*//&apos;); \&lt;br/&gt;
RPMARGS=&quot;$RPMARGS --define \&quot;configure_args $CONFIGURE_ARGS\&quot;&quot;; \&lt;br/&gt;
if ! false; then \&lt;br/&gt;
    RPMARGS=&quot;$RPMARGS --define \&quot;build_lustre_tests 0\&quot;&quot;; \&lt;br/&gt;
fi; \&lt;br/&gt;
if ! ; then \&lt;br/&gt;
    RPMARGS=&quot;$RPMARGS --define \&quot;lustre_name lustre-client\&quot;&quot;; \&lt;br/&gt;
fi; \&lt;br/&gt;
echo &quot;Building Lustre RPM with $RPMARGS&quot;; \&lt;br/&gt;
eval rpmbuild $RPMARGS -ta lustre-ldiskfs-3.3.0.tar.gz&lt;br/&gt;
/bin/sh: -c: line 14: syntax error near unexpected token `;&apos;&lt;br/&gt;
/bin/sh: -c: line 14: `if ! ; then \&apos;&lt;br/&gt;
make&lt;span class=&quot;error&quot;&gt;&amp;#91;1&amp;#93;&lt;/span&gt;: *** &lt;span class=&quot;error&quot;&gt;&amp;#91;rpms-real&amp;#93;&lt;/span&gt; Error 2&lt;/p&gt;

&lt;p&gt;The autoMakefile.am in ldsikfs does not define the BUILD_SERVER flag. &lt;br/&gt;
This is from the autoMakefile in the real-rpms section coming out as&lt;/p&gt;

&lt;p&gt;CONFIGURE_ARGS=$$(echo $$(eval echo $$CONFIGURE_ARGS) | sed -re&lt;br/&gt;
&apos;s/--with-release=&lt;span class=&quot;error&quot;&gt;&amp;#91;^ &amp;#93;&lt;/span&gt;&lt;span class=&quot;error&quot;&gt;&amp;#91;^ &amp;#93;&lt;/span&gt;*//&apos;); \&lt;br/&gt;
RPMARGS=&quot;$$RPMARGS --define \&quot;configure_args $$CONFIGURE_ARGS\&quot;&quot;; \&lt;br/&gt;
if ! $(BUILD_TESTS); then \&lt;br/&gt;
    RPMARGS=&quot;$$RPMARGS --define \&quot;build_lustre_tests 0\&quot;&quot;; \&lt;br/&gt;
fi; \&lt;br/&gt;
if ! $(BUILD_SERVER); then \&lt;br/&gt;
    RPMARGS=&quot;$$RPMARGS --define \&quot;lustre_name lustre-client\&quot;&quot;; \&lt;br/&gt;
fi; \&lt;br/&gt;
echo &quot;Building Lustre RPM with $$RPMARGS&quot;; \&lt;br/&gt;
eval rpmbuild $$RPMARGS -ta $(distdir).tar.gz&lt;/p&gt;

&lt;p&gt;As you can sse no BUILD_SERVER define leads to the above error.&lt;/p&gt;</comment>
                            <comment id="26712" author="kent" created="Tue, 17 Jan 2012 09:42:45 +0000"  >&lt;p&gt;I ran into this problem trying to build the Lustre 1.8 fix for &lt;a href=&quot;https://jira.whamcloud.com/browse/LU-974&quot; title=&quot;Lustre does not ignore umask when default ACL with mask is set&quot; class=&quot;issue-link&quot; data-issue-key=&quot;LU-974&quot;&gt;&lt;del&gt;LU-974&lt;/del&gt;&lt;/a&gt; on CentOS 5.7 (with kernel 2.6.18-274.3.1.el5). &lt;br/&gt;
The simple one-line fix in &lt;a href=&quot;http://review.whamcloud.com/#change,1964&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;http://review.whamcloud.com/#change,1964&lt;/a&gt; seems to work.&lt;/p&gt;</comment>
