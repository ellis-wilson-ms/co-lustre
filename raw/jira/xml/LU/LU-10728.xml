                            <comment id="282317" author="jhammond" created="Thu, 15 Oct 2020 14:01:22 +0000"  >&lt;p&gt;&lt;a href=&quot;https://jira.whamcloud.com/secure/ViewProfile.jspa?name=cbordage&quot; class=&quot;user-hover&quot; rel=&quot;cbordage&quot;&gt;cbordage&lt;/a&gt;, could you take a look?&lt;/p&gt;</comment>
                            <comment id="221798" author="jhammond" created="Tue, 27 Feb 2018 14:15:36 +0000"  >&lt;p&gt;There are also several places where we do&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;&lt;span class=&quot;code-object&quot;&gt;char&lt;/span&gt; err_str[LNET_MAX_STR_LEN];
snprintf(err_str, sizeof(err_str), &lt;span class=&quot;code-quote&quot;&gt;&quot;\&quot;&lt;/span&gt;success\&quot;&quot;);
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;instead of just&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;&lt;span class=&quot;code-object&quot;&gt;char&lt;/span&gt; err_str[LNET_MAX_STR_LEN] = &lt;span class=&quot;code-quote&quot;&gt;&quot;\&quot;&lt;/span&gt;success\&quot;&quot;;
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;and where we explicitly &apos;\0&apos; terminate a buffer after calling snprintf():&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;snprintf(err_str, str_len,
			 &lt;span class=&quot;code-quote&quot;&gt;&quot;\&quot;&lt;/span&gt;failed to get &lt;span class=&quot;code-keyword&quot;&gt;interface&lt;/span&gt; addresses: %d\&quot;&quot;, -errno);
err_str[str_len - 1] = &lt;span class=&quot;code-quote&quot;&gt;&apos;\0&apos;&lt;/span&gt;;
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
</comment>
