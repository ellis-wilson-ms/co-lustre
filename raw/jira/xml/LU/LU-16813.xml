            <title>[LU-16813] sanity-flr/42 fails due to LU-16518</title>
                <link>https://jira.whamcloud.com/browse/LU-16813</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;&lt;a href=&quot;https://jira.whamcloud.com/browse/LU-16518&quot; title=&quot;Fix Clang build errors&quot; class=&quot;issue-link&quot; data-issue-key=&quot;LU-16518&quot;&gt;&lt;del&gt;LU-16518&lt;/del&gt;&lt;/a&gt; introduced this change:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
@@ -2942,7 +2942,7 @@ &lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; llapi_mirror_resync_many(&lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; fd, struct llapi_layout *layout,
