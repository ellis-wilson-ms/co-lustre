<item>
            <title>[LU-4925] bad negative dentry caching in striped directory</title>
                <link>https://jira.whamcloud.com/browse/LU-4925</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Using 2.5.57-87-g57d8f6d with or without &lt;a href=&quot;http://review.whamcloud.com/#/c/9511/17&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;http://review.whamcloud.com/#/c/9511/17&lt;/a&gt;, I see spurious negative dentry caching in a striped directory.&lt;/p&gt;
&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;# export MDSCOUNT=2
# export MOUNT_2=y
# llmount.sh
...
u:~# cd /mnt/lustre
u:lustre# rm -rf d0/0 d1/0 d0 d1
u:lustre# ls
u:lustre# lfs mkdir -c4 -i0 d0
u:lustre# lfs mkdir -c4 -i0 d1
u:lustre# sleep 30
u:lustre# touch d0/0
u:lustre# sys_rename d0/0 d1/0
u:lustre# sys_stat d0/0
cannot stat `d0/0&apos;: No such file or directory
u:lustre# sys_rename /mnt/lustre2/d1/0 /mnt/lustre2/d0/0
u:lustre# sys_stat d0/0
cannot stat `d0/0&apos;: No such file or directory
u:lustre# 
u:lustre# sys_stat d1/0
cannot stat `d1/0&apos;: No such file or directory
u:lustre# sys_getdents d0
d 180144002274689027 &apos;..&apos;
d 216172799293652995 &apos;.&apos;
d 144115188193296385 &apos;..&apos;
d 180144002274689027 &apos;..&apos;
d 234187197803134979 &apos;.&apos;
d 180144002274689027 &apos;.&apos;
r 234187197819912194 &apos;0&apos;
d 198158400784171011 &apos;.&apos;
d 180144002274689027 &apos;..&apos;
u:lustre# echo &amp;gt; d0/0
u:lustre# sys_stat d0/0
dev             743766374
ino      234187197819912194
mode                33188
nlink                   1
uid                     0
gid                     0
rdev                    0
size                    1
blksize           4194304
blocks                  8
atime          1397770152
mtime          1397770174
ctime          1397770174
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
