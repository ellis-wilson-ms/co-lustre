            <title>[LU-18332] lfs migrate is not setting the mirror count</title>
                <link>https://jira.whamcloud.com/browse/LU-18332</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Mirror (-N) is accepted but not set in lfs migrate&#160;&lt;/p&gt;

&lt;p&gt;&#160;&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
[root@co ~]# lfs migrate --verbose -N3 --stripe-count 1 --stripe-index 12 /lustre/testfs/client/test_file
/lustre/testfs/client/test_file
[root@co ~]#
[root@co ~]# lfs getstripe -N /lustre/testfs/client/test_file
[root@co ~]#&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;&#160;&lt;/p&gt;</description>
