CMD: trevis-77vm9 /usr/sbin/lctl get_param -n qmt.lustre-QMT0000.dt-qpool1.info 			&amp;gt;/dev/null 2&amp;gt;&amp;amp;1 || echo foo
CMD: trevis-77vm9 /usr/sbin/lctl get_param -n qmt.lustre-QMT0000.dt-qpool1.info 			&amp;gt;/dev/null 2&amp;gt;&amp;amp;1 || echo foo
CMD: trevis-77vm9 /usr/sbin/lctl get_param -n qmt.lustre-QMT0000.dt-qpool1.info
