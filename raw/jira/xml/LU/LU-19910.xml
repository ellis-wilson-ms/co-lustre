<item>
            <title>[LU-19910] osd-ldiskfs: incorrect sign extension caused by integer overflow in some cases</title>
                <link>https://jira.whamcloud.com/browse/LU-19910</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;In some cases (e.g. de-&amp;gt;inode &amp;gt; 2^31 {-}1), the int variable (ino) is too small to save the vaule of de&amp;#45;&amp;gt;inode so that extending it (ino) to unsigned long will result in various unexpected errors.&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
lustre/osd-ldiskfs/osd_handler.c:
&lt;span class=&quot;code-keyword&quot;&gt;static&lt;/span&gt; &lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; osd_ea_lookup_rec(&lt;span class=&quot;code-keyword&quot;&gt;const&lt;/span&gt; struct lu_env *env, struct osd_object *obj,
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160;struct dt_rec *rec, &lt;span class=&quot;code-keyword&quot;&gt;const&lt;/span&gt; struct lu_name *ln)
{
&#160; &#160; &#160; &#160; struct inode *dir = obj-&amp;gt;oo_inode;
&#160; &#160; &#160; &#160; struct dentry *dentry;
&#160; &#160; &#160; &#160; struct ldiskfs_dir_entry_2 *de;
&#160; &#160; &#160; &#160; struct buffer_head *bh;
&#160; &#160; &#160; &#160; struct lu_fid *fid = (struct lu_fid *)rec;
&#160; &#160; &#160; &#160; struct htree_lock *hlock = NULL;
&#160; &#160; &#160; &#160; &lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; ino;
&#160; &#160; &#160; &#160; &lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; rc;
        ...
  &#160; &#160; &#160; bh = osd_ldiskfs_find_entry(dir, &amp;amp;dentry-&amp;gt;d_name, &amp;amp;de, NULL, hlock);
&#160; &#160; &#160; &#160; &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (!IS_ERR(bh)) {
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; struct osd_thread_info *oti = osd_oti_get(env);
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; struct osd_inode_id *id = &amp;amp;oti-&amp;gt;oti_id;
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; struct osd_device *dev = osd_obj2dev(obj);
 &#160; &#160; &#160; &#160; &#160; &#160; 
                ino = le32_to_cpu(de-&amp;gt;inode);

&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (CFS_FAIL_CHECK(OBD_FAIL_FID_LOOKUP)) {
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; brelse(bh);
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; rc = osd_fail_fid_lookup(oti, dev, fid, ino);
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; GOTO(out, rc);
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; }

                rc = osd_get_fid_from_dentry(de, rec);
        ...&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
