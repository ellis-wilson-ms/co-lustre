<item>
            <title>[LU-17819] LMR1a: Replicate MGS Services to Multiple MDS</title>
                <link>https://jira.whamcloud.com/browse/LU-17819</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Replicate MGS running on MDT0000 to other MDTs/MDSes to improve MGS availability and resiliency in the face of server and/or storage issues.  This includes:&lt;/p&gt;
&lt;ul class=&quot;alternate&quot; type=&quot;square&quot;&gt;
	&lt;li&gt;redundant MGS/MGT configuration logs&lt;/li&gt;
	&lt;li&gt;redundant MGS Imperative Recovery service&lt;/li&gt;
&lt;/ul&gt;
</description>
                <environment></environment>
        <key id="67811">LU-17819</key>
            <summary>LMR1a: Replicate MGS Services to Multiple MDS</summary>
