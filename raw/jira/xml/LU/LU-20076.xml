<item>
            <title>[LU-20076] reduce testing time by optimizing test and test-framework.sh</title>
                <link>https://jira.whamcloud.com/browse/LU-20076</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;There are a number of subtests that take excessively long to complete for the value that they bring.  This ticket is for general fixes related to speeding up subtests and optimizing the test-framework.sh infrastructure to be more efficient.&lt;/p&gt;</description>
                <environment></environment>
        <key id="96799">LU-20076</key>
            <summary>reduce testing time by optimizing test and test-framework.sh</summary>
                <type id="4" iconUrl="https://jira.whamcloud.com/secure/viewavatar?size=xsmall&amp;avatarId=11310&amp;avatarType=issuetype">Improvement</type>
