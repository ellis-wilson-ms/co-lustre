            <title>[LU-1124] Add lustre to /etc/updatedb.conf </title>
                <link>https://jira.whamcloud.com/browse/LU-1124</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Please add &quot;lustre&quot; to PRUNEFS in /etc/updatedb.conf&lt;/p&gt;</description>
                <environment>Linux client 2.6.18-238.12.1.el5&lt;br/&gt;
lustre-client-1.8.6-wc1_2.6.18_238.12.1.el5 and lustre-client-modules-1.8.6-wc1_2.6.18_238.12.1.el5 RPMs installed</environment>
