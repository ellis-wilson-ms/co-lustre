 [&amp;lt;ffffffffa0a44c38&amp;gt;] out_index_insert+0x468/0x770 [ptlrpc]
 [&amp;lt;ffffffffa07a4ffb&amp;gt;] ? lu_object_put+0x12b/0x330 [obdclass]
 [&amp;lt;ffffffffa0a46cec&amp;gt;] out_handle+0x94c/0xdf0 [ptlrpc]
 [&amp;lt;ffffffffa09d89cc&amp;gt;] ? lustre_msg_get_opc+0x9c/0x110 [ptlrpc]
 [&amp;lt;ffffffffa0a3be5e&amp;gt;] tgt_request_handle+0x71e/0xb10 [ptlrpc]
 [&amp;lt;ffffffffa09eb6c4&amp;gt;] ptlrpc_main+0xe64/0x1990 [ptlrpc]
 [&amp;lt;ffffffff810096f0&amp;gt;] ? __switch_to+0xd0/0x320
 [&amp;lt;ffffffff8152970e&amp;gt;] ? thread_return+0x4e/0x770
 [&amp;lt;ffffffffa09ea860&amp;gt;] ? ptlrpc_main+0x0/0x1990 [ptlrpc]
 [&amp;lt;ffffffff8109abf6&amp;gt;] kthread+0x96/0xa0
