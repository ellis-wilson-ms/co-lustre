<item>
            <title>[LU-11075] suspicious code in ldlm_prepare_lru_list()</title>
                <link>https://jira.whamcloud.com/browse/LU-11075</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;There is some suspicious code in &lt;tt&gt;ldlm_prepare_lru_list()&lt;/tt&gt; which should be fixed:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;&lt;span class=&quot;code-keyword&quot;&gt;static&lt;/span&gt; &lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; ldlm_prepare_lru_list(struct ldlm_namespace *ns,
                                 struct list_head *cancels, &lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; count, &lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; max,
                                 &lt;span class=&quot;code-keyword&quot;&gt;enum&lt;/span&gt; ldlm_lru_flags lru_flags)
...
                        &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (!ldlm_is_canceling(lock) || &lt;span class=&quot;code-comment&quot;&gt;/* XXX &lt;span class=&quot;code-quote&quot;&gt;&apos;||&apos;&lt;/span&gt; should be &lt;span class=&quot;code-quote&quot;&gt;&apos;&amp;amp;&amp;amp;&apos;&lt;/span&gt; */&lt;/span&gt;
                            !ldlm_is_converting(lock))
                                &lt;span class=&quot;code-keyword&quot;&gt;break&lt;/span&gt;;
...
                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (result == LDLM_POLICY_SKIP_LOCK) {
                        lu_ref_del(&amp;amp;lock-&amp;gt;l_reference, __func__, current);
                        LDLM_LOCK_RELEASE(lock); &lt;span class=&quot;code-comment&quot;&gt;/* XXX release should follow &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; block. */&lt;/span&gt;
                        &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (no_wait) {
                                spin_lock(&amp;amp;ns-&amp;gt;ns_lock);
                                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (!list_empty(&amp;amp;lock-&amp;gt;l_lru) &amp;amp;&amp;amp;
                                    lock-&amp;gt;l_lru.prev == ns-&amp;gt;ns_last_pos)
                                        ns-&amp;gt;ns_last_pos = &amp;amp;lock-&amp;gt;l_lru;
                                spin_unlock(&amp;amp;ns-&amp;gt;ns_lock);
                        }
                        &lt;span class=&quot;code-keyword&quot;&gt;continue&lt;/span&gt;;
                }
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
