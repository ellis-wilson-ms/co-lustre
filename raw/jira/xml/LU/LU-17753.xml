<item>
            <title>[LU-17753] ll_merge_attr() may report wrong timestamps for racing stat()-s</title>
                <link>https://jira.whamcloud.com/browse/LU-17753</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;The following race between stats may lead to wrong timestamps provided to stat:&lt;/p&gt;
&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;Process 1
stat(&quot;file&quot;)
  ll_getattr_dentry
    ll_glimpse_size
      ll_merge_attr_nolock
        inode_set_mtime(inode, lli-&amp;gt;lli_mtime, 0)
        ..
        inode_set_mtime(inode, mtime, 0)

Process 2
stat(&quot;file&quot;)
  ll_getattr_dentry
    ll_glimpse_size
      ll_merge_attr_nolock
        inode_set_mtime(inode, lli-&amp;gt;lli_mtime, 0)

Process 1
    stat-&amp;gt;mtime = inode_get_mtime(inode);   &amp;lt;&amp;lt;&amp;lt; wrong mtime gets to stat
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
