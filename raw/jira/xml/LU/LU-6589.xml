<item>
            <title>[LU-6589] llapi_layout_pattern_set() rejects valid pattern values</title>
                <link>https://jira.whamcloud.com/browse/LU-6589</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;The input validation for this function appears to have a typo.  Presumably &quot;&amp;amp;&amp;amp;&quot; was intended instead of  &quot;||&quot;:&lt;/p&gt;

&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;	&lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (pattern != LLAPI_LAYOUT_DEFAULT ||
	    pattern != LLAPI_LAYOUT_RAID0) {
		errno = EOPNOTSUPP;
		&lt;span class=&quot;code-keyword&quot;&gt;return&lt;/span&gt; -1;
	}
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
                <environment></environment>
