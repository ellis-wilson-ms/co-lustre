<item>
            <title>[LU-8372] Suspicious dereference of pointer &apos;vma-&gt;vm_file&apos; in ll_vm_{open|close}</title>
                <link>https://jira.whamcloud.com/browse/LU-8372</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;&lt;span class=&quot;code-keyword&quot;&gt;static&lt;/span&gt; void ll_vm_open(struct vm_area_struct * vma)
{
            struct inode *inode    = file_inode(vma-&amp;gt;vm_file); &amp;lt;== &lt;span class=&quot;code-quote&quot;&gt;&apos;vma-&amp;gt;vm_file&apos;&lt;/span&gt; is dereferenced by being passed as argument 1 to function &lt;span class=&quot;code-quote&quot;&gt;&apos;file_inode&apos;&lt;/span&gt;.
            struct vvp_object *vob = cl_inode2vvp(inode);

            ENTRY;
            LASSERT(vma-&amp;gt;vm_file); &amp;lt;== &lt;span class=&quot;code-quote&quot;&gt;&apos;vma-&amp;gt;vm_file&apos;&lt;/span&gt; is checked &lt;span class=&quot;code-keyword&quot;&gt;for&lt;/span&gt; NULL.
            LASSERT(atomic_read(&amp;amp;vob-&amp;gt;vob_mmap_cnt) &amp;gt;= 0);
            atomic_inc(&amp;amp;vob-&amp;gt;vob_mmap_cnt);
            EXIT;
}
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;So, LASSERT(vma-&amp;gt;vm_file) is useless because if it&apos;s NULL it will crash in file_inode(vma-&amp;gt;vm_file).&lt;/p&gt;</description>
