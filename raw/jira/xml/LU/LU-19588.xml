                            <comment id="478142" author="qian_wc" created="Thu, 13 Nov 2025 04:33:12 +0000"  >&lt;p&gt;The following test script can not reproduce the problem...&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
test_118e() {
&#160; &#160; &#160; &#160; local dir=$DIR/$tdir
&#160; &#160; &#160; &#160; local dir0=$tdir.0
&#160; &#160; &#160; &#160; local nodes=$(comma_list $(mdts_nodes))
&#160; &#160; &#160; &#160; local policy=$(do_facet mds1 $LCTL get_param -n mdd.*.trash_can_delete_policy |
&#160;&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; head -n1)


&#160; &#160; &#160; &#160; (( MDS1_REL &amp;gt;= EXA7 &amp;amp;&amp;amp;
&#160;&#160; &#160; &#160; &#160; &#160; MDS1_VERSION &amp;gt;= $(version_code 2.16.0-ddn35) )) ||
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; skip &lt;span class=&quot;code-quote&quot;&gt;&quot;Need MDS &amp;gt;= 2.16.0-ddn35 &lt;span class=&quot;code-keyword&quot;&gt;for&lt;/span&gt; Trash via rename()&quot;&lt;/span&gt;


&#160; &#160; &#160; &#160; [[ &lt;span class=&quot;code-quote&quot;&gt;&quot;$mds1_FSTYPE&quot;&lt;/span&gt; == &lt;span class=&quot;code-quote&quot;&gt;&quot;ldiskfs&quot;&lt;/span&gt; ]] || skip_env &lt;span class=&quot;code-quote&quot;&gt;&quot;ldiskfs only test&quot;&lt;/span&gt;


&#160; &#160; &#160; &#160; trash_setup


&#160; &#160; &#160; &#160; stack_trap &lt;span class=&quot;code-quote&quot;&gt;&quot;do_nodes $nodes $LCTL set_param mdd.*.trash_can_delete_policy=$policy&quot;&lt;/span&gt;
&#160; &#160; &#160; &#160; do_nodes $nodes $LCTL set_param mdd.*.trash_can_delete_policy=&lt;span class=&quot;code-quote&quot;&gt;&quot;timestamp&quot;&lt;/span&gt;


&#160; &#160; &#160; &#160; mkdir_on_mdt0 $dir || error &lt;span class=&quot;code-quote&quot;&gt;&quot;failed to mkdir $dir&quot;&lt;/span&gt;
&#160; &#160; &#160; &#160; stack_trap &lt;span class=&quot;code-quote&quot;&gt;&quot;popd &amp;gt; /dev/&lt;span class=&quot;code-keyword&quot;&gt;null&lt;/span&gt;&quot;&lt;/span&gt;
&#160; &#160; &#160; &#160; pushd $dir &amp;gt; /dev/&lt;span class=&quot;code-keyword&quot;&gt;null&lt;/span&gt;
&#160; &#160; &#160; &#160; mkdir $dir0 || error &lt;span class=&quot;code-quote&quot;&gt;&quot;failed to mkdir $dir0&quot;&lt;/span&gt;
&#160; &#160; &#160; &#160; rmdir $dir0 || error &lt;span class=&quot;code-quote&quot;&gt;&quot;failed to rmdir $dir0&quot;&lt;/span&gt;
&#160; &#160; &#160; &#160; mkdir $dir0 || error &lt;span class=&quot;code-quote&quot;&gt;&quot;failed to mkdir $dir0&quot;&lt;/span&gt;
&#160; &#160; &#160; &#160; rmdir $dir0 || error &lt;span class=&quot;code-quote&quot;&gt;&quot;failed to rmdir $dir0&quot;&lt;/span&gt;
}
run_test 118e &lt;span class=&quot;code-quote&quot;&gt;&quot;TCU: repeated deletion with same fname &lt;span class=&quot;code-keyword&quot;&gt;for&lt;/span&gt; a empty dir&quot;&lt;/span&gt; &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</comment>
