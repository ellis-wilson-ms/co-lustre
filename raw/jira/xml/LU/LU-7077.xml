<item>
            <title>[LU-7077] Pointer &apos;hash&apos; returned from call to function &apos;cfs_hash_getref&apos; may be NULL and will be dereferenced.</title>
                <link>https://jira.whamcloud.com/browse/LU-7077</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;lustre/obdclass/genops.c:944&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;hash = cfs_hash_getref(exp-&amp;gt;exp_obd-&amp;gt;obd_gen_hash);
cfs_hash_del(hash, &amp;amp;ted-&amp;gt;ted_lcd-&amp;gt;lcd_generation,
	     &amp;amp;exp-&amp;gt;exp_gen_hash);
cfs_hash_putref(hash);
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;

&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;struct cfs_hash *cfs_hash_getref(struct cfs_hash *hs)
{
	&lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (atomic_inc_not_zero(&amp;amp;hs-&amp;gt;hs_refcount))
		&lt;span class=&quot;code-keyword&quot;&gt;return&lt;/span&gt; hs;
	&lt;span class=&quot;code-keyword&quot;&gt;return&lt;/span&gt; NULL;
}
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
