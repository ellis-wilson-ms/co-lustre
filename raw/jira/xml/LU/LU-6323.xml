                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt; Debian seems compiled client module with fixed configurations,&lt;/p&gt;

&lt;p&gt;338         ./configure --with-linux=$(KSRC_TREE) \&lt;br/&gt;
339                     --with-linux-obj=$(KSRC) \&lt;br/&gt;
