&lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;0&amp;gt;&amp;#93;&lt;/span&gt; mdt_reint_rec+0x11f/0x270 &lt;span class=&quot;error&quot;&gt;&amp;#91;mdt&amp;#93;&lt;/span&gt;&lt;br/&gt;
