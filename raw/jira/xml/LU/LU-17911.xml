0xffffffffc2de3a80 &amp;lt;lmv_fid2path+48&amp;gt;: &#160; xor&#160; &#160; %eax,%eax
0xffffffffc2de3a82 &amp;lt;lmv_fid2path+50&amp;gt;: &#160; call &#160; 0xffffffffc28941f0 &amp;lt;class_exp2obd&amp;gt;
0xffffffffc2de3a87 &amp;lt;lmv_fid2path+55&amp;gt;: &#160; mov&#160; &#160; -0x50(%rbp),%r8
 .......................
0xffffffffc2de3c5d &amp;lt;lmv_fid2path+525&amp;gt;:&#160; call &#160; 0xffffffffc2ddc9f0 &amp;lt;obd_iocontrol&amp;gt; 0xffffffffc2de3c62 &amp;lt;lmv_fid2path+530&amp;gt;:&#160; mov&#160; &#160; %eax,%r11d 
0xffffffffc2de3c65 &amp;lt;lmv_fid2path+533&amp;gt;:&#160; test &#160; %eax,%eax
0xffffffffc2de3c67 &amp;lt;lmv_fid2path+535&amp;gt;:&#160; je &#160; &#160; 0xffffffffc2de3c72 &amp;lt;lmv_fid2path+546&amp;gt; &lt;span class=&quot;code-comment&quot;&gt;/* rc == 0 */&lt;/span&gt;
0xffffffffc2de3c69 &amp;lt;lmv_fid2path+537&amp;gt;:&#160; cmp&#160; &#160; $0xffffffbe,%eax 
0xffffffffc2de3c6c &amp;lt;lmv_fid2path+540&amp;gt;:&#160; jne&#160; &#160; 0xffffffffc2de4175 &amp;lt;lmv_fid2path+1829&amp;gt; &lt;span class=&quot;code-comment&quot;&gt;/* &amp;amp;&amp;amp; rc != -EREMOTE) */&lt;/span&gt;
0xffffffffc2de3c72 &amp;lt;lmv_fid2path+546&amp;gt;:&#160; test &#160; %r15,%r15
0xffffffffc2de3c75 &amp;lt;lmv_fid2path+549&amp;gt;:&#160; jne&#160; &#160; 0xffffffffc2de41d2 &amp;lt;lmv_fid2path+1922&amp;gt; &lt;span class=&quot;code-comment&quot;&gt;/* &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (remote_gf != NULL) { */&lt;/span&gt;
.......................
0xffffffffc2f261d2 &amp;lt;+1922&amp;gt;:&#160; mov&#160; &#160; -0x80(%rbp),%r8 &#160;&#160;
0xffffffffc2f261d6 &amp;lt;+1926&amp;gt;:&#160; xor&#160; &#160; %esi,%esi &#160;&#160;
0xffffffffc2f261d8 &amp;lt;+1928&amp;gt;:&#160; lea&#160; &#160; 0x20(%r8),%rdi &#160;&#160;
0xffffffffc2f261dc &amp;lt;+1932&amp;gt;:&#160; call &#160; 0xffffffffacd97a50 &amp;lt;strnlen&amp;gt; &#160;&#160; 0xffffffffc2f261e1 &amp;lt;+1937&amp;gt;:&#160; test &#160; %rax,%rax &#160;&#160;
0xffffffffc2f261e4 &amp;lt;+1940&amp;gt;:&#160; jne&#160; &#160; 0xffffffffc2f2625c &amp;lt;lmv_fid2path+2060&amp;gt; &#160;&#160; 0xffffffffc2f261e6 &amp;lt;+1942&amp;gt;:&#160; mov&#160; &#160; $0xffffffffc2f4b330,%rdi &#160;&#160;
0xffffffffc2f261ed &amp;lt;+1949&amp;gt;:&#160; call &#160; 0xffffffffac4629d0 &amp;lt;fortify_panic&amp;gt; &#160;&#160;
........................
0xffffffffc2f2625c &amp;lt;+2060&amp;gt;:&#160; mov &#160; &#160;$0xffffffffc2f4b848,%rdi
0xffffffffc2f26263 &amp;lt;+2067&amp;gt;:&#160; call &#160; 0xffffffffac4629d0 &amp;lt;fortify_panic&amp;gt; 
End of assembler dump.

0xffffffffc2f4b330 &amp;lt;__func__.642&amp;gt;:&#160; &#160; &#160; &lt;span class=&quot;code-quote&quot;&gt;&quot;__fortify_strlen&quot;&lt;/span&gt;
0xffffffffc2f4b848 &amp;lt;__func__.190&amp;gt;:&#160; &#160; &#160; &lt;span class=&quot;code-quote&quot;&gt;&quot;strnlen&quot;&lt;/span&gt;
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;&#160;&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
Dump of assembler code &lt;span class=&quot;code-keyword&quot;&gt;for&lt;/span&gt; function fortify_panic:
&#160;&#160; 0xffffffffac4629d0 &amp;lt;+0&amp;gt;: &#160; &#160; push &#160; %rbp
&#160;&#160; 0xffffffffac4629d1 &amp;lt;+1&amp;gt;: &#160; &#160; mov&#160; &#160; %rdi,%rsi
&#160;&#160; 0xffffffffac4629d4 &amp;lt;+4&amp;gt;: &#160; &#160; mov&#160; &#160; $0xffffffffad8a9770,%rdi
&#160;&#160; 0xffffffffac4629db &amp;lt;+11&amp;gt;:&#160; &#160; mov&#160; &#160; %rsp,%rbp
&#160;&#160; 0xffffffffac4629de &amp;lt;+14&amp;gt;:&#160; &#160; call &#160; 0xffffffffabdae080 &amp;lt;_printk&amp;gt;
&#160;&#160; 0xffffffffac4629e3 &amp;lt;+19&amp;gt;:&#160; &#160; ud2 &#160;  &amp;gt;&amp;gt;&amp;gt;&amp;gt; crash &lt;span class=&quot;code-keyword&quot;&gt;for&lt;/span&gt; invalid Op !!!!!!
End of assembler dump. &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;it looks obvious that, after calling first strlen() occurence in lmv_fid2path() ,&#160; in all cases fortify_panic() will be called to print error msg and crash !!...&lt;/p&gt;

&lt;p&gt;So even if any faked flexible array usage must be fixed, I wonder if we did not also trigger some compiler issue in dealing with Fortify feature ??&lt;/p&gt;

&lt;p&gt;&#160;&lt;/p&gt;</comment>
