&amp;lt;4&amp;gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff81022d87&amp;gt;&amp;#93;&lt;/span&gt; ? intel_pmu_handle_irq+0x187/0x2f0&lt;br/&gt;
