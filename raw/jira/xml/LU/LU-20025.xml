                <created>Fri, 20 Mar 2026 15:03:53 +0000</created>
                <updated>Mon, 6 Apr 2026 16:22:18 +0000</updated>
                                                                                <due></due>
                            <votes>0</votes>
                                    <watches>2</watches>
                                                                            <comments>
                            <comment id="492526" author="JIRAUSER20209" created="Mon, 6 Apr 2026 16:21:39 +0000"  >&lt;p&gt;The issue might be that Router B and Node C negotiated a V2 version connection, and when forwarding IPv6 messages, the message is mapped from the V4 format to V2, causing NID truncation.&lt;/p&gt;</comment>
                            <comment id="492524" author="JIRAUSER20209" created="Mon, 6 Apr 2026 16:11:19 +0000"  >&lt;p&gt;Hi, &lt;a href=&quot;https://jira.whamcloud.com/secure/ViewProfile.jspa?name=simmonsja&quot; class=&quot;user-hover&quot; rel=&quot;simmonsja&quot;&gt;simmonsja&lt;/a&gt; ,&lt;/p&gt;

&lt;p&gt;The configuration does not use `lnetctl import`. The full setup is as follows:&lt;br/&gt;
We can use the following topology for testing:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
C &amp;lt;-tcp(IPv4)-&amp;gt; Router B &amp;lt;-tcp(IPv6)-&amp;gt; A &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;&lt;b&gt;Node A&lt;/b&gt;&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
lustre_rmmod
modprobe lnet
lnetctl lnet configure

# Configure IP
ip -6 addr add 2006::211:2233:4455:201/64 dev ens38
ip addr show dev ens38

# Configure LNet
lnetctl net add --net tcp6 --&lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; ens38
lnetctl net show

# Add LNet route
lnetctl route add --net tcp --gateway 2006::211:2233:4455:202@tcp6 --hop 1 --priority 0
lnetctl route show &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;&lt;b&gt;Router B&lt;/b&gt;&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
lustre_rmmod
modprobe lnet
lnetctl lnet configure

# Configure IPs
ip -6 addr add 2006::211:2233:4455:202/64 dev ens38
ip addr show dev ens38

ip addr add 10.0.2.232/22 dev ens37
ip addr show dev ens37

# Configure both networks
lnetctl net add --net tcp6 --&lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; ens38
lnetctl net add --net tcp &#160;--&lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; ens37

# Enable routing
lnetctl set routing 1

# Verify configuration
lnetctl net show
lnetctl route show
lnetctl peer show &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;&lt;b&gt;Node C&lt;/b&gt;&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
lustre_rmmod
modprobe lnet
lnetctl lnet configure

# Configure address
ip addr add 10.0.2.233/22 dev ens37
ip addr show dev ens37

# Configure LNet
lnetctl net add --net tcp --&lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; ens37
lnetctl net show

# Add route to o2ib network
lnetctl route add --net tcp6 --gateway 10.0.2.232@tcp --hop 1 --priority 0
lnetctl route show &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;On Router B, pinging both Node A and Node C succeeds.&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
[root@Router_B &#160;~]# lnetctl peer show
peer:
- &#160; &#160; primary nid: 2006::211:2233:4455:201@tcp6
&#160; &#160; &#160; Multi-Rail: &lt;span class=&quot;code-keyword&quot;&gt;true&lt;/span&gt;
&#160; &#160; &#160; peer ni:
&#160; &#160; &#160; - &#160; &#160; nid: 2006::211:2233:4455:201@tcp6
&#160; &#160; &#160; &#160; &#160; &#160; state: up
- &#160; &#160; primary nid: 10.0.2.233@tcp
&#160; &#160; &#160; Multi-Rail: &lt;span class=&quot;code-keyword&quot;&gt;true&lt;/span&gt;
&#160; &#160; &#160; peer ni:
&#160; &#160; &#160; - &#160; &#160; nid: 10.0.2.233@tcp
&#160; &#160; &#160; &#160; &#160; &#160; state: up
[root@Router_B &#160;~]#
[root@Router_B &#160;~]# lnetctl ping 2006::211:2233:4455:201@tcp6
ping:
- primary nid: 2006::211:2233:4455:201@tcp6
&#160; Multi-Rail: &lt;span class=&quot;code-keyword&quot;&gt;true&lt;/span&gt;
&#160; peer_ni:
&#160; - nid: 2006::211:2233:4455:201@tcp6
[root@Router_B &#160;~]#
[root@Router_B &#160;~]# lnetctl ping 10.0.2.233@tcp
ping:
- primary nid: 10.0.2.233@tcp
&#160; Multi-Rail: &lt;span class=&quot;code-keyword&quot;&gt;true&lt;/span&gt;
&#160; peer_ni:
&#160; - nid: 10.0.2.233@tcp&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
&lt;p&gt;Pinging from Node C to Node A fails with an error.&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
[root@Node_C ~]# lnetctl ping 2006::211:2233:4455:201@tcp6
manage:
- ping:
&#160; errno: -5
&#160; descr: ! &lt;span class=&quot;code-quote&quot;&gt;&apos;failed to ping 2006::211:2233:4455:201@tcp6: Input/output error&apos;&lt;/span&gt; &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</comment>
                            <comment id="491619" author="simmonsja" created="Fri, 20 Mar 2026 16:39:53 +0000"  >&lt;p&gt;How are setting this up? With lnetctl import?&lt;/p&gt;</comment>
                    </comments>
