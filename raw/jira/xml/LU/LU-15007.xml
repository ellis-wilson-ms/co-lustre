<item>
            <title>[LU-15007] Test-framework cannot enable quota using lctl set_param -P</title>
                <link>https://jira.whamcloud.com/browse/LU-15007</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Test-framework cannot enable quota using lctl set_param &amp;#45;P due to a typo in &quot;osd&amp;#45;&amp;#42;.&amp;#42;.quota_slave.enabled&quot; tunable.&lt;/p&gt;

&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;PERM_CMD=&quot;lctl set_param -P&quot; MDSCOUNT=2 ENABLE_QUOTA=yes QUOTA_TYPE=ugp DEBUG_SIZE=200 REFORMAT=yes MODOPTS_LNET=&quot;networks=tcp0(eth1)&quot;   RUNAS_ID=1000 ONLY=1 sh llmount.sh 
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;

&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;[root@devvm1 tests]# lctl get_param  osd-*.*.quota_slave.*enabled
osd-ldiskfs.lustre-MDT0000.quota_slave.enabled=none
osd-ldiskfs.lustre-MDT0001.quota_slave.enabled=none
osd-ldiskfs.lustre-OST0000.quota_slave.enabled=none
osd-ldiskfs.lustre-OST0001.quota_slave.enabled=none
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
