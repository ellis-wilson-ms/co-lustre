<item>
            <title>[LU-14492] wrong OSTCOUNT checks in overstripe sanity tests</title>
                <link>https://jira.whamcloud.com/browse/LU-14492</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;
test_27ce() {
        [[ $OSTCOUNT -ge $(($LOV_MAX_STRIPE_COUNT / 2)) ]] &amp;amp;&amp;amp;
                skip_env &lt;span class=&quot;code-quote&quot;&gt;&quot;too many osts, skipping&quot;&lt;/span&gt;
        [[ $($LCTL get_param mdc.*.&lt;span class=&quot;code-keyword&quot;&gt;import&lt;/span&gt;) =~ connect_flags.*overstriping ]] ||
                skip &lt;span class=&quot;code-quote&quot;&gt;&quot;server does not support overstriping&quot;&lt;/span&gt;
        # We &lt;span class=&quot;code-keyword&quot;&gt;do&lt;/span&gt; one more stripe than we have OSTs
        [ $OSTCOUNT -ge 159 ] || large_xattr_enabled ||
^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
                skip_env &lt;span class=&quot;code-quote&quot;&gt;&quot;ea_inode feature disabled&quot;&lt;/span&gt;

 &lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;

&lt;p&gt;if large xattrs are not enabled and OSTCOUNT is small, say, 10, the test is skipped as well as other overstripe tests.&lt;/p&gt;</description>
