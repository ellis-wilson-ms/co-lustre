                    <description>&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;test_250() {
        [ &lt;span class=&quot;code-quote&quot;&gt;&quot;$(facet_fstype ost$(($($GETSTRIPE -i $DIR/$tfile) + 1)))&quot;&lt;/span&gt; = &lt;span class=&quot;code-quote&quot;&gt;&quot;zfs&quot;&lt;/span&gt; ] \
