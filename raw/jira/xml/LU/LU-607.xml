&lt;span class=&quot;error&quot;&gt;&amp;#91;2011-01-20 19:14:30&amp;#93;&lt;/span&gt;&lt;span class=&quot;error&quot;&gt;&amp;#91;c0-0c0s5n0&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff810072b9&amp;gt;&amp;#93;&lt;/span&gt; try_stack_unwind+0x149/0x190&lt;br/&gt;
&lt;span class=&quot;error&quot;&gt;&amp;#91;2011-01-20 19:14:30&amp;#93;&lt;/span&gt;&lt;span class=&quot;error&quot;&gt;&amp;#91;c0-0c0s5n0&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff81005d90&amp;gt;&amp;#93;&lt;/span&gt; dump_trace+0x90/0x2f0&lt;br/&gt;
&lt;span class=&quot;error&quot;&gt;&amp;#91;2011-01-20 19:14:30&amp;#93;&lt;/span&gt;&lt;span class=&quot;error&quot;&gt;&amp;#91;c0-0c0s5n0&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff81006eb7&amp;gt;&amp;#93;&lt;/span&gt; show_trace_log_lvl+0x57/0x70&lt;br/&gt;
&lt;span class=&quot;error&quot;&gt;&amp;#91;2011-01-20 19:14:30&amp;#93;&lt;/span&gt;&lt;span class=&quot;error&quot;&gt;&amp;#91;c0-0c0s5n0&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff81006ee0&amp;gt;&amp;#93;&lt;/span&gt; show_trace+0x10/0x20&lt;br/&gt;
&lt;span class=&quot;error&quot;&gt;&amp;#91;2011-01-20 19:14:30&amp;#93;&lt;/span&gt;&lt;span class=&quot;error&quot;&gt;&amp;#91;c0-0c0s5n0&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff8125c69c&amp;gt;&amp;#93;&lt;/span&gt; dump_stack+0x72/0x7b&lt;br/&gt;
&lt;span class=&quot;error&quot;&gt;&amp;#91;2011-01-20 19:14:30&amp;#93;&lt;/span&gt;&lt;span class=&quot;error&quot;&gt;&amp;#91;c0-0c0s5n0&amp;#93;&lt;/span&gt; &lt;span class=&quot;error&quot;&gt;&amp;#91;&amp;lt;ffffffff8125c71a&amp;gt;&amp;#93;&lt;/span&gt; panic+0x75/0x13b&lt;br/&gt;
