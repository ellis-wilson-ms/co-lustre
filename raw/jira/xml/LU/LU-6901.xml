<item>
            <title>[LU-6901] LNet: Support dynamic number of NIDs in ping response</title>
                <link>https://jira.whamcloud.com/browse/LU-6901</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;It is desirable for ping to discover all NIDs on a router if the router has more than 16 NIDs.  Current restriction is 16.&lt;/p&gt;</description>
                <environment></environment>
        <key id="31213">LU-6901</key>
            <summary>LNet: Support dynamic number of NIDs in ping response</summary>
                <type id="2" iconUrl="https://jira.whamcloud.com/secure/viewavatar?size=xsmall&amp;avatarId=11311&amp;avatarType=issuetype">New Feature</type>
