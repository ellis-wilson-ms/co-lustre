AS_IF(&lt;span class=&quot;error&quot;&gt;&amp;#91;test &amp;quot;x$gss_conf_test&amp;quot; = xsuccess &amp;amp;&amp;amp; test &amp;quot;x$enable_gss&amp;quot; != xno&amp;#93;&lt;/span&gt;, [&lt;/p&gt;</comment>
