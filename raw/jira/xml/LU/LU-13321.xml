<item>
            <title>[LU-13321] sanity: 160f failed &quot;mds3: user cl6 index expected 0 + 2, but is 0&quot;</title>
                <link>https://jira.whamcloud.com/browse/LU-13321</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;This issue was created by maloo for Lai Siyao &amp;lt;lai.siyao@whamcloud.com&amp;gt;&lt;/p&gt;

&lt;p&gt;This issue relates to the following test suite run: &lt;a href=&quot;https://testing.whamcloud.com/test_sets/ddd8bcd4-cb29-447c-8d67-c749d3fc38f1&quot; class=&quot;external-link&quot; target=&quot;_blank&quot; rel=&quot;nofollow noopener&quot;&gt;https://testing.whamcloud.com/test_sets/ddd8bcd4-cb29-447c-8d67-c749d3fc38f1&lt;/a&gt;&lt;/p&gt;</description>
                <environment></environment>
