...&lt;br/&gt;
    mdcdev=`lctl get_param &lt;del&gt;n devices | awk &apos;/MDT0000-mdc&lt;/del&gt;/ &lt;/p&gt;
{print $1}
&lt;p&gt;&apos;`&lt;br/&gt;
    [ &quot;$mdcdev&quot; ] || return 2&lt;br/&gt;
    [ $(echo $mdcdev | wc -w) -eq 1 ] || &lt;/p&gt;
{ echo $mdcdev=$mdcdev &amp;amp;&amp;amp; return 3; }
