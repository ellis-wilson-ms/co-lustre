<item>
            <title>[LU-6875] thandle_get_sub_by_dt dereferences ERR_PTR pointer on error</title>
                <link>https://jira.whamcloud.com/browse/LU-6875</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;thandle_get_sub_by_dt function dereferences PTR_ERR pointer:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;                st = create_sub_thandle_with_thandle(top_th,
                                top_th-&amp;gt;tt_master_sub_thandle);
                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (IS_ERR(st))
                        GOTO(stop_trans, rc = PTR_ERR(st));
....
stop_trans:
        &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (rc &amp;lt; 0) {
                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (st != NULL)
                        OBD_FREE_PTR(st);
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
