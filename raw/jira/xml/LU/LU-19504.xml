				f28: R_X86_64_32S	.rodata.str1.1+0x9d  # kfreed &lt;span class=&quot;code-quote&quot;&gt;&apos;m&apos;&lt;/span&gt;: %d at %p.n
0000000000000f2c &amp;lt;mdd_device_free+0x18c&amp;gt; mov $0x0,%rdi
				f2f: R_X86_64_32S .bss+0xc20
