<item>
            <title>[LU-6543] memory leak in lfs_setstripe, lustre/utils/lfs.c</title>
                <link>https://jira.whamcloud.com/browse/LU-6543</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;lfs_setstripe() returns on an error return without free&apos;ing param&lt;/p&gt;

&lt;p&gt;                if (st_count &amp;gt; 0 &amp;amp;&amp;amp; nr_osts != st_count) &lt;/p&gt;
{
                        fprintf(stderr, &quot;error: %s: stripe count &apos;%d&apos; doesn&apos;t &quot;
                                &quot;match the number of OSTs: %d\n&quot;,
                                argv[0], st_count, nr_osts);
                        return CMD_HELP;
                }

&lt;p&gt;should be:&lt;/p&gt;

&lt;p&gt;                if (st_count &amp;gt; 0 &amp;amp;&amp;amp; nr_osts != st_count) &lt;/p&gt;
{
                        fprintf(stderr, &quot;error: %s: stripe count &apos;%d&apos; doesn&apos;t &quot;
                                &quot;match the number of OSTs: %d\n&quot;,
                                argv[0], st_count, nr_osts);
                        free(param);
                        return CMD_HELP;
                }</description>
                <environment>Ubuntu 15.04</environment>
