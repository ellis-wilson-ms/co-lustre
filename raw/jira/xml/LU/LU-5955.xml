<item>
            <title>[LU-5955] llapi_semantic_traverse() and lfs find skip any child directory named .lustre</title>
                <link>https://jira.whamcloud.com/browse/LU-5955</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;From llapi_semantic_traverse():&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;        &lt;span class=&quot;code-keyword&quot;&gt;while&lt;/span&gt; ((dent = readdir64(d)) != NULL) {
                &lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt; rc;

                param-&amp;gt;have_fileinfo = 0;

                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (!strcmp(dent-&amp;gt;d_name, &lt;span class=&quot;code-quote&quot;&gt;&quot;.&quot;&lt;/span&gt;) || !strcmp(dent-&amp;gt;d_name, &lt;span class=&quot;code-quote&quot;&gt;&quot;..&quot;&lt;/span&gt;))
                        &lt;span class=&quot;code-keyword&quot;&gt;continue&lt;/span&gt;;

                &lt;span class=&quot;code-comment&quot;&gt;/* Don&apos;t traverse .lustre directory */&lt;/span&gt;
                &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (!(strcmp(dent-&amp;gt;d_name, dot_lustre_name)))
                        &lt;span class=&quot;code-keyword&quot;&gt;continue&lt;/span&gt;;
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;
</description>
