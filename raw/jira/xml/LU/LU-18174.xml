&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160;osd_iget
&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; osd_iget2 &#160; &amp;lt;&amp;lt; &lt;span class=&quot;code-keyword&quot;&gt;this&lt;/span&gt; returns error
&lt;/pre&gt;
