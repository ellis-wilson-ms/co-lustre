                ...
                rc = cl_page_own(env, io, clp);
                ...
                /* check the page type: if the page is a host page, then do
                 * write directly */
                if (clp-&amp;gt;cp_type == CPT_CACHEABLE) {
------------------------&amp;gt; since transient pages are not stored in the radix tree
