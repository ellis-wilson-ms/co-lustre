<item>
            <title>[LU-17195] Add option to dump log on checksum error</title>
                <link>https://jira.whamcloud.com/browse/LU-17195</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;Add an option to dump debug log on checksum failure. Similar to dump_on_eviction/timeout&lt;/p&gt;</description>
                <environment></environment>
        <key id="78386">LU-17195</key>
            <summary>Add option to dump log on checksum error</summary>
                <type id="4" iconUrl="https://jira.whamcloud.com/secure/viewavatar?size=xsmall&amp;avatarId=11310&amp;avatarType=issuetype">Improvement</type>
                                            <priority id="4" iconUrl="https://jira.whamcloud.com/images/icons/priorities/minor.svg">Minor</priority>
                        <status id="6" iconUrl="https://jira.whamcloud.com/images/icons/statuses/closed.png" description="The issue is considered finished, the resolution is correct. Issues which are closed can be reopened.">Closed</status>
