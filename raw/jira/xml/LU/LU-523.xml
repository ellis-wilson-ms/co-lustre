<item>
            <title>[LU-523] No prepare_write for lockless IO</title>
                <link>https://jira.whamcloud.com/browse/LU-523</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;For page unaligned write, CLIO does prepare_write even for lockless IO and then write them back, this will cause data corruption since some of data is not covered by lock.&lt;/p&gt;</description>
                <environment></environment>
