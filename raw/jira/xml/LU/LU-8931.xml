<item>
            <title>[LU-8931] OBD_ALLOC_POST() body should be enclosed in a do ... while (0)</title>
                <link>https://jira.whamcloud.com/browse/LU-8931</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;The definition of OBD_ALLOC_POST() needs ot be corrected so that it can be used as it it used:&lt;/p&gt;
&lt;div class=&quot;code panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;codeContent panelContent&quot;&gt;
&lt;pre class=&quot;code-java&quot;&gt;#define OBD_ALLOC_POST(ptr, size, name)                                 \
                obd_memory_add(size);                                   \
                CDEBUG(D_MALLOC, name &lt;span class=&quot;code-quote&quot;&gt;&quot; &lt;span class=&quot;code-quote&quot;&gt;&apos;&quot;&lt;/span&gt; #ptr &lt;span class=&quot;code-quote&quot;&gt;&quot;&apos;&lt;/span&gt;: %d at %p.\n&quot;&lt;/span&gt;,       \
                       (&lt;span class=&quot;code-object&quot;&gt;int&lt;/span&gt;)(size), ptr)

...

#define __OBD_MALLOC_VERBOSE(ptr, cptab, cpt, size, flags)                    \
&lt;span class=&quot;code-keyword&quot;&gt;do&lt;/span&gt; {                                                                          \
        (ptr) = (cptab) == NULL ?                                             \
                kmalloc(size, (flags) | __GFP_ZERO) :                         \
                cfs_cpt_malloc(cptab, cpt, size, (flags) | __GFP_ZERO);       \
        &lt;span class=&quot;code-keyword&quot;&gt;if&lt;/span&gt; (likely((ptr) != NULL))                                            \
                OBD_ALLOC_POST(ptr, size, &lt;span class=&quot;code-quote&quot;&gt;&quot;kmalloced&quot;&lt;/span&gt;);                       \
} &lt;span class=&quot;code-keyword&quot;&gt;while&lt;/span&gt; (0)
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
