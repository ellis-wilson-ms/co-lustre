#!/bin/bash&lt;br/&gt;
set -e&lt;br/&gt;
cleanup () &lt;/p&gt;
{ trap 0; echo killing $1 ... ; kill -9 $1 || true; }
&lt;p&gt;/usr/sbin/lst new_session --timeo 100000 hh&lt;br/&gt;
/usr/sbin/lst add_group c 10.10.4.1@tcp 10.10.4.3@tcp&lt;br/&gt;
/usr/sbin/lst add_group s 10.10.4.133@tcp 10.10.4.135@tcp&lt;/p&gt;</description>
