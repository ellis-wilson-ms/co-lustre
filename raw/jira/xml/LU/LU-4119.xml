+             (obd-&amp;gt;obd_recovery_start + obd-&amp;gt;obd_recovery_time_hard))) {
+               CWARN(&quot;recovery is aborted by hard timeout\n&quot;);
+               obd-&amp;gt;obd_abort_recovery = 1;
+       }&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</comment>
