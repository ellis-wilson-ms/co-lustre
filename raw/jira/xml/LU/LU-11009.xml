lctl dl | grep &apos; ST &apos; || true
CMD: trevis-12vm6.trevis.hpdd.intel.com lsmod | grep lnet &amp;gt; /dev/null &amp;amp;&amp;amp;
lctl dl | grep &apos; ST &apos; || true
modules unloaded.
CMD: trevis-12vm9 test -b /dev/lvm-Role_MDS/P1
