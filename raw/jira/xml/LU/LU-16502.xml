<item>
            <title>[LU-16502] Bugs and sharp edges running LUTF</title>
                <link>https://jira.whamcloud.com/browse/LU-16502</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;I founds some bugs and sharp edges when trying to run LUTF. Fixing these and adding better error checking would make using LUTF smoother.&lt;/p&gt;</description>
                <environment></environment>
        <key id="74141">LU-16502</key>
