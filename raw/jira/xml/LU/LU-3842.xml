<item>
            <title>[LU-3842] handle missing crh in hsm_cdt_request_completed()</title>
                <link>https://jira.whamcloud.com/browse/LU-3842</link>
                <project id="10000" key="LU">Lustre</project>
                    <description>&lt;p&gt;hsm_cdt_request_completed() only partially handles the case where a restore handle could not be found.&lt;/p&gt;
&lt;div class=&quot;preformatted panel&quot; style=&quot;border-width: 1px;&quot;&gt;&lt;div class=&quot;preformattedContent panelContent&quot;&gt;
&lt;pre&gt;                /* give back layout lock */
                mutex_lock(&amp;amp;cdt-&amp;gt;cdt_restore_lock);
                crh = hsm_restore_hdl_find(cdt, &amp;amp;car-&amp;gt;car_hai-&amp;gt;hai_fid);
                if (crh != NULL)
                        list_del(&amp;amp;crh-&amp;gt;crh_list);
                mutex_unlock(&amp;amp;cdt-&amp;gt;cdt_restore_lock);
                /* just give back layout lock, we keep
                 * the reference which is given back
                 * later with the lock for HSM flags */
                if (!IS_ERR(obj))
                        mdt_object_unlock(mti, obj, &amp;amp;crh-&amp;gt;crh_lh, 1);
                if (crh != NULL)
                        OBD_SLAB_FREE_PTR(crh, mdt_hsm_cdt_kmem);
&lt;/pre&gt;
&lt;/div&gt;&lt;/div&gt;</description>
